{% extends "base.jinja" %}
{% block title %}Admin monitor — StudentCloud{% endblock %}
{% block content %}
<section class="space-y-8">
  <div class="flex flex-col gap-4 border-b border-slate-800 pb-6 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-violet-400">Staff monitor</p>
      <h1 class="mt-1 text-2xl font-semibold text-white">Platform monitor</h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-400">
        Live counts, uploads, deploys, security scans, and project logs. Use
        <a href="{{ django_admin_path }}" class="font-medium text-violet-300 underline hover:text-violet-200">Django admin (/sd/)</a>
        to edit rows, permissions, and raw data.
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ django_admin_path }}" class="rounded-lg bg-violet-600 px-3 py-2 text-sm font-semibold text-white hover:bg-violet-500">Open /sd/ admin</a>
      <a href="{{ url('admin_monitor:dashboard') }}" class="rounded-lg border border-slate-600 px-3 py-2 text-sm font-medium text-slate-200 hover:bg-slate-800">Refresh</a>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4 2xl:grid-cols-6">
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Users</p>
      <p class="mt-1 text-2xl font-bold text-white">{{ user_active }}</p>
      <p class="mt-1 text-xs text-slate-500">{{ user_total }} accounts · {{ user_staff }} staff · +{{ users_joined_week }} joined (7d)</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Projects</p>
      <p class="mt-1 text-2xl font-bold text-white">{{ project_active }}</p>
      <p class="mt-1 text-xs text-slate-500">{{ project_deleted }} deleted · {{ projects_custom_domain }} custom domains</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Project health</p>
      <p class="mt-1 text-2xl font-bold text-emerald-300">{{ projects_running }}</p>
      <p class="mt-1 text-xs text-rose-400">{{ projects_failed }} failed</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Uploads</p>
      <p class="mt-1 text-2xl font-bold text-white">{{ upload_total }}</p>
      <p class="mt-1 text-xs text-slate-500">{{ uploads_pending }} pending/scan · {% if upload_week_bytes %}{{ (upload_week_bytes / 1048576)|round(1) }}{% else %}0{% endif %} MB (7d)</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Logs</p>
      <p class="mt-1 text-2xl font-bold text-sky-300">{{ logs_day }}</p>
      <p class="mt-1 text-xs text-slate-500">{{ logs_week }} entries (7d)</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Alerts &amp; jobs</p>
      <p class="mt-1 text-2xl font-bold text-amber-300">{{ notifications_unread }}</p>
      <p class="mt-1 text-xs text-slate-500">{{ deployments_failed_week }} deploy fail (7d) · {{ backups_running }} backups running</p>
    </div>
  </div>

  {% if projects_by_type %}
    <div class="flex flex-wrap gap-2">
      {% for row in projects_by_type %}
        <span class="rounded-full border border-slate-700 bg-slate-900/80 px-3 py-1 text-xs text-slate-300">
          <span class="font-mono text-emerald-300/90">{{ row.label }}</span>
          <span class="text-slate-500">·</span>{{ row.c }}
        </span>
      {% endfor %}
    </div>
  {% endif %}

  {% if upload_status_rows %}
    <div class="flex flex-wrap gap-2 text-xs">
      {% for row in upload_status_rows %}
        <span class="rounded border border-slate-800 bg-slate-950 px-2 py-1 font-mono text-slate-400">{{ row.label }}: <span class="text-white">{{ row.c }}</span></span>
      {% endfor %}
    </div>
  {% endif %}

  <div class="grid gap-6 xl:grid-cols-2">
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">Recent uploads</h2>
        <a href="{{ url('admin:uploads_projectupload_changelist') }}" class="text-xs font-medium text-violet-400 hover:text-violet-300">All in /sd/</a>
      </div>
      <div class="max-h-[28rem] overflow-auto">
        <table class="min-w-full text-left text-xs">
          <thead class="sticky top-0 bg-slate-950/95 text-slate-500">
            <tr>
              <th class="px-3 py-2">When</th>
              <th class="px-3 py-2">Project</th>
              <th class="px-3 py-2">Owner</th>
              <th class="px-3 py-2">File</th>
              <th class="px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800 text-slate-300">
            {% for u in recent_uploads %}
              <tr class="hover:bg-slate-900/80">
                <td class="whitespace-nowrap px-3 py-2 font-mono text-slate-500">{{ u.created_at.strftime("%m-%d %H:%M") }}</td>
                <td class="px-3 py-2"><a href="{{ url('admin:projects_project_change', u.project.pk) }}" class="text-emerald-400 hover:underline">{{ u.project.name }}</a></td>
                <td class="max-w-[8rem] truncate px-3 py-2 text-slate-500">{{ u.owner.email }}</td>
                <td class="max-w-[10rem] truncate px-3 py-2 font-mono text-slate-400" title="{{ u.original_name }}">{{ u.original_name }}</td>
                <td class="px-3 py-2"><span class="rounded bg-slate-800 px-1.5 py-0.5">{{ u.get_status_display() }}</span></td>
              </tr>
            {% else %}
              <tr><td colspan="5" class="px-4 py-8 text-center text-slate-500">No uploads.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">Recent project logs</h2>
        <a href="{{ url('admin:logs_logentry_changelist') }}" class="text-xs font-medium text-violet-400 hover:text-violet-300">All in /sd/</a>
      </div>
      <ul class="max-h-[28rem] divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for e in recent_logs %}
          <li class="px-4 py-2.5 hover:bg-slate-900/60">
            <div class="flex flex-wrap items-baseline gap-2">
              <span class="font-mono text-slate-500">{{ e.created_at.strftime("%m-%d %H:%M") }}</span>
              <span class="rounded bg-slate-800 px-1.5 text-[10px] font-semibold uppercase text-slate-400">{{ e.get_kind_display() }}</span>
              <a href="{{ url('admin:projects_project_change', e.project.pk) }}" class="text-emerald-400 hover:underline">{{ e.project.name }}</a>
            </div>
            <p class="mt-1 line-clamp-2 text-slate-400">{{ e.message }}</p>
          </li>
        {% else %}
          <li class="px-4 py-8 text-center text-slate-500">No log entries.</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">Security scans</h2>
        <a href="{{ url('admin:security_scanreport_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">/sd/</a>
      </div>
      <ul class="max-h-80 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for s in recent_scans %}
          <li class="px-4 py-2.5">
            <span class="font-mono text-slate-500">{{ s.created_at.strftime("%m-%d %H:%M") }}</span>
            <span class="ml-2 font-semibold text-slate-200">{{ s.get_status_display() }}</span>
            {% if s.upload and s.upload.project %}
              <p class="mt-0.5 truncate text-slate-500">{{ s.upload.project.name }} · {{ s.upload.project.owner.email }}</p>
            {% endif %}
            {% if s.summary %}<p class="mt-1 line-clamp-2 text-slate-600">{{ s.summary }}</p>{% endif %}
          </li>
        {% else %}
          <li class="px-4 py-6 text-center text-slate-500">No scans.</li>
        {% endfor %}
      </ul>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">New users</h2>
        <a href="{{ url('admin:accounts_user_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">/sd/</a>
      </div>
      <ul class="max-h-80 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for u in recent_users %}
          <li class="flex items-center justify-between gap-2 px-4 py-2">
            <a href="{{ url('admin:accounts_user_change', u.pk) }}" class="truncate font-medium text-sky-300 hover:underline">{{ u.email }}</a>
            <span class="shrink-0 font-mono text-slate-500">{{ u.date_joined.strftime("%m-%d") }}</span>
          </li>
        {% else %}
          <li class="px-4 py-6 text-center text-slate-500">No users.</li>
        {% endfor %}
      </ul>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">New projects</h2>
        <a href="{{ url('admin:projects_project_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">/sd/</a>
      </div>
      <ul class="max-h-80 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for p in recent_projects %}
          <li class="px-4 py-2">
            <a href="{{ url('admin:projects_project_change', p.pk) }}" class="font-medium text-emerald-300 hover:underline">{{ p.name }}</a>
            <p class="mt-0.5 truncate text-slate-500">{{ p.owner.email }} · {{ p.get_project_type_display() }} · {{ p.get_status_display() }}</p>
          </li>
        {% else %}
          <li class="px-4 py-6 text-center text-slate-500">No projects.</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
    <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/50 px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-200">Recent deployments</h2>
      <a href="{{ url('admin:deployments_deployment_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">/sd/</a>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-left text-xs">
        <thead class="text-slate-500">
          <tr>
            <th class="px-3 py-2">When</th>
            <th class="px-3 py-2">Project</th>
            <th class="px-3 py-2">Status</th>
            <th class="px-3 py-2">Log</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-300">
          {% for d in recent_deployments %}
            <tr>
              <td class="whitespace-nowrap px-3 py-2 font-mono text-slate-500">{{ d.created_at.strftime("%m-%d %H:%M") }}</td>
              <td class="px-3 py-2"><a href="{{ url('admin:projects_project_change', d.project.pk) }}" class="text-emerald-400 hover:underline">{{ d.project.name }}</a></td>
              <td class="px-3 py-2">{{ d.get_status_display() }}</td>
              <td class="max-w-md truncate px-3 py-2 text-slate-500" title="{{ d.log }}">{{ d.log or "—" }}</td>
            </tr>
          {% else %}
            <tr><td colspan="4" class="px-4 py-6 text-center text-slate-500">No deployments.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="rounded-xl border border-slate-800 bg-slate-950/40 p-4 text-xs text-slate-500">
    <span class="font-semibold text-slate-400">Shortcuts:</span>
    <a class="ml-2 text-violet-400 hover:underline" href="{{ url('admin:students_batch_changelist') }}">Batches</a>
    · <a class="text-violet-400 hover:underline" href="{{ url('admin:students_quotaconfig_changelist') }}">Quotas</a>
    · <a class="text-violet-400 hover:underline" href="{{ url('admin:backups_backupjob_changelist') }}">Backups</a>
    · <a class="text-violet-400 hover:underline" href="{{ url('admin:databases_databaseinstance_changelist') }}">Databases</a>
    · <a class="text-violet-400 hover:underline" href="{{ url('admin:notifications_notification_changelist') }}">Notifications</a>
    · <a class="text-violet-400 hover:underline" href="{{ url('admin:billing_subscription_changelist') }}">Billing</a>
  </div>
</section>
{% endblock %}
