{% extends "base.jinja" %}
{% block title %}Become an Affiliate — Krizn{% endblock %}
{% block content %}
<section class="mx-auto max-w-2xl space-y-8 py-4">

  <div>
    <h1 class="text-3xl font-bold text-white">Affiliate Program</h1>
    <p class="mt-2 text-slate-400">Earn {{ product_commission_pct }}% on resell products and {{ server_commission_pct }}% on server plans. Log in, apply, then share your referral links from the dashboard.</p>
  </div>

  {% if application %}
    {% if application.status == 'pending' %}
    <div class="rounded-xl border border-amber-500/40 bg-amber-950/30 px-4 py-3 text-sm text-amber-100">
      Your application is <strong>pending review</strong>. We usually respond within 48 hours.
    </div>
    {% elif application.status == 'rejected' %}
    <div class="rounded-xl border border-rose-500/40 bg-rose-950/30 px-4 py-3 text-sm text-rose-100">
      Your previous application was not approved. You may submit a new application below.
    </div>
    {% endif %}
  {% endif %}

  <div class="grid gap-3 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-3">
      <p class="text-lg">📦</p>
      <p class="mt-1 text-sm font-semibold text-white">{{ product_commission_pct }}% on products</p>
      <p class="mt-0.5 text-xs text-slate-500">Commission on every resell product in a referred order.</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-3">
      <p class="text-lg">🖥</p>
      <p class="mt-1 text-sm font-semibold text-white">{{ server_commission_pct }}% on server plans</p>
      <p class="mt-0.5 text-xs text-slate-500">Commission when buyer adds a server plan at checkout.</p>
    </div>
    <div class="rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-3">
      <p class="text-lg">🔗</p>
      <p class="mt-1 text-sm font-semibold text-white">Shareable links</p>
      <p class="mt-0.5 text-xs text-slate-500">Store link + individual product links with your ref code.</p>
    </div>
  </div>

  {% if not can_apply|default(false) %}
  <div class="rounded-2xl border border-sky-500/30 bg-sky-500/10 p-6">
    <p class="text-center text-sm text-slate-300">Sign in to submit your affiliate application and get shareable product links.</p>
    {% if google_login_url %}
    <div class="mx-auto mt-5 max-w-md">
      {% with button_label = 'Sign in with Google to apply', next_url = url('affiliates:apply') %}
        {% include "components/_google_sign_in_button.jinja" %}
      {% endwith %}
    </div>
    {% endif %}
    <p class="mt-4 text-center text-xs text-slate-500">
      Or <a href="{{ login_url }}" class="text-emerald-400 hover:text-emerald-300">log in another way</a>
    </p>
  </div>
  {% elif not application or application.status == 'rejected' %}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    <h2 class="text-lg font-semibold text-white">Apply now</h2>
    <p class="mt-1 text-xs text-slate-500">Signed in as {{ request.user.email }}. All fields marked * are required.</p>

    {% if form.non_field_errors() %}
      <div class="mt-4 rounded-lg border border-rose-700/50 bg-rose-950/40 px-3 py-2 text-sm text-rose-200">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
      </div>
    {% endif %}

    <form method="post" class="mt-5 space-y-4">
      {{ csrf_input }}

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="block text-sm font-medium text-slate-200" for="id_name">Full name *</label>
          <input id="id_name" type="text" name="name" value="{{ form.name.value() or '' }}"
                 placeholder="Your full name"
                 class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
          {% if form.name.errors %}<p class="mt-1 text-xs text-rose-400">{{ form.name.errors|join(' ') }}</p>{% endif %}
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-200" for="id_email">Email address *</label>
          <input id="id_email" type="email" name="email" value="{{ form.email.value() or request.user.email }}" readonly
                 class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-400">
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="block text-sm font-medium text-slate-200" for="id_platform">Primary platform *</label>
          <select id="id_platform" name="platform"
                  class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 focus:border-emerald-500 focus:outline-none">
            {% for val, label in form.fields.platform.choices %}
              <option value="{{ val }}" {% if form.platform.value() == val %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-200" for="id_audience_size">Audience size</label>
          <input id="id_audience_size" type="text" name="audience_size" value="{{ form.audience_size.value() or '' }}"
                 placeholder="e.g. 5000 or 10k"
                 class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-200" for="id_website">Website / Channel URL</label>
        <input id="id_website" type="url" name="website" value="{{ form.website.value() or '' }}"
               placeholder="https://yourchannel.com"
               class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-200" for="id_message">Why do you want to join? *</label>
        <textarea id="id_message" name="message" rows="4"
                  placeholder="Tell us how you plan to promote Krizn resell products…"
                  class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">{{ form.message.value() or '' }}</textarea>
        {% if form.message.errors %}<p class="mt-1 text-xs text-rose-400">{{ form.message.errors|join(' ') }}</p>{% endif %}
      </div>

      <button type="submit"
              class="w-full rounded-lg bg-emerald-500 py-2.5 text-sm font-semibold text-slate-950 shadow hover:bg-emerald-400 active:scale-[0.99] transition-all">
        Submit Application →
      </button>
    </form>
  </div>
  {% endif %}
</section>
{% endblock %}
