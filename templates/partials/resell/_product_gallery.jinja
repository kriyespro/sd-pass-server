{# Multi-image gallery — pass `product`, optional `image_class` #}
{% set gallery = product.gallery %}
{% if gallery %}
  <div
    x-data="{ active: 0, images: [{% for img in gallery %}'{{ img.image.url }}'{% if not loop.last %}, {% endif %}{% endfor %}] }"
    class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60"
  >
    <div class="relative {{ image_class | default('aspect-square max-h-[28rem]') }} overflow-hidden bg-gradient-to-br from-slate-800 to-slate-900">
      <template x-for="(src, index) in images" :key="index">
        <img
          x-show="active === index"
          :src="src"
          alt="{{ product.name }}"
          class="absolute inset-0 h-full w-full object-cover"
        >
      </template>
      {% if product.badge_text %}
        <span class="absolute left-3 top-3 z-10 rounded-full bg-emerald-500 px-2.5 py-0.5 text-[11px] font-bold text-slate-950">{{ product.badge_text }}</span>
      {% endif %}
      {% if product.discount_pct %}
        <span class="absolute right-3 top-3 z-10 rounded-full bg-rose-500 px-2 py-0.5 text-[11px] font-bold text-white">-{{ product.discount_pct }}%</span>
      {% endif %}
    </div>
    {% if gallery | length > 1 %}
      <div class="flex gap-2 overflow-x-auto border-t border-slate-800 p-2">
        {% for img in gallery %}
          <button
            type="button"
            @click="active = {{ loop.index0 }}"
            :class="active === {{ loop.index0 }} ? 'ring-2 ring-emerald-400' : 'opacity-70 hover:opacity-100'"
            class="h-14 w-14 shrink-0 overflow-hidden rounded-lg border border-slate-700"
          >
            <img src="{{ img.image.url }}" alt="{{ img.alt }}" class="h-full w-full object-cover">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
{% else %}
  <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
    {% with image_class=image_class | default('aspect-square max-h-[28rem]') %}
      {% include "partials/resell/_product_image.jinja" %}
    {% endwith %}
  </div>
{% endif %}
