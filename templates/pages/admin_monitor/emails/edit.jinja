{% extends "base.jinja" %}
{% block title %}{{ 'Edit' if template_obj else 'Create' }} Email Template — Krizn{% endblock %}
{% block content %}
<section class="space-y-4">

  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">
        {{ 'Edit' if template_obj else 'Create' }} Template
      </h1>
      <p class="text-[11px] text-slate-500">
        {{ template_obj.get_template_type_display() if template_obj else template_type | replace('_', ' ') | title }}
      </p>
    </div>
    <a href="{{ url('admin_emails:list') }}"
       class="rounded-md border border-slate-700 bg-slate-900 px-2 py-1 text-[11px] font-medium text-slate-300 hover:bg-slate-800">
      ← All Templates
    </a>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">

    {# Form #}
    <div class="lg:col-span-2">
      <form method="post" class="space-y-3 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
        {{ csrf_input }}

        {# template_type hidden if editing #}
        {% if template_obj %}
          <input type="hidden" name="template_type" value="{{ template_obj.template_type }}">
        {% endif %}

        {% for field in form %}
          {% if field.name == 'template_type' and template_obj %}
            {# skip — hidden above #}
          {% elif field.name == 'html_body' %}
            <div>
              <div class="mb-1 flex items-center justify-between gap-2">
                <label class="text-[11px] font-semibold uppercase text-slate-400">
                  {{ field.label }}
                </label>
                <button type="button" id="load-default-btn"
                        class="rounded border border-sky-700/40 bg-sky-600/10 px-2 py-0.5 text-[10px] font-semibold text-sky-300 hover:bg-sky-600/20">
                  Load Default Template
                </button>
              </div>
              <textarea name="{{ field.html_name }}" id="html-body-textarea"
                        rows="22"
                        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 font-mono text-xs text-slate-200 placeholder-slate-600 focus:border-sky-600 focus:outline-none"
                        placeholder="Paste your HTML email template here. Use {{placeholder}} for dynamic values.">{{ field.value() or '' }}</textarea>
              {% if field.errors %}
                {% for e in field.errors %}
                  <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
                {% endfor %}
              {% endif %}
            </div>
          {% elif field.name == 'is_active' %}
            <div class="flex items-center gap-2">
              <input type="checkbox" name="{{ field.html_name }}" id="{{ field.id_for_label }}"
                     class="rounded border-slate-600 bg-slate-800 text-sky-600"
                     {{ 'checked' if field.value() else '' }}>
              <label for="{{ field.id_for_label }}" class="text-[11px] font-semibold uppercase text-slate-400">
                {{ field.label }}
              </label>
            </div>
          {% else %}
            <div>
              <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">
                {{ field.label }}
              </label>
              <input type="{{ 'text' if field.field.widget.__class__.__name__ == 'TextInput' else 'text' }}"
                     name="{{ field.html_name }}"
                     value="{{ field.value() or '' }}"
                     placeholder="{{ field.field.widget.attrs.get('placeholder', '') }}"
                     class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-sky-600 focus:outline-none">
              {% if field.errors %}
                {% for e in field.errors %}
                  <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
                {% endfor %}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}

        <div class="flex gap-2 pt-1">
          <button type="submit"
                  class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500">
            {{ 'Save Changes' if template_obj else 'Create Template' }}
          </button>
          <a href="{{ url('admin_emails:list') }}"
             class="rounded-lg border border-slate-700 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800">
            Cancel
          </a>
        </div>
      </form>
    </div>

    {# Placeholder reference #}
    <div class="space-y-3">
      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-3">
        <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-slate-500">Available Placeholders</p>
        <p class="mb-2 text-[10px] text-slate-600">Click to copy. Paste into subject or body.</p>
        {% if placeholders %}
          <div class="space-y-1">
            {% for placeholder, description in placeholders %}
              <div class="flex items-start gap-2">
                <button type="button"
                        onclick="navigator.clipboard.writeText('{{ placeholder }}')"
                        title="Click to copy"
                        class="shrink-0 rounded bg-slate-800 px-1.5 py-0.5 font-mono text-[10px] text-sky-300 hover:bg-slate-700 hover:text-sky-200">
                  {{ placeholder }}
                </button>
                <span class="text-[10px] leading-tight text-slate-500 pt-0.5">{{ description }}</span>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-[10px] italic text-slate-600">No placeholders defined.</p>
        {% endif %}
      </div>

      <div class="rounded-xl border border-amber-800/30 bg-amber-950/20 p-3">
        <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-wide text-amber-400">Tips</p>
        <ul class="space-y-1 text-[10px] text-slate-400">
          <li>• Use <code class="text-amber-300">{{placeholder}}</code> syntax exactly</li>
          <li>• Full HTML supported — style inline for email clients</li>
          <li>• Test with "Test Send" after saving</li>
          <li>• Subject line also supports placeholders</li>
        </ul>
      </div>
    </div>

  </div>

</section>

<script>
(function() {
  var btn = document.getElementById('load-default-btn');
  if (!btn) return;
  var ttype = '{{ template_type }}';
  btn.addEventListener('click', function() {
    if (!confirm('Load default template? This will replace the current content.')) return;
    fetch('/admin/emails/default/' + ttype + '/')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var ta = document.getElementById('html-body-textarea');
        if (ta && d.html) { ta.value = d.html; }
      });
  });
})();
</script>
{% endblock %}
