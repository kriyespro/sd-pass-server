{% extends "base.jinja" %}
{% block title %}Upload ZIP — {{ project.name }}{% endblock %}
{% block content %}
<section class="mx-auto max-w-2xl space-y-6">
  <p class="text-sm text-slate-400">
    <a href="{{ url('projects:dashboard') }}" class="font-medium text-emerald-400 hover:text-emerald-300">← Projects</a>
    · <span class="text-slate-300">{{ project.name }}</span>
  </p>
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    {# ── Project type badge + change button ── #}
    <div class="flex items-center justify-between flex-wrap gap-3 mb-4">
      <div class="flex items-center gap-2">
        {% if is_flask_project %}
          <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-500/15 px-3 py-1 text-xs font-semibold text-amber-300 ring-1 ring-amber-500/30">
            🐍 Flask App
          </span>
        {% else %}
          <span class="inline-flex items-center gap-1.5 rounded-full bg-sky-500/15 px-3 py-1 text-xs font-semibold text-sky-300 ring-1 ring-sky-500/30">
            🌐 Static Website
          </span>
        {% endif %}
        <span class="text-xs text-slate-500">Project type</span>
      </div>
      {# Change type mini-form #}
      <form method="post" action="{{ url('projects:change_type', slug=project.slug) }}" class="flex items-center gap-2">
        {{ csrf_input }}
        {% if is_flask_project %}
          <input type="hidden" name="project_type" value="static">
          <button type="submit"
            class="text-xs text-slate-400 hover:text-slate-200 underline"
            onclick="return confirm('Switch to Static Website? Flask runtime will stop.')">
            Switch to Static
          </button>
        {% else %}
          <input type="hidden" name="project_type" value="flask">
          <button type="submit"
            class="text-xs text-amber-400 hover:text-amber-300 underline font-medium">
            Switch to Flask App 🐍
          </button>
        {% endif %}
      </form>
    </div>

    <h1 class="text-xl font-semibold text-white">
      {% if is_flask_project %}🐍 Deploy Flask App{% else %}Upload project ZIP{% endif %}
    </h1>
    <p class="mt-2 text-sm text-slate-400">
      Max {{ upload_max_mb }} MB · <code class="text-emerald-300">.zip</code> only ·
      {% if is_flask_project %}
        First deploy takes 1–3 minutes (installing packages). Subsequent deploys are faster.
      {% else %}
        After upload, a security scan runs then files are published.
      {% endif %}
    </p>

    {% if is_static_project %}
      <p class="mt-2 text-sm text-sky-300/90">
        Or upload several HTML/CSS/JS files at once (no ZIP):
        <a href="{{ url('projects:upload_static_files', slug=project.slug) }}" class="font-semibold text-sky-300 underline hover:text-sky-200">multi-file upload</a>
      </p>
    {% endif %}

    {% if is_flask_project %}
    {# ── Flask account status badge ── #}
    {% if flask_enabled is defined %}
      {% if flask_enabled %}
        <div class="mt-4 flex items-center gap-3 rounded-xl border border-emerald-700/50 bg-emerald-950/30 px-4 py-3">
          <span class="text-2xl">🐍</span>
          <div class="flex-1">
            <p class="text-sm font-semibold text-emerald-200">Python Flask support is enabled on your account</p>
            <p class="text-xs text-emerald-400/80 mt-0.5">
              {{ flask_quota_used }} of {{ flask_quota_total }} Flask app{{ 's' if flask_quota_total != 1 }} used
              {% if flask_quota_used < flask_quota_total %}
                · <span class="text-emerald-300">{{ flask_quota_total - flask_quota_used }} slot{{ 's' if (flask_quota_total - flask_quota_used) != 1 }} available</span>
              {% else %}
                · <span class="text-amber-300">Limit reached — upgrade plan or add Flask add-on</span>
              {% endif %}
            </p>
          </div>
          <span class="rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-bold text-emerald-300 ring-1 ring-emerald-500/40">
            ✓ Active
          </span>
        </div>
      {% else %}
        <div class="mt-4 flex items-center gap-3 rounded-xl border border-rose-700/50 bg-rose-950/20 px-4 py-3">
          <span class="text-2xl">🔒</span>
          <div class="flex-1">
            <p class="text-sm font-semibold text-rose-200">Flask support not available on your current plan</p>
            <p class="text-xs text-rose-400/80 mt-0.5">Upgrade to WordPress Pro (₹3,699/yr) or higher to deploy Flask apps.</p>
          </div>
          <a href="{{ url('billing:redeem') }}"
             class="shrink-0 rounded-lg bg-rose-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-rose-500">
            Upgrade
          </a>
        </div>
      {% endif %}
    {% endif %}

    {# ── Flask deploy instructions ── #}
    <div class="mt-5 rounded-xl border border-amber-700/40 bg-amber-950/20 p-5 space-y-4 text-sm">
      <p class="font-semibold text-amber-200">How to package your Flask app</p>

      <div class="space-y-2 text-slate-300">
        <p class="font-medium text-slate-100">1. Required file — <code class="text-amber-300">app.py</code></p>
        <p class="text-slate-400 text-xs">Must be at the ZIP root. Must contain <code class="text-amber-300">app = Flask(__name__)</code></p>
        <pre class="mt-1 rounded-lg bg-slate-900 px-4 py-3 text-xs text-emerald-300 overflow-x-auto">from flask import Flask, render_template
app = Flask(__name__)

@app.route('/')
def index():
    return render_template('index.html')</pre>
      </div>

      <div class="space-y-2 text-slate-300">
        <p class="font-medium text-slate-100">2. Optional — <code class="text-amber-300">requirements.txt</code></p>
        <p class="text-slate-400 text-xs">List any extra packages. <code>flask</code> and <code>gunicorn</code> are always installed automatically.</p>
        <pre class="mt-1 rounded-lg bg-slate-900 px-4 py-3 text-xs text-emerald-300 overflow-x-auto">flask-sqlalchemy
python-dotenv</pre>
      </div>

      <div class="space-y-2 text-slate-300">
        <p class="font-medium text-slate-100">3. Recommended ZIP structure</p>
        <pre class="mt-1 rounded-lg bg-slate-900 px-4 py-3 text-xs text-slate-300 overflow-x-auto">myapp.zip
├── app.py               ← required entry point
├── requirements.txt     ← optional
├── database.db          ← SQLite (optional)
├── templates/
│   ├── index.html
│   └── base.html
└── static/
    ├── style.css
    ├── script.js
    └── images/
        └── logo.png</pre>
      </div>

      <div class="rounded-lg border border-slate-700 bg-slate-900/60 px-4 py-3 space-y-1.5 text-xs text-slate-400">
        <p class="font-semibold text-slate-300">✅ Allowed file types</p>
        <p><span class="text-amber-300">.py</span> Python · <span class="text-sky-300">.html .htm</span> Templates · <span class="text-emerald-300">.css .js</span> Static · <span class="text-slate-300">.sqlite .db</span> SQLite</p>
        <p><span class="text-slate-300">.png .jpg .jpeg .gif .webp .svg .ico</span> Images · <span class="text-slate-300">.woff .woff2 .ttf</span> Fonts</p>
        <p><span class="text-slate-300">.txt .json .csv .yaml .toml .cfg .ini .env</span> Config / data</p>
        <p class="text-rose-400 mt-1">❌ Not allowed: .exe · .sh · .bat · .php — and no <code>.venv/</code> folder in the ZIP (we create it for you)</p>
      </div>

      <div class="rounded-lg border border-sky-700/40 bg-sky-950/20 px-4 py-3 text-xs text-sky-300 space-y-1">
        <p class="font-semibold text-sky-200">💡 Tips</p>
        <ul class="space-y-1 list-disc pl-4 text-slate-300">
          <li>Entry point must be <code class="text-amber-300">app.py</code> with variable <code class="text-amber-300">app = Flask(__name__)</code></li>
          <li>For SQLite use a relative path: <code class="text-emerald-300">db = sqlite3.connect('database.db')</code></li>
          <li>Templates folder must be named <code class="text-emerald-300">templates/</code></li>
          <li>Static files folder must be named <code class="text-emerald-300">static/</code></li>
          <li>Do NOT include <code class="text-rose-300">.venv/</code> or <code class="text-rose-300">__pycache__/</code> in the ZIP</li>
          <li>First visit after deploy may take 3–5 seconds while gunicorn warms up</li>
        </ul>
      </div>
    </div>
    {% endif %}
    <div x-data="uploadForm({ redirectFallback: '{{ url('projects:dashboard') }}' })">
    {% include "partials/uploads/_upload_progress_overlay.jinja" %}
    <form method="post" enctype="multipart/form-data" class="mt-6 space-y-4" @submit.prevent="start($event)">
      {{ csrf_input }}
      {% if form.non_field_errors() %}
        <div class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-3 py-2 text-sm text-rose-100">
          {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
        </div>
      {% endif %}
      <div>
        <label class="block text-sm font-medium text-slate-200" for="{{ form.file.id_for_label }}">ZIP file</label>
        {{ form.file }}
        {% if form.file.errors %}
          {% for err in form.file.errors %}<p class="mt-1 text-sm text-rose-300">{{ err }}</p>{% endfor %}
        {% endif %}
      </div>
      {% if not is_flask_project %}
      <div x-data="{ subfolder: '' }">
        <label class="block text-sm font-medium text-slate-200" for="subfolder-input">
          Upload into subfolder <span class="text-slate-500 font-normal">(optional)</span>
        </label>
        <input
          id="subfolder-input"
          type="text"
          name="subfolder"
          x-model="subfolder"
          placeholder="e.g. blog  or  portfolio"
          maxlength="64"
          class="mt-1 block w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600"
        />
        <template x-if="subfolder.trim()">
          <div class="mt-1.5 space-y-0.5 text-xs">
            {% if sub_base_url %}
              <p class="text-emerald-400">↳ <span x-text="'{{ sub_base_url }}' + subfolder.trim().replace(/^\/+|\/+$/g, '') + '/'"></span></p>
            {% endif %}
            {% if custom_base_url %}
              <p class="text-amber-400">↳ <span x-text="'{{ custom_base_url }}' + subfolder.trim().replace(/^\/+|\/+$/g, '') + '/'"></span></p>
            {% endif %}
          </div>
        </template>
        <template x-if="!subfolder.trim()">
          <p class="mt-1 text-xs text-slate-500">Leave blank to deploy to the site root.</p>
        </template>
        {% if deployed_subfolders %}
          <p class="mt-2 text-xs text-slate-500">
            Already deployed:
            {% for sf in deployed_subfolders %}
              <code class="text-slate-400">{{ sf if sf else '/' }}</code>{% if not loop.last %}, {% endif %}
            {% endfor %}
          </p>
        {% endif %}
      </div>
      {% endif %}
      {% if is_flask_project and flask_enabled is defined and not flask_enabled %}
        <a href="{{ url('billing:redeem') }}"
           class="inline-block rounded-lg bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-500">
          🔒 Upgrade plan to deploy Flask apps
        </a>
      {% else %}
        <button type="submit"
          class="rounded-lg {% if is_flask_project %}bg-amber-500 hover:bg-amber-400{% else %}bg-emerald-500 hover:bg-emerald-400{% endif %} px-4 py-2 text-sm font-semibold text-slate-950 disabled:opacity-50"
          :disabled="uploading">
          {% if is_flask_project %}🐍 Upload &amp; Deploy Flask App{% else %}Upload &amp; queue scan{% endif %}
        </button>
      {% endif %}
    </form>
    </div>
  </div>

  {% if recent_uploads %}
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-4">
      <h2 class="text-sm font-semibold text-slate-300">Recent uploads</h2>
      <ul class="mt-2 space-y-1 text-sm text-slate-400">
        {% for u in recent_uploads %}
          <li class="flex justify-between gap-2">
            <span class="truncate text-slate-200">{{ u.original_name }}</span>
            <span class="shrink-0 font-mono text-xs">{{ u.get_status_display() }}</span>
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</section>
{% endblock %}
