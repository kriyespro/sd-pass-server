{% extends "base.jinja" %}
{% block title %}Page not found{% endblock %}
{% block content %}
<div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-10 text-center">
  <p class="text-sm font-semibold uppercase tracking-wide text-amber-300">404</p>
  <h1 class="mt-2 text-2xl font-semibold text-white">We could not find that page</h1>
  <p class="mt-3 text-slate-400">Check the URL or head back home.</p>
  <a href="{{ url('home') }}" class="mt-6 inline-flex rounded-lg bg-emerald-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Go home</a>
</div>
{% endblock %}
