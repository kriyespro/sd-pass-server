{% extends "base.jinja" %}
{% block title %}Home — StudentCloud Deploy{% endblock %}
{% block content %}
<section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-8 shadow-xl shadow-slate-950/40">
  <p class="text-sm font-medium uppercase tracking-wide text-emerald-400/90">Mini PaaS for institutes</p>
  <h1 class="mt-2 text-3xl font-semibold text-white sm:text-4xl">Deploy student apps from the browser</h1>
  <p class="mt-4 max-w-2xl text-slate-300">
    Students ship projects with guardrails; trainers and admins keep visibility—no raw server access.
  </p>
  <div class="mt-8 flex flex-wrap gap-3">
    {% if request.user.is_authenticated %}
      <a href="{{ url('projects:dashboard') }}" class="inline-flex items-center rounded-lg bg-emerald-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Open dashboard</a>
      <form method="post" action="{{ url('accounts:logout') }}" class="inline">
        {{ csrf_input }}
        <button type="submit" class="inline-flex items-center rounded-lg border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 hover:border-slate-500">Log out</button>
      </form>
    {% else %}
      <a href="{{ url('accounts:login') }}" class="inline-flex items-center rounded-lg bg-emerald-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Log in</a>
      <a href="{{ url('accounts:register') }}" class="inline-flex items-center rounded-lg border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 hover:border-slate-500">Create account</a>
    {% endif %}
  </div>
</section>
{% endblock %}
