{% extends "base.jinja" %}
{% block title %}{{ 'Edit' if list_obj else 'New' }} Email List — Krizn{% endblock %}
{% block content %}
<section class="space-y-4">

  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">{{ 'Edit' if list_obj else 'New' }} Email List</h1>
      {% if list_obj %}
        <p class="text-[11px] text-slate-500">{{ list_obj.count }} recipient(s)</p>
      {% endif %}
    </div>
    <a href="{{ url('admin_emails:email_lists') }}"
       class="rounded border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-medium text-slate-400 hover:bg-slate-800">
      ← Email Lists
    </a>
  </div>

  {% if messages %}
    <div class="space-y-1">
      {% for message in messages %}
        <p class="rounded-lg border px-3 py-2 text-xs
          {{ 'border-emerald-800/50 bg-emerald-950/40 text-emerald-300' if message.tags == 'success' else 'border-rose-800/50 bg-rose-950/40 text-rose-300' }}">
          {{ message }}
        </p>
      {% endfor %}
    </div>
  {% endif %}

  <div class="grid gap-4 lg:grid-cols-3">

    <div class="lg:col-span-2 space-y-3">

      {# Main form #}
      <form method="post" action="{{ url('admin_emails:email_list_edit', pk=list_obj.pk) if list_obj else url('admin_emails:email_list_create') }}"
            class="space-y-3 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
        {{ csrf_input }}

        {% for field in form %}
          {% if field.name == 'emails' %}
            <div>
              <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">{{ field.label }}</label>
              <textarea name="{{ field.html_name }}" rows="14"
                        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 font-mono text-xs text-slate-200 placeholder-slate-600 focus:border-sky-600 focus:outline-none"
                        placeholder="{{ field.field.widget.attrs.get('placeholder', '') }}">{{ field.value() or '' }}</textarea>
              {% if field.errors %}{% for e in field.errors %}<p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>{% endfor %}{% endif %}
            </div>
          {% else %}
            <div>
              <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">{{ field.label }}</label>
              <input type="text" name="{{ field.html_name }}" value="{{ field.value() or '' }}"
                     placeholder="{{ field.field.widget.attrs.get('placeholder', '') }}"
                     class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-sky-600 focus:outline-none">
              {% if field.errors %}{% for e in field.errors %}<p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>{% endfor %}{% endif %}
            </div>
          {% endif %}
        {% endfor %}

        <div class="flex gap-2 pt-1">
          <button type="submit" class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500">
            Save List
          </button>
          <a href="{{ url('admin_emails:email_lists') }}"
             class="rounded-lg border border-slate-700 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800">
            Cancel
          </a>
        </div>
      </form>

    </div>

    {# Sidebar: auto-populate #}
    <div class="space-y-3">
      {% if list_obj %}
        <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-3">
          <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-slate-500">Auto-Populate from Users</p>
          <p class="mb-3 text-[10px] text-slate-600">Add emails from your registered users. Duplicates are skipped.</p>
          <div class="space-y-2">
            <form method="post" action="{{ url('admin_emails:email_list_populate', pk=list_obj.pk) }}">
              {{ csrf_input }}
              <input type="hidden" name="filter" value="all">
              <button type="submit"
                      class="w-full rounded border border-emerald-700/40 bg-emerald-600/10 px-3 py-1.5 text-[11px] font-semibold text-emerald-300 hover:bg-emerald-600/20 text-left">
                + All Active Users
              </button>
            </form>
            <form method="post" action="{{ url('admin_emails:email_list_populate', pk=list_obj.pk) }}">
              {{ csrf_input }}
              <input type="hidden" name="filter" value="staff">
              <button type="submit"
                      class="w-full rounded border border-amber-700/40 bg-amber-600/10 px-3 py-1.5 text-[11px] font-semibold text-amber-300 hover:bg-amber-600/20 text-left">
                + Staff Only
              </button>
            </form>
          </div>
        </div>
      {% endif %}

      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-3">
        <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-slate-500">Tips</p>
        <ul class="space-y-1 text-[10px] text-slate-500">
          <li>• One email per line</li>
          <li>• Blank lines and duplicates ignored</li>
          <li>• Use auto-populate to pull user emails</li>
          <li>• Attach list to scheduled emails for bulk sends</li>
        </ul>
      </div>
    </div>

  </div>

</section>
{% endblock %}
