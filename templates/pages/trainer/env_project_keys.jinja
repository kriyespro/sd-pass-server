{% extends "base.jinja" %}
{% block title %}Trainer — {{ project.name }} — env keys{% endblock %}
{% block content %}
<section class="mx-auto max-w-2xl space-y-6">
  <div>
    <a href="{{ url('trainer:env_audit') }}" class="text-sm text-sky-300 hover:text-sky-200">← All projects</a>
    <h1 class="mt-4 text-2xl font-semibold text-white">{{ project.name }}</h1>
    <p class="mt-1 text-sm text-slate-400">
      Owner: <span class="text-slate-300">{{ project.owner.email }}</span>
      · Slug: <code class="text-xs text-slate-500">{{ project.slug }}</code>
    </p>
    <p class="mt-3 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-200/90">
      Compliance: this page lists encrypted variable <strong>names</strong> only. Values are not decrypted or displayed.
    </p>
  </div>

  {% if env_keys %}
    <ul class="divide-y divide-slate-800 rounded-2xl border border-slate-800 bg-slate-900/50 font-mono text-sm text-emerald-200/90">
      {% for key in env_keys %}
        <li class="px-4 py-2.5">{{ key }}</li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="rounded-2xl border border-slate-800 bg-slate-900/40 px-4 py-8 text-center text-slate-500">
      No environment variables configured for this project.
    </p>
  {% endif %}
</section>
{% endblock %}
