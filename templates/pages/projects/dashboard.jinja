{% extends "base.jinja" %}
{% block title %}Projects — StudentCloud Deploy{% endblock %}
{% block content %}
{% if onboarding_active %}
  {% include "partials/onboarding/_wizard_modal.jinja" %}
{% endif %}
<section class="space-y-6">
  {% if student_apps_base_is_ipv4 and apps_base_domain %}
    <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
      <p class="font-semibold text-amber-50">Student hostnames use your server IP as the domain</p>
      <p class="mt-1 text-amber-100/90">
        Add a line to <code class="font-mono text-xs">/etc/hosts</code> for each subdomain, e.g.
        <code class="rounded bg-slate-950/80 px-1 font-mono text-xs">{{ apps_base_domain }} radha.{{ apps_base_domain }}</code>.
        <code class="font-mono text-xs">TRAEFIK_HTTP_PUBLISH</code> and <code class="font-mono text-xs">STUDENT_SITE_HTTP_PORT</code> must match.
      </p>
    </div>
  {% endif %}

  {# ── Header row ── #}
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-white">Your Projects</h1>
      <p class="text-sm text-slate-400">Static websites hosted on StudentCloud.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <a href="{{ url('projects:create') }}"
         class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 shadow hover:bg-emerald-400 active:scale-95 transition-transform">
        + New Project
      </a>
      <div class="flex items-center gap-2 rounded-xl border border-slate-800 bg-slate-900/60 px-4 py-2.5 text-sm text-slate-300">
        <span>
          <span class="font-semibold text-white">{{ project_count }}</span>
          / {{ plan_limit }} site{{ 's' if plan_limit != 1 }}
        </span>
        {% if project_count >= plan_limit %}
          <span class="rounded-full bg-rose-500/20 px-2 py-0.5 text-xs font-semibold text-rose-300 ring-1 ring-rose-500/30">Limit reached</span>
        {% endif %}
      </div>
      <a href="{{ url('billing:redeem') }}"
         class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-4 py-2.5 text-sm font-semibold text-emerald-300 hover:bg-emerald-500/20 transition-colors">
        🎟 Upgrade Plan
      </a>
    </div>
  </div>

  {# ── Server Status ── #}
  {% set s = server %}
  {% macro sc(st) %}{{ 'text-rose-400' if st=='critical' else ('text-amber-400' if st=='warning' else 'text-emerald-400') }}{% endmacro %}
  {% macro bc(st) %}{{ 'bg-rose-500' if st=='critical' else ('bg-amber-400' if st=='warning' else 'bg-emerald-400') }}{% endmacro %}
  <div class="flex items-center gap-px overflow-hidden rounded-xl border border-slate-800 bg-slate-950 divide-x divide-slate-800">
    {% for item in [
      ('CPU',     s.cpu_pct,  s.cpu_status),
      ('RAM',     s.ram_pct,  s.ram_status),
      ('Storage', s.disk_pct, s.disk_status),
    ] %}
      <div class="flex flex-1 flex-col gap-1.5 px-4 py-3">
        <div class="flex items-center justify-between">
          <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ item[0] }}</span>
          <span class="text-xs font-bold {{ sc(item[2]) }}">{{ item[1] }}%</span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-slate-800">
          <div class="h-1 rounded-full {{ bc(item[2]) }}" style="width:{{ [item[1],100]|min }}%"></div>
        </div>
      </div>
    {% endfor %}
    <div class="flex flex-col gap-0.5 px-4 py-3">
      <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">Load</span>
      <span class="text-xs font-bold {{ sc(s.load_status) }}">{{ s.load1 }}</span>
    </div>
  </div>

  {# ── Projects table ── #}
  <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/50">
    {% if projects %}
      <table class="min-w-full divide-y divide-slate-800 text-sm">
        <thead class="bg-slate-950/60 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Subdomain</th>
            <th class="px-4 py-3">Live Site</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-200">
          {% for p in projects %}
            <tr class="hover:bg-slate-900/80 transition-colors">
              <td class="px-4 py-3 font-medium text-white">{{ p.name }}</td>
              <td class="px-4 py-3">
                {% if p.status == 'running' %}
                  <span class="inline-flex rounded-full bg-emerald-500/15 px-2 py-1 text-xs font-semibold text-emerald-300 ring-1 ring-emerald-500/30">Running</span>
                {% elif p.status == 'pending' %}
                  <span class="inline-flex rounded-full bg-amber-500/15 px-2 py-1 text-xs font-semibold text-amber-300 ring-1 ring-amber-500/30">Pending</span>
                {% elif p.status == 'failed' %}
                  <span class="inline-flex rounded-full bg-rose-500/15 px-2 py-1 text-xs font-semibold text-rose-300 ring-1 ring-rose-500/30">Failed</span>
                {% else %}
                  <span class="inline-flex rounded-full bg-slate-800 px-2 py-1 text-xs font-semibold text-slate-300">{{ p.get_status_display() }}</span>
                {% endif %}
              </td>
              <td class="px-4 py-3 font-mono text-xs text-slate-300">{{ p.subdomain }}</td>

              {# ── Live site button ── #}
              <td class="px-4 py-3">
                {% if apps_base_domain and p.project_type == 'static' %}
                  {% set site_fqdn = p.subdomain ~ '.' ~ apps_base_domain %}
                  {% set port_seg = ':' ~ student_site_port if student_site_port else '' %}
                  {% set site_url = student_site_scheme ~ '://' ~ site_fqdn ~ port_seg ~ '/' %}
                  <a href="{{ site_url }}" target="_blank" rel="noopener noreferrer"
                     class="inline-flex items-center gap-1.5 rounded-lg bg-sky-500/15 px-3 py-1.5 text-xs font-semibold text-sky-300 ring-1 ring-sky-500/30 hover:bg-sky-500/25 transition-colors">
                    🌐 Visit Site
                  </a>
                  <div class="mt-1 max-w-[160px] select-all break-all font-mono text-[10px] text-slate-500">{{ site_url }}</div>
                {% elif apps_base_domain %}
                  <span class="font-mono text-xs text-slate-500">{{ p.subdomain }}.{{ apps_base_domain }}</span>
                {% else %}
                  <span class="text-slate-600">—</span>
                {% endif %}
              </td>

              <td class="px-4 py-3 text-slate-400">{{ p.created_at.strftime("%d %b %Y") }}</td>
              <td class="px-4 py-3 text-right">
                <div class="flex flex-wrap justify-end gap-x-2 gap-y-1 text-xs font-medium">
                  <a href="{{ url('projects:upload_zip', slug=p.slug) }}" class="text-emerald-400 hover:text-emerald-300">ZIP</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:upload_static_files', slug=p.slug) }}" class="text-emerald-400 hover:text-emerald-300">Files</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:domain', slug=p.slug) }}" class="text-amber-400 hover:text-amber-300">Domain</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:logs', slug=p.slug) }}" class="text-slate-400 hover:text-white">Logs</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:delete', slug=p.slug) }}" class="text-rose-400 hover:text-rose-300">Delete</a>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      {% include "partials/projects/_empty_state.jinja" %}
    {% endif %}
  </div>

  {# ── Upgrade nudge when at limit ── #}
  {% if project_count >= plan_limit %}
    <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 px-5 py-4 text-sm text-amber-100">
      <p class="font-semibold text-amber-50">You've used all {{ plan_limit }} website slot{{ 's' if plan_limit != 1 }}.</p>
      <p class="mt-1 text-amber-100/80">Upgrade your plan with a coupon code to add more projects.</p>
      <a href="{{ url('billing:redeem') }}"
         class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-amber-400">
        🎟 Redeem Coupon
      </a>
    </div>
  {% endif %}

</section>
{% endblock %}
