{% extends "base.jinja" %}
{% block title %}Databases — {{ project.name }}{% endblock %}
{% block content %}
<section class="mx-auto max-w-3xl space-y-6">
  <p class="text-sm text-slate-400">
    <a href="{{ url('projects:dashboard') }}" class="font-medium text-emerald-400 hover:text-emerald-300">← Projects</a>
    · <span class="text-slate-300">{{ project.name }}</span>
  </p>
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    <h1 class="text-xl font-semibold text-white">Databases</h1>
    <p class="mt-2 text-sm text-slate-400">
      Per-project PostgreSQL/Redis instances will appear here. Provisioning runs in Celery (<code class="text-emerald-300">databases.provision_stub</code>) — not wired from the UI yet.
    </p>
    {% if database_instances %}
      <ul class="mt-4 divide-y divide-slate-800 rounded-xl border border-slate-800 text-sm">
        {% for db in database_instances %}
          <li class="flex flex-wrap items-center justify-between gap-2 px-4 py-3">
            <span class="font-medium text-white">{{ db.name }}</span>
            <span class="font-mono text-xs text-slate-400">{{ db.get_engine_display() }} · {{ db.host or "—" }}:{{ db.port }}</span>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="mt-4 rounded-xl border border-dashed border-slate-700 bg-slate-950/40 px-4 py-6 text-center text-sm text-slate-500">No database instances yet.</p>
    {% endif %}
  </div>
</section>
{% endblock %}
