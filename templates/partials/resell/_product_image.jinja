{# Product image — optional image_class (default h-48) #}
<div class="relative overflow-hidden bg-gradient-to-br from-slate-800 to-slate-900 {{ image_class | default('h-48') }}">
  {% if product.featured_image %}
    <img src="{{ product.featured_image.url }}" alt="{{ product.name }}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105">
  {% else %}
    <div class="flex h-full items-center justify-center text-5xl text-slate-700">
      {% if product.category == 'course' %}🎓{% elif product.category == 'digital' %}💾{% elif product.category == 'physical' %}📦{% elif product.category == 'service' %}⚙️{% else %}🏷️{% endif %}
    </div>
  {% endif %}
  {% if product.badge_text %}
    <span class="absolute left-3 top-3 rounded-full bg-emerald-500 px-2.5 py-0.5 text-[11px] font-bold text-slate-950">{{ product.badge_text }}</span>
  {% endif %}
  {% if product.discount_pct %}
    <span class="absolute right-3 top-3 rounded-full bg-rose-500 px-2 py-0.5 text-[11px] font-bold text-white">-{{ product.discount_pct }}%</span>
  {% endif %}
  {% if product.stock > 0 and product.stock <= 5 %}
    <span class="absolute bottom-3 left-3 rounded-full border border-amber-500/40 bg-amber-950/80 px-2 py-0.5 text-[10px] font-semibold text-amber-300">Only {{ product.stock }} left!</span>
  {% endif %}
</div>
