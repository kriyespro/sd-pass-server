{% extends "base.jinja" %}
{% block title %}Custom domain — {{ project.name }}{% endblock %}
{% block content %}
<section class="mx-auto max-w-2xl space-y-6">
  <p class="text-sm text-slate-400">
    <a href="{{ url('projects:dashboard') }}" class="font-medium text-emerald-400 hover:text-emerald-300">← Projects</a>
    <span class="text-slate-600">·</span>
    <span class="text-slate-300">{{ project.name }}</span>
  </p>

  {# ── Default platform URL ── #}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    <h1 class="text-xl font-semibold text-white">Custom domain</h1>
    <p class="mt-2 text-sm text-slate-400">
      Your site is live at:
      <a href="https://{{ platform_fqdn }}/" target="_blank"
         class="font-mono text-sky-300 hover:text-sky-200">{{ platform_fqdn }}</a>
    </p>
    <p class="mt-1 text-sm text-slate-500">
      Want it on your own domain (e.g. <span class="font-mono text-slate-300">www.mybrand.com</span>)?
      Follow the steps below.
    </p>

    <form method="post" class="mt-6 space-y-4">
      {{ csrf_input }}
      {% if form.non_field_errors() %}
        <div class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-3 py-2 text-sm text-rose-100">
          {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
        </div>
      {% endif %}
      <div>
        <label class="block text-sm font-medium text-slate-200" for="id_custom_hostname">
          Your domain name
        </label>
        {{ form.custom_hostname }}
        {% if form.custom_hostname.errors %}
          <p class="mt-1 text-sm text-rose-300">{{ form.custom_hostname.errors[0] }}</p>
        {% endif %}
        <p class="mt-1 text-xs text-slate-500">
          Enter a full hostname, e.g. <code class="text-slate-300">www.mysite.com</code> or
          <code class="text-slate-300">portfolio.myname.com</code>. No http:// prefix.
        </p>
      </div>
      <button type="submit"
              class="rounded-lg bg-sky-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-sky-400">
        Save domain
      </button>
    </form>
  </div>

  {# ── DNS instructions ── #}
  <div class="rounded-2xl border border-slate-700 bg-slate-900/40 p-6 text-sm text-slate-300 space-y-4">
    <h2 class="text-lg font-semibold text-white">Step-by-step DNS setup (Cloudflare)</h2>

    <ol class="list-decimal pl-5 space-y-5 text-slate-300">
      <li>
        <p class="font-medium text-slate-100">Enter your domain above and click <em>Save domain</em>.</p>
      </li>
      <li>
        <p class="font-medium text-slate-100">Log in to your Cloudflare account → select your domain → DNS → Records.</p>
      </li>
      <li>
        <p class="font-medium text-slate-100">Add an <strong>A record</strong>:</p>
        <table class="mt-2 w-full text-xs rounded-lg overflow-hidden border border-slate-700">
          <thead class="bg-slate-800 text-slate-300">
            <tr>
              <th class="px-3 py-2 text-left">Type</th>
              <th class="px-3 py-2 text-left">Name</th>
              <th class="px-3 py-2 text-left">IPv4 address</th>
              <th class="px-3 py-2 text-left">Proxy status</th>
            </tr>
          </thead>
          <tbody class="bg-slate-900">
            <tr>
              <td class="px-3 py-2 font-mono font-bold text-amber-300">A</td>
              <td class="px-3 py-2 font-mono text-slate-200">
                {%- if project.custom_hostname -%}
                  {{ project.custom_hostname.split('.')[0] if '.' in project.custom_hostname else project.custom_hostname }}
                {%- else -%}
                  www (or @)
                {%- endif -%}
              </td>
              <td class="px-3 py-2 font-mono text-emerald-300">
                {{ public_ip if public_ip else '(your server IP)' }}
              </td>
              <td class="px-3 py-2">
                <span class="inline-flex items-center gap-1 rounded-full bg-amber-500/15 px-2 py-0.5 text-amber-300 ring-1 ring-amber-500/40">
                  ⬛ Proxied (orange cloud)
                </span>
              </td>
            </tr>
          </tbody>
        </table>
        <p class="mt-2 text-slate-500">
          Use <code class="text-slate-300">@</code> as the name for an apex domain (e.g. <code class="text-slate-300">mysite.com</code>),
          or the subdomain label (e.g. <code class="text-slate-300">www</code> or <code class="text-slate-300">portfolio</code>).
        </p>
      </li>
      <li>
        <p class="font-medium text-slate-100">Set Cloudflare SSL/TLS → Overview → <strong>Full</strong> mode.</p>
        <p class="mt-1 text-slate-500">This encrypts both browser ↔ Cloudflare and Cloudflare ↔ our server.</p>
      </li>
      <li>
        <p class="font-medium text-slate-100">Come back here and click <strong>Check verification</strong> below.</p>
        <p class="mt-1 text-slate-500">
          We check that the A record points to our server IP
          (<code class="font-mono text-emerald-300">{{ public_ip if public_ip else 'server IP' }}</code>).
          DNS changes can take 1–5 minutes.
        </p>
      </li>
    </ol>
  </div>

  {# ── Verification status ── #}
  {% if project.custom_hostname %}
    <div class="rounded-2xl border {% if domain_verified %}border-emerald-700/50 bg-emerald-950/30{% else %}border-amber-700/40 bg-amber-950/20{% endif %} p-5 text-sm">
      <p class="font-semibold {% if domain_verified %}text-emerald-200{% else %}text-amber-100{% endif %}">
        Domain: <span class="font-mono">{{ project.custom_hostname }}</span>
        — {% if domain_verified %}✅ Verified{% else %}⏳ Pending verification{% endif %}
      </p>

      {% if domain_verified %}
        <p class="mt-2 text-emerald-300/80">
          Your site is live at
          <a href="https://{{ project.custom_hostname }}/" target="_blank"
             class="font-mono underline hover:text-emerald-200">https://{{ project.custom_hostname }}/</a>
        </p>
      {% else %}
        <p class="mt-2 text-amber-200/80">
          Waiting for the A record to point to
          <code class="font-mono text-emerald-300">{{ public_ip if public_ip else 'server IP' }}</code>.
          After adding the DNS record, click below.
        </p>
        <form method="post" action="{{ url('projects:domain_verify', slug=project.slug) }}" class="mt-3">
          {{ csrf_input }}
          <button type="submit"
                  class="rounded-lg border border-sky-600/60 bg-sky-500/10 px-4 py-2 text-sm font-medium text-sky-200 hover:bg-sky-500/20">
            Check verification
          </button>
        </form>
      {% endif %}
    </div>
  {% endif %}

  {# ── How it works info box ── #}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/30 p-5 text-xs text-slate-400 space-y-2">
    <p class="font-semibold text-slate-300 text-sm">How it works</p>
    <p>When your A record points to our server and you click <em>Check verification</em>,
       we confirm DNS is set up correctly, then instantly route your domain to your project.
       No SSH or admin required.</p>
    <p>Verification checks every 5 minutes automatically. You can also trigger it manually above.</p>
    <p>If you use Cloudflare <strong>orange cloud (proxied)</strong>, your visitors get Cloudflare DDoS
       protection and free SSL. Set SSL mode to <strong>Full</strong> in your Cloudflare dashboard.</p>
  </div>
</section>
{% endblock %}
