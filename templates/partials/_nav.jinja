<header class="border-b border-slate-800 pb-4">

  {# ── Row 1: logo left · nav right ── #}
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">

    {# Brand logo — uses only safe compiled Tailwind classes #}
    <a href="{{ url('home') }}" class="flex items-center gap-2" aria-label="Krizn home">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500 text-base font-black text-slate-950">K</span>
      <span class="text-xl font-bold tracking-tight text-emerald-400">Krizn</span>
    </a>

    {# Navigation links #}
    <nav class="flex flex-wrap items-center gap-3 text-sm font-medium text-slate-300">

      {# Welcome greeting — shown before Home when logged in #}
      {% if request.user is defined and request.user.is_authenticated %}
        {% set _fname = request.user.first_name or request.user.username %}
        <span class="mr-1 text-xs text-slate-400">
          Welcome, <strong class="text-emerald-300">{{ _fname }}</strong> — Have a nice day ☀️
        </span>
        <span class="text-slate-700">|</span>
      {% endif %}

      <a href="{{ url('home') }}" class="hover:text-white">Home</a>
      <a href="{{ url('resell:store') }}" class="hover:text-amber-300">🛒 Resell</a>

      {% if request.user is defined and request.user.is_authenticated %}
        <a href="{{ url('affiliates:partner') }}" class="krizn-partner-link" aria-label="Partner earnings dashboard">
          <span class="krizn-partner-coin">💰</span>
          <span>Partner</span>
          <span class="krizn-partner-dot"></span>
        </a>
        <a href="{{ url('projects:dashboard') }}" class="hover:text-white">Server</a>
        <a href="{{ url('billing:redeem') }}" class="hover:text-emerald-300">Upgrade</a>
        <a href="{{ url('notifications:list') }}" class="relative inline-flex items-center gap-1 hover:text-white">
          <span>Alerts</span>
          {% if notification_unread_count > 0 %}
            <span class="rounded-full bg-emerald-500 px-1.5 py-0.5 text-xs font-bold text-slate-950">{{ notification_unread_count }}</span>
          {% endif %}
        </a>
        {% if request.user.is_staff %}
          <a href="{{ url('admin_monitor:dashboard') }}" class="rounded-md bg-violet-500/15 px-2 py-1 font-semibold text-violet-300 ring-1 ring-violet-500/40 hover:bg-violet-500/25">Admin</a>
        {% endif %}
        {% if trainer_portal_visible %}
          <a href="{{ url('trainer:overview') }}" class="hover:text-sky-300">Trainer</a>
        {% endif %}
        <form method="post" action="{{ url('accounts:logout') }}" class="inline">
          {{ csrf_input }}
          <button type="submit" class="hover:text-white">Log out</button>
        </form>
      {% else %}
        <a href="{{ url('accounts:login') }}" class="hover:text-white">Log in</a>
        <a href="{{ url('accounts:register') }}" class="rounded-lg bg-emerald-500/10 px-3 py-1 text-emerald-300 ring-1 ring-emerald-500/40 hover:bg-emerald-500/20">Sign up</a>
      {% endif %}

    </nav>
  </div>

</header>

<style>
/* ── Partner link — glow + ping dot + coin bounce ── */
.krizn-partner-link {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px 3px 8px;
  border-radius: 999px;
  background: rgba(16,185,129,0.10);
  border: 1px solid rgba(16,185,129,0.45);
  color: #6ee7b7;
  font-size: .875rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  animation: krizn-partner-glow 2.4s ease-in-out infinite;
  transition: background .2s, color .2s;
}
.krizn-partner-link:hover {
  background: rgba(16,185,129,0.22);
  color: #a7f3d0;
  box-shadow: 0 0 18px rgba(16,185,129,0.55);
}

/* pulsing green outer glow */
@keyframes krizn-partner-glow {
  0%,100% {
    box-shadow: 0 0 5px rgba(16,185,129,0.30),
                0 0 10px rgba(16,185,129,0.10);
    border-color: rgba(16,185,129,0.40);
  }
  50% {
    box-shadow: 0 0 12px rgba(16,185,129,0.65),
                0 0 22px rgba(16,185,129,0.25),
                0 0 36px rgba(16,185,129,0.10);
    border-color: rgba(16,185,129,0.80);
  }
}

/* money coin — gentle wobble */
.krizn-partner-coin {
  display: inline-block;
  animation: krizn-coin-wobble 2.4s ease-in-out infinite;
  transform-origin: center bottom;
}
@keyframes krizn-coin-wobble {
  0%,100% { transform: rotate(0deg) translateY(0); }
  20%     { transform: rotate(-12deg) translateY(-1px); }
  40%     { transform: rotate(10deg) translateY(-2px); }
  60%     { transform: rotate(-6deg) translateY(-1px); }
  80%     { transform: rotate(4deg) translateY(0); }
}

/* ping notification dot */
.krizn-partner-dot {
  position: absolute;
  top: -3px;
  right: -3px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #10b981;
  box-shadow: 0 0 4px rgba(16,185,129,0.8);
}
.krizn-partner-dot::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(16,185,129,0.6);
  animation: krizn-dot-ping 1.8s ease-out infinite;
}
@keyframes krizn-dot-ping {
  0%   { transform: scale(1);   opacity: .8; }
  70%  { transform: scale(2.4); opacity: 0; }
  100% { transform: scale(2.4); opacity: 0; }
}
</style>
