{% extends "base.jinja" %}
{% block title %}Schedule Email Send — Krizn{% endblock %}
{% block content %}
<section class="space-y-4">

  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">Schedule Email Send</h1>
      <p class="text-[11px] text-slate-500">Pick a template, recipients, and when to send</p>
    </div>
    <a href="{{ url('admin_emails:scheduled') }}"
       class="rounded border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-medium text-slate-400 hover:bg-slate-800">
      ← Scheduled
    </a>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">

    <div class="lg:col-span-2">
      <form method="post" class="space-y-4 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
        {{ csrf_input }}

        {# ── Template ── #}
        <div>
          <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">Template</label>
          <select name="template"
                  class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 focus:border-sky-600 focus:outline-none">
            <option value="">— Select a template —</option>
            {% for choice_val, choice_label in form.template.field.choices %}
              {% if choice_val %}
                <option value="{{ choice_val }}"
                        {{ 'selected' if form.template.value()|string == choice_val|string else '' }}>
                  {{ choice_label }}
                </option>
              {% endif %}
            {% endfor %}
          </select>
          {% for e in form.template.errors %}
            <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
          {% endfor %}
        </div>

        {# ── Email List ── #}
        <div>
          <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">Email List</label>
          <select name="email_list"
                  class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 focus:border-sky-600 focus:outline-none">
            <option value="">— None (enter emails manually below) —</option>
            {% for choice_val, choice_label in form.email_list.field.choices %}
              {% if choice_val %}
                <option value="{{ choice_val }}"
                        {{ 'selected' if form.email_list.value()|string == choice_val|string else '' }}>
                  {{ choice_label }}
                </option>
              {% endif %}
            {% endfor %}
          </select>
          {% for e in form.email_list.errors %}
            <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
          {% endfor %}
        </div>

        {# ── Manual emails (fallback) ── #}
        <div>
          <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">
            Manual Recipients
            <span class="ml-1 normal-case font-normal text-slate-600">(only used if no list selected)</span>
          </label>
          <textarea name="to_emails" rows="4"
                    class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 font-mono text-xs text-slate-200 placeholder-slate-600 focus:border-sky-600 focus:outline-none"
                    placeholder="user@example.com&#10;another@example.com">{{ form.to_emails.value() or '' }}</textarea>
          {% for e in form.to_emails.errors %}
            <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
          {% endfor %}
        </div>

        {# ── Scheduled at ── #}
        <div>
          <label class="mb-1 block text-[11px] font-semibold uppercase text-slate-400">Send at</label>
          {% set dt_val = form.scheduled_at.value() %}
          <input type="datetime-local" name="scheduled_at"
                 value="{{ dt_val.strftime('%Y-%m-%dT%H:%M') if dt_val else '' }}"
                 class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 focus:border-sky-600 focus:outline-none">
          <p class="mt-0.5 text-[10px] text-slate-600">Leave blank and use "Send Now" on the list page to send immediately.</p>
          {% for e in form.scheduled_at.errors %}
            <p class="mt-0.5 text-[10px] text-rose-400">{{ e }}</p>
          {% endfor %}
        </div>

        {% if form.non_field_errors() %}
          <div class="rounded-lg border border-rose-800/40 bg-rose-950/30 px-3 py-2">
            {% for e in form.non_field_errors() %}
              <p class="text-[11px] text-rose-400">{{ e }}</p>
            {% endfor %}
          </div>
        {% endif %}

        <div class="flex gap-2 pt-1">
          <button type="submit"
                  class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-semibold text-white hover:bg-violet-500">
            Schedule Send
          </button>
          <a href="{{ url('admin_emails:scheduled') }}"
             class="rounded-lg border border-slate-700 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800">
            Cancel
          </a>
        </div>
      </form>
    </div>

    {# ── Sidebar ── #}
    <div class="space-y-3">
      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-3 h-fit">
        <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-slate-500">How it works</p>
        <ul class="space-y-2 text-[10px] text-slate-500">
          <li><span class="text-violet-400 font-semibold">1.</span> Pick a template</li>
          <li><span class="text-violet-400 font-semibold">2.</span> Choose a saved list <span class="text-slate-600">or</span> paste manual emails</li>
          <li><span class="text-violet-400 font-semibold">3.</span> Set a date &amp; time (optional)</li>
          <li><span class="text-violet-400 font-semibold">4.</span> Hit <strong class="text-slate-300">Send Now</strong> on the scheduled page to dispatch immediately</li>
        </ul>
        <div class="mt-3 border-t border-slate-800 pt-3 space-y-1.5">
          <p class="text-[10px] text-slate-600">
            No list yet?
            <a href="{{ url('admin_emails:email_list_create') }}" class="text-sky-400 hover:underline">Create one →</a>
          </p>
          <p class="text-[10px] text-slate-600">
            Auto-populate?
            <a href="{{ url('admin_emails:email_lists') }}" class="text-sky-400 hover:underline">Email Lists →</a>
          </p>
        </div>
      </div>
    </div>

  </div>

</section>
{% endblock %}
