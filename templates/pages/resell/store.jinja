{% extends "base.jinja" %}
{% block title %}Resell Store — Krizn{% endblock %}

{% block content %}
<div x-data="resellStore()" class="relative space-y-6">
  {% include "partials/resell/_store_modals.jinja" %}

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Resell Store</h1>
      <p class="mt-1 text-sm text-slate-400">{{ products | length }} product{{ 's' if products | length != 1 }} available</p>
    </div>
    <button
      type="button"
      @click="cartOpen = true"
      class="relative flex items-center gap-2 rounded-xl border border-slate-700 bg-slate-900/60 px-4 py-2.5 text-sm font-medium text-slate-200 transition-colors hover:border-emerald-500/50"
    >
      🛒 Cart
      <span
        x-show="cartCount > 0"
        class="absolute -right-2 -top-2 flex h-5 w-5 items-center justify-center rounded-full bg-emerald-500 text-[11px] font-bold text-slate-950"
        x-text="cartCount"
        style="display:none;"
      ></span>
    </button>
  </div>

  {% if products %}
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {% for p in products %}
    <div class="group flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 transition-all hover:border-slate-700 hover:shadow-xl hover:shadow-emerald-500/5">
      <a href="{{ url('resell:product_detail', slug=p.slug) }}" class="block">
        {% with product=p %}
          {% include "partials/resell/_product_image.jinja" %}
        {% endwith %}
      </a>

      <div class="flex flex-1 flex-col gap-3 p-4">
        <div>
          <span class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">{{ p.get_category_display() }}</span>
          <h2 class="mt-0.5 text-base font-semibold leading-tight text-white">
            <a href="{{ url('resell:product_detail', slug=p.slug) }}" class="hover:text-emerald-300">{{ p.name }}</a>
          </h2>
          {% if p.card_summary %}
            <p class="mt-1.5 line-clamp-2 text-xs text-slate-400">{{ p.card_summary }}</p>
          {% endif %}
        </div>

        <div class="mt-auto">
          <div class="mb-3 flex items-baseline gap-2">
            <span class="text-xl font-bold text-emerald-300">₹{{ p.price }}</span>
            {% if p.original_price %}
              <span class="text-sm text-slate-500 line-through">₹{{ p.original_price }}</span>
            {% endif %}
          </div>

          <div class="flex gap-2">
            <button
              type="button"
              @click='addToCart({{ p.pk }}, {{ p.name | tojson }})'
              class="flex-1 rounded-lg border border-emerald-500/40 bg-emerald-500/10 py-2 text-xs font-semibold text-emerald-300 transition-all hover:bg-emerald-500/20 active:scale-[0.97]"
            >
              + Add to Cart
            </button>
            <button
              type="button"
              @click='buyNow({{ p.pk }}, {{ p.name | tojson }})'
              class="flex-1 rounded-lg bg-emerald-500 py-2 text-xs font-bold text-slate-950 shadow transition-all hover:bg-emerald-400 active:scale-[0.97]"
            >
              Buy Now →
            </button>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="py-24 text-center">
    <p class="text-5xl">🏪</p>
    <h2 class="mt-4 text-lg font-semibold text-white">No products yet</h2>
    <p class="mt-2 text-sm text-slate-400">Check back soon — products will appear here once listed.</p>
  </div>
  {% endif %}
</div>
{% endblock %}

{% block extra_js %}
{% include "partials/resell/_store_scripts.jinja" %}
{% endblock %}
