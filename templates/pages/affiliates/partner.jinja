{% extends "base.jinja" %}
{% block title %}Partner Dashboard — Krizn{% endblock %}

{% block content %}
<div x-data="partnerPage()" class="mx-auto max-w-2xl space-y-5 py-4">

  {# ══════════════════════════════════════════════════════
     MOTIVATIONAL HERO BANNER — context-aware message
  ══════════════════════════════════════════════════════ #}
  {% if paid_count == 0 and partner.click_count == 0 %}
  {# Fresh start #}
  <div class="rounded-2xl border border-emerald-700/40 bg-emerald-950/25 px-5 py-4">
    <p class="text-base font-bold text-emerald-300">👋 Welcome to your Partner Dashboard!</p>
    <p class="mt-1 text-sm text-slate-400">Share your links below and start earning. Every click brings you closer to your first sale.</p>
    <div class="mt-3 rounded-xl border border-emerald-800/40 bg-slate-950/40 px-4 py-3">
      <p class="text-xs font-semibold text-slate-300">💡 Earning potential:</p>
      <p class="mt-1 text-xs text-slate-400">Share daily for just <strong class="text-white">20 minutes</strong> → <strong class="text-emerald-300">₹10,000–₹20,000/month</strong></p>
      <p class="mt-0.5 text-xs text-slate-500">Resell product sale = ₹1,200–₹2,000 commission · Server plan = ₹30–₹150 credit</p>
    </div>
  </div>

  {% elif paid_count == 0 and partner.click_count > 0 %}
  {# Clicks but no purchase yet #}
  <div class="rounded-2xl border border-amber-700/40 bg-amber-950/20 px-5 py-4">
    <p class="text-base font-bold text-amber-300">
      {% if partner.click_count >= 20 %}🔥 {{ partner.click_count }} clicks!
      {% elif partner.click_count >= 5 %}👍 {{ partner.click_count }} clicks — nice work!
      {% else %}✅ {{ partner.click_count }} click{{ 's' if partner.click_count != 1 else '' }} so far
      {% endif %}
    </p>
    <p class="mt-1 text-sm text-slate-400">
      Someone is about to buy — keep sharing! Every 20–30 clicks typically converts into 1 sale.
    </p>
    <p class="mt-2 text-xs text-slate-500">💡 Try WhatsApp groups, Instagram stories, or your college network for faster results.</p>
  </div>

  {% elif paid_count >= 1 %}
  {# At least one sale! #}
  <div class="rounded-2xl border border-emerald-600/50 bg-emerald-950/30 px-5 py-4">
    <p class="text-base font-bold text-emerald-300">
      🎉 {{ paid_count }} sale{{ 's' if paid_count != 1 else '' }} done! You've earned <span class="text-white">₹{{ total_earned | float | round(0) | int }}</span>
    </p>
    <p class="mt-1 text-sm text-slate-400">
      Keep the momentum going — <strong class="text-white">more shares = more sales = more money.</strong>
    </p>
    <div class="mt-2 grid grid-cols-2 gap-2 text-xs">
      <div class="rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2">
        <p class="text-slate-500">At this rate</p>
        <p class="mt-0.5 font-semibold text-emerald-300">₹{{ ((total_earned | float) * (30.0 / ([paid_count, 1] | max))) | round(0) | int }}/month est.</p>
      </div>
      <div class="rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2">
        <p class="text-slate-500">Next tier at {{ slab_info.next.at if slab_info.next else '—' }} sales</p>
        <p class="mt-0.5 font-semibold text-amber-300">{{ slab_info.next.rate if slab_info.next else slab_info.rate_pct }}% commission</p>
      </div>
    </div>
  </div>
  {% endif %}

  {# ══════════════════════════════════════════════════════
     STATS ROW — always 4 columns, never wraps
  ══════════════════════════════════════════════════════ #}
  <div class="grid grid-cols-4 gap-2">

    {# Tier #}
    <div class="rounded-xl border px-2 py-3 text-center
      {% if slab_info.label == 'Gold' %}border-amber-500/40 bg-amber-950/30
      {% elif slab_info.label == 'Silver' %}border-slate-500/40 bg-slate-800/40
      {% else %}border-orange-700/40 bg-orange-950/20{% endif %}">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-slate-500">Tier</p>
      <p class="mt-1 text-xl font-black
        {% if slab_info.label == 'Gold' %}text-amber-300
        {% elif slab_info.label == 'Silver' %}text-slate-200
        {% else %}text-orange-300{% endif %}">{{ slab_info.rate_pct }}%</p>
      <p class="text-[10px] font-semibold text-slate-400">{{ slab_info.label }}</p>
    </div>

    {# Credit balance #}
    <div class="rounded-xl border border-emerald-500/30 bg-emerald-950/20 px-2 py-3 text-center">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-slate-500">Credit</p>
      <p class="mt-1 text-xl font-black text-emerald-300">₹{{ partner.credit_balance | float | round(0) | int }}</p>
      <p class="text-[10px] text-slate-500">₹{{ partner.total_earned | float | round(0) | int }} earned</p>
    </div>

    {# Paid sales #}
    <div class="rounded-xl border border-sky-500/20 bg-slate-900/60 px-2 py-3 text-center">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-slate-500">Sales</p>
      <p class="mt-1 text-xl font-black text-white">{{ paid_count }}</p>
      <p class="text-[10px] text-slate-500">paid refs</p>
    </div>

    {# Link clicks #}
    <div class="rounded-xl border border-violet-500/20 bg-slate-900/60 px-2 py-3 text-center">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-slate-500">Clicks</p>
      <p class="mt-1 text-xl font-black text-violet-300">{{ partner.click_count }}</p>
      <p class="text-[10px] text-slate-500">link visits</p>
    </div>

  </div>

  {# ══════════════════════════════════════════════════════
     COMMISSION TIERS — bold ladder with current highlighted
  ══════════════════════════════════════════════════════ #}
  <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
    <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-slate-500">Commission Tiers</p>

    <div class="grid grid-cols-3 gap-2">

      {# Bronze #}
      <div class="rounded-xl border px-3 py-3 text-center
        {% if slab_info.label == 'Bronze' %}border-orange-500/60 bg-orange-950/30 ring-1 ring-orange-500/30{% else %}border-slate-800 bg-slate-950/40 opacity-50{% endif %}">
        <p class="text-[10px] font-semibold text-slate-400">Bronze</p>
        <p class="mt-1 text-2xl font-black text-emerald-400">10%</p>
        <p class="mt-0.5 text-[10px] text-slate-500">0 sales</p>
        {% if slab_info.label == 'Bronze' %}
        <span class="mt-1.5 inline-block rounded-full bg-orange-500/20 px-2 py-0.5 text-[9px] font-bold text-orange-300">YOU ARE HERE</span>
        {% endif %}
      </div>

      {# Silver #}
      <div class="rounded-xl border px-3 py-3 text-center
        {% if slab_info.label == 'Silver' %}border-slate-400/60 bg-slate-700/30 ring-1 ring-slate-400/30{% else %}border-slate-800 bg-slate-950/40 opacity-50{% endif %}">
        <p class="text-[10px] font-semibold text-slate-400">Silver</p>
        <p class="mt-1 text-2xl font-black text-emerald-400">15%</p>
        <p class="mt-0.5 text-[10px] text-slate-500">5 sales</p>
        {% if slab_info.label == 'Silver' %}
        <span class="mt-1.5 inline-block rounded-full bg-slate-500/20 px-2 py-0.5 text-[9px] font-bold text-slate-300">YOU ARE HERE</span>
        {% endif %}
      </div>

      {# Gold #}
      <div class="rounded-xl border px-3 py-3 text-center
        {% if slab_info.label == 'Gold' %}border-amber-500/60 bg-amber-950/30 ring-1 ring-amber-500/30{% else %}border-slate-800 bg-slate-950/40 opacity-50{% endif %}">
        <p class="text-[10px] font-semibold text-slate-400">Gold</p>
        <p class="mt-1 text-2xl font-black text-emerald-400">20%</p>
        <p class="mt-0.5 text-[10px] text-slate-500">10 sales</p>
        {% if slab_info.label == 'Gold' %}
        <span class="mt-1.5 inline-block rounded-full bg-amber-500/20 px-2 py-0.5 text-[9px] font-bold text-amber-300">YOU ARE HERE</span>
        {% endif %}
      </div>

    </div>

    {# Progress bar under tiers #}
    {% set filled = [slab_info.count, 10] | min %}
    <div class="mt-3 relative h-2 w-full overflow-hidden rounded-full bg-slate-800">
      <div class="absolute left-0 top-0 h-full rounded-full
        {% if slab_info.label == 'Gold' %}bg-amber-400
        {% elif slab_info.label == 'Silver' %}bg-slate-300
        {% else %}bg-orange-400{% endif %}"
        style="width: {{ (filled / 10 * 100) | int }}%"></div>
      <div class="absolute top-0 h-full w-px bg-slate-700" style="left:50%"></div>
    </div>
    <div class="mt-1 flex justify-between text-[9px] text-slate-600">
      <span>0</span>
      <span>{% if slab_info.next %}{{ slab_info.next.need }} more to {{ slab_info.next.label }}{% else %}🏆 Max tier!{% endif %}</span>
      <span>10</span>
    </div>
  </div>

  {# ══════════════════════════════════════════════════════
     SHARE LINKS — SERVER HOSTING
  ══════════════════════════════════════════════════════ #}
  <div class="rounded-xl border border-slate-700/60 bg-slate-900/60 p-4 space-y-3">
    <div class="flex items-center gap-2">
      <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-500/15 text-base">🖥</span>
      <div>
        <h2 class="text-sm font-semibold text-white">Server Hosting Link</h2>
        <p class="text-[11px] text-slate-500">Earn credit when someone buys a hosting plan</p>
      </div>
    </div>
    <div class="flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-950/70 px-3 py-2">
      <p class="min-w-0 flex-1 truncate font-mono text-[11px] text-slate-400">{{ server_url }}</p>
      <button type="button" @click="copyLink('{{ server_url }}', 'server')"
              class="shrink-0 rounded-md bg-emerald-500 px-2.5 py-1 text-[11px] font-bold text-slate-950 transition hover:bg-emerald-400 active:scale-95">
        <span x-show="copiedKey !== 'server'">Copy</span>
        <span x-show="copiedKey === 'server'" x-cloak>✓ Copied!</span>
      </button>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ wa_server }}" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 rounded-lg border border-green-700/40 bg-green-950/20 px-3 py-1.5 text-xs font-semibold text-green-400 transition hover:bg-green-950/40 active:scale-95">
        📱 WhatsApp
      </a>
      <button type="button" @click="copyLink('{{ partner.code }}', 'code')"
              class="inline-flex items-center gap-1.5 rounded-lg border border-slate-600 bg-slate-800/50 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:bg-slate-800 active:scale-95">
        <span x-show="copiedKey !== 'code'">Copy code</span>
        <span x-show="copiedKey === 'code'" x-cloak>✓ {{ partner.code }}</span>
      </button>
    </div>
  </div>

  {# ══════════════════════════════════════════════════════
     SHARE LINKS — RESELL STORE
  ══════════════════════════════════════════════════════ #}
  <div class="rounded-xl border border-amber-700/40 bg-amber-950/10 p-4 space-y-3">
    <div class="flex items-center gap-2">
      <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-amber-500/15 text-base">🛒</span>
      <div>
        <h2 class="text-sm font-semibold text-white">Resell Store Link</h2>
        <p class="text-[11px] text-slate-500">Big commissions — job portal, matrimony, marketplace. Up to ₹2,000/sale!</p>
      </div>
    </div>
    <div class="flex items-center gap-2 rounded-lg border border-amber-800/40 bg-slate-950/70 px-3 py-2">
      <p class="min-w-0 flex-1 truncate font-mono text-[11px] text-slate-400">{{ resell_url }}</p>
      <button type="button" @click="copyLink('{{ resell_url }}', 'resell')"
              class="shrink-0 rounded-md bg-amber-500 px-2.5 py-1 text-[11px] font-bold text-slate-950 transition hover:bg-amber-400 active:scale-95">
        <span x-show="copiedKey !== 'resell'">Copy</span>
        <span x-show="copiedKey === 'resell'" x-cloak>✓ Copied!</span>
      </button>
    </div>
    <a href="{{ wa_resell }}" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-1.5 rounded-lg border border-green-700/40 bg-green-950/20 px-3 py-1.5 text-xs font-semibold text-green-400 transition hover:bg-green-950/40 active:scale-95">
      📱 WhatsApp Store
    </a>

    {# Per-product links #}
    {% if product_links %}
    <div class="space-y-2 pt-1">
      <p class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Or share a specific product:</p>
      {% for pl in product_links %}
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2.5">
        <div class="flex items-start justify-between gap-2 mb-2">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-white truncate">{{ pl.product.name }}</p>
            <p class="text-[11px] text-slate-500">
              ₹{{ pl.product.price | int }} · 20% = <span class="text-emerald-400 font-semibold">₹{{ (pl.product.price | float * 0.20) | round(0) | int }} commission</span>
            </p>
          </div>
          <div class="flex shrink-0 gap-1.5">
            <button type="button" @click="copyLink('{{ pl.url }}', 'prod_{{ pl.product.slug }}')"
                    class="rounded-md border border-slate-700 bg-slate-800/60 px-2 py-1 text-[10px] font-semibold text-slate-300 transition hover:bg-slate-700 active:scale-95">
              <span x-show="copiedKey !== 'prod_{{ pl.product.slug }}'">Copy</span>
              <span x-show="copiedKey === 'prod_{{ pl.product.slug }}'" x-cloak>✓</span>
            </button>
            <a href="{{ pl.wa_url }}" target="_blank" rel="noopener noreferrer"
               class="rounded-md border border-green-800/50 bg-green-950/20 px-2 py-1 text-[10px] font-semibold text-green-400 transition hover:bg-green-950/40">WA</a>
          </div>
        </div>
        <p class="font-mono text-[10px] text-slate-600 truncate">{{ pl.url }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  {# ══════════════════════════════════════════════════════
     EARNING POTENTIAL CALCULATOR
  ══════════════════════════════════════════════════════ #}
  <div class="rounded-xl border border-violet-700/30 bg-violet-950/10 p-4 space-y-3">
    <p class="text-sm font-semibold text-white">💡 How much can you earn?</p>
    <div class="grid grid-cols-1 gap-2 text-xs sm:grid-cols-3">
      <div class="rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2.5 text-center">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide">20 min/day</p>
        <p class="mt-1 text-base font-bold text-white">1–2 sales</p>
        <p class="text-emerald-300 font-semibold">₹1,400–₹4,000</p>
        <p class="text-[10px] text-slate-600 mt-0.5">per month</p>
      </div>
      <div class="rounded-lg border border-emerald-700/30 bg-emerald-950/20 px-3 py-2.5 text-center">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide">1 hr/day</p>
        <p class="mt-1 text-base font-bold text-white">5–7 sales</p>
        <p class="text-emerald-300 font-semibold">₹7,000–₹14,000</p>
        <p class="text-[10px] text-slate-600 mt-0.5">per month</p>
      </div>
      <div class="rounded-lg border border-amber-700/30 bg-amber-950/15 px-3 py-2.5 text-center">
        <p class="text-[10px] text-slate-500 uppercase tracking-wide">2+ hrs/day</p>
        <p class="mt-1 text-base font-bold text-white">15–20 sales</p>
        <p class="text-amber-300 font-semibold">₹20,000–₹40,000</p>
        <p class="text-[10px] text-slate-600 mt-0.5">per month</p>
      </div>
    </div>
    <p class="text-[11px] text-slate-600">Based on 20% commission on resell products (avg ₹7,000). More you share → more you earn.</p>
  </div>

  {# ══════════════════════════════════════════════════════
     REDEEM CREDIT
  ══════════════════════════════════════════════════════ #}
  {% if partner.credit_balance > 0 %}
  <div class="rounded-xl border border-emerald-700/40 bg-emerald-950/15 p-4 space-y-2.5">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-white">🎁 Redeem credit</h2>
      <span class="text-xs text-emerald-300 font-semibold">₹{{ partner.credit_balance | float | round(0) | int }} available</span>
    </div>
    <div class="space-y-1.5">
      {% for plan in redeemable_plans %}
      {% if plan.affordable or plan.partial %}
      <div class="flex items-center justify-between gap-3 rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-slate-200">{{ plan.label }}</p>
          <p class="text-[11px] text-slate-500">₹{{ plan.price | int }}
            {% if plan.affordable %}<span class="ml-1 text-emerald-400 font-semibold">· Free with credit!</span>
            {% elif plan.partial %}<span class="ml-1 text-sky-400">· Pay ₹{{ (plan.price - (partner.credit_balance | float)) | round(0) | int }} after credit</span>
            {% endif %}
          </p>
        </div>
        {% if plan.affordable %}
        <button @click="creditBuy('{{ plan.slug }}', {{ plan.price }}, '{{ plan.label }}')"
                class="shrink-0 rounded-md bg-emerald-500 px-2.5 py-1 text-[11px] font-bold text-slate-950 transition hover:bg-emerald-400 active:scale-95">
          Activate →
        </button>
        {% else %}
        <button @click="partialCreditBuy('{{ plan.slug }}', {{ plan.price }}, {{ partner.credit_balance | float }}, '{{ plan.label }}')"
                class="shrink-0 rounded-md border border-sky-500/50 bg-sky-950/30 px-2.5 py-1 text-[11px] font-semibold text-sky-300 transition hover:bg-sky-950/50 active:scale-95">
          Apply + Pay
        </button>
        {% endif %}
      </div>
      {% endif %}
      {% endfor %}
    </div>
    <div x-show="redeemMsg" x-cloak class="rounded-lg border border-emerald-700/50 bg-emerald-950/40 px-3 py-2 text-xs text-emerald-200" x-text="redeemMsg"></div>
    <div x-show="redeemErr" x-cloak class="rounded-lg border border-rose-700/50 bg-rose-950/40 px-3 py-2 text-xs text-rose-200" x-text="redeemErr"></div>
  </div>
  {% endif %}

  {# ══════════════════════════════════════════════════════
     REFERRAL HISTORY
  ══════════════════════════════════════════════════════ #}
  <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
    <h2 class="mb-3 text-sm font-semibold text-white">Referral History</h2>
    {% if referrals %}
    <div class="space-y-2">
      {% for r in referrals %}
      <div class="flex items-center gap-3 rounded-lg border border-slate-800/60 bg-slate-950/40 px-3 py-2">
        <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-800 text-xs font-bold text-slate-400">
          {{ loop.index }}
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-slate-200 truncate">
            {{ (r.referred_user.get_full_name().strip() or r.referred_user.email) if r.referred_user else 'Anonymous' }}
          </p>
          <p class="text-[11px] text-slate-600">{{ r.created_at.strftime('%d %b %Y') }}{% if r.plan_slug %} · {{ r.plan_slug }}{% endif %}</p>
        </div>
        <div class="shrink-0 text-right">
          {% if r.status == 'credited' %}
          <span class="block text-xs font-bold text-emerald-300">+₹{{ r.commission_amount | round(0) | int }}</span>
          <span class="text-[10px] text-emerald-600">Paid</span>
          {% else %}
          <span class="block text-xs font-medium text-amber-400">Pending</span>
          <span class="text-[10px] text-slate-600">Waiting</span>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="py-6 text-center">
      <p class="text-2xl">🔗</p>
      <p class="mt-2 text-sm text-slate-400">No referrals yet</p>
      <p class="text-xs text-slate-600 mt-1">Share your links above to get started!</p>
    </div>
    {% endif %}
  </div>

  {# ══════════════════════════════════════════════════════
     CREDIT USED HISTORY
  ══════════════════════════════════════════════════════ #}
  {% if redemptions %}
  <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
    <h2 class="mb-3 text-sm font-semibold text-white">Credit Used</h2>
    <div class="space-y-1.5">
      {% for rd in redemptions %}
      <div class="flex items-center justify-between rounded-lg border border-slate-800/60 bg-slate-950/40 px-3 py-2 text-xs">
        <span class="text-slate-300">{{ rd.plan_slug or '—' }}</span>
        <span class="text-slate-600">{{ rd.created_at.strftime('%d %b %Y') }}</span>
        <span class="font-semibold text-rose-400">−₹{{ rd.amount_redeemed }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}

{% block extra_js %}
<script>
function partnerPage() {
  return {
    copiedKey: '',
    redeemMsg: '',
    redeemErr: '',
    csrf: document.querySelector('meta[name="csrf-token"]').content,

    copyLink(text, key) {
      navigator.clipboard.writeText(text).catch(() => {
        const el = document.createElement('textarea');
        el.value = text; document.body.appendChild(el); el.select();
        document.execCommand('copy'); document.body.removeChild(el);
      });
      this.copiedKey = key;
      setTimeout(() => { if (this.copiedKey === key) this.copiedKey = ''; }, 2500);
    },

    async creditBuy(slug, price, label) {
      this.redeemMsg = ''; this.redeemErr = '';
      if (!confirm(`Activate ${label} using ₹${price} credit?`)) return;
      try {
        const r = await fetch('{{ url("billing:partner_credit_buy") }}', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'X-CSRFToken': this.csrf},
          body: JSON.stringify({plan_slug: slug}),
        });
        const d = await r.json();
        if (d.status === 'success') { this.redeemMsg = `✓ ${d.label} activated!`; setTimeout(() => location.reload(), 1200); }
        else this.redeemErr = d.error || 'Something went wrong.';
      } catch { this.redeemErr = 'Network error.'; }
    },

    async partialCreditBuy(slug, price, creditBalance, label) {
      this.redeemMsg = ''; this.redeemErr = '';
      const key = '{{ razorpay_key_id }}';
      if (!key) { this.redeemErr = 'Payment not configured.'; return; }
      const creditAmount = parseFloat(creditBalance.toFixed(2));
      const oRes = await fetch('{{ url("billing:create_order") }}', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-CSRFToken': this.csrf},
        body: JSON.stringify({plan_slug: slug, credit_amount: creditAmount}),
      });
      const oData = await oRes.json();
      if (oData.error) { this.redeemErr = oData.error; return; }
      if (oData.free) { return this.creditBuy(slug, price, label); }
      new Razorpay({
        key, order_id: oData.order_id, amount: oData.amount, currency: oData.currency,
        name: 'Krizn', description: `${label} (₹${creditAmount} credit applied)`,
        handler: async (resp) => {
          const vRes = await fetch('{{ url("billing:verify_payment") }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-CSRFToken': this.csrf},
            body: JSON.stringify({...resp, plan_slug: slug, credit_amount: creditAmount}),
          });
          const vData = await vRes.json();
          if (vData.status === 'success') { this.redeemMsg = `✓ ${vData.label} activated!`; setTimeout(() => location.reload(), 1200); }
          else this.redeemErr = vData.error || 'Verification failed.';
        },
        prefill: {email: '{{ request.user.email }}'},
        theme: {color: '#10b981'},
      }).open();
    },
  };
}
</script>
{% endblock %}
