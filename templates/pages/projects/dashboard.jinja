{% extends "base.jinja" %}
{% block title %}Projects — Krizn{% endblock %}
{% block content %}
{% if onboarding_active %}
  {% include "partials/onboarding/_wizard_modal.jinja" %}
{% endif %}
<section class="space-y-6">
  {% if student_apps_base_is_ipv4 and apps_base_domain %}
    <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
      <p class="font-semibold text-amber-50">Student hostnames use your server IP as the domain</p>
      <p class="mt-1 text-amber-100/90">
        Add a line to <code class="font-mono text-xs">/etc/hosts</code> for each subdomain, e.g.
        <code class="rounded bg-slate-950/80 px-1 font-mono text-xs">{{ apps_base_domain }} radha.{{ apps_base_domain }}</code>.
        <code class="font-mono text-xs">TRAEFIK_HTTP_PUBLISH</code> and <code class="font-mono text-xs">STUDENT_SITE_HTTP_PORT</code> must match.
      </p>
    </div>
  {% endif %}

  {# ── Header row ── #}
  <div class="flex flex-wrap items-center justify-between gap-2">
    <h1 class="text-lg font-semibold text-white">Your Projects</h1>
    <div class="flex flex-wrap items-center gap-2">
      <a href="{{ url('projects:create') }}"
         class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-500 px-3 py-1.5 text-xs font-semibold text-slate-950 shadow hover:bg-emerald-400 active:scale-95 transition-transform">
        + New Project
      </a>
      <div class="flex items-center gap-1.5 rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-1.5 text-xs text-slate-300">
        <span class="font-semibold text-white">{{ project_count }}</span>
        <span class="text-slate-600">/</span>
        <span>{{ plan_limit }} site{{ 's' if plan_limit != 1 }}</span>
        <span class="text-slate-600">·</span>
        <span class="text-slate-400">{{ plan_label }}</span>
        {% if project_count >= plan_limit %}
          <span class="rounded-full bg-rose-500/20 px-1.5 py-px text-[10px] font-semibold text-rose-300 ring-1 ring-rose-500/30">Limit</span>
        {% endif %}
      </div>
      <a href="{{ url('billing:redeem') }}"
         class="inline-flex items-center gap-1 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-semibold text-emerald-300 hover:bg-emerald-500/20 transition-colors">
        🎟 Upgrade
      </a>
      <a href="{{ url('billing:redeem') }}#addons"
         class="inline-flex items-center gap-1 rounded-lg border border-sky-500/40 bg-sky-500/10 px-3 py-1.5 text-xs font-semibold text-sky-300 hover:bg-sky-500/20 transition-colors">
        ➕ Add-on
      </a>
    </div>
  </div>

  {# ── Plan expiry banner with inline share link ── #}
  {% if plan_is_expired and expiry_share_url %}
  <div x-data="expiryBanner()" class="rounded-xl border border-rose-500/40 bg-rose-950/25 px-4 py-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-rose-200">Your plan has expired</p>
        <p class="mt-0.5 text-xs text-rose-300/70">
          Share your referral link — earn credit, use it to renew for free.
          {% if expiry_partner and expiry_partner.credit_balance > 0 %}
          <span class="ml-1 text-emerald-400 font-semibold">You already have ₹{{ expiry_partner.credit_balance | float | round(0) | int }} credit!</span>
          {% endif %}
        </p>

        {# Inline link + copy + WhatsApp — no redirect needed #}
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <div class="flex min-w-0 flex-1 items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-950/60 px-2.5 py-1.5 max-w-xs">
            <span class="min-w-0 flex-1 truncate font-mono text-[11px] text-slate-400">{{ expiry_share_url }}</span>
          </div>
          <button type="button" @click="copy('{{ expiry_share_url }}')"
                  class="shrink-0 rounded-lg bg-emerald-500 px-3 py-1.5 text-xs font-bold text-slate-950 transition hover:bg-emerald-400 active:scale-95">
            <span x-show="!copied">Copy link</span>
            <span x-show="copied" x-cloak>✓ Copied!</span>
          </button>
          {% set wa_text = 'Join Krizn — deploy your website in minutes! Sign up using my link: ' ~ expiry_share_url %}
          <a href="https://wa.me/?text={{ wa_text | urlencode }}" target="_blank" rel="noopener noreferrer"
             class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-[#25D366]/40 bg-[#25D366]/10 px-3 py-1.5 text-xs font-semibold text-[#25D366] hover:bg-[#25D366]/20 active:scale-95 transition">
            <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
      <div class="flex shrink-0 flex-col gap-1.5 text-right">
        <a href="{{ url('billing:redeem') }}"
           class="inline-flex items-center gap-1 rounded-lg bg-rose-500 px-3 py-1.5 text-xs font-bold text-white hover:bg-rose-400 active:scale-95 transition">
          Renew plan →
        </a>
        <a href="{{ url('affiliates:partner') }}"
           class="text-[11px] text-slate-500 hover:text-slate-300 transition">View earnings</a>
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Promo ticker — pure CSS GPU scroll, zero JS ── #}
  {% if promo_messages %}
  {% set _ticker_s = promo_messages | length %}
  {% set _ticker_s = _ticker_s * 9 if _ticker_s * 9 > 30 else 30 %}
  <style>
    .promo-ticker-track { animation: promo-scroll {{ _ticker_s }}s linear infinite; }
    .promo-ticker-track:hover { animation-play-state: paused; }
    @media (prefers-reduced-motion: reduce) { .promo-ticker-track { animation: none; } }
  </style>
  <div class="flex items-center overflow-hidden rounded-lg border border-emerald-500/20 bg-gradient-to-r from-emerald-950/40 via-slate-900/60 to-slate-900/60" style="min-height:2rem;">

    {# Live badge — fixed left #}
    <div class="flex shrink-0 items-center gap-1.5 border-r border-emerald-500/20 px-2.5 py-1.5 self-stretch">
      <span class="relative flex h-1.5 w-1.5 shrink-0">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-50"></span>
        <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
      </span>
      <span class="text-[9px] font-bold tracking-widest text-emerald-400 uppercase">Live</span>
    </div>

    {# Scrolling strip — translate runs on GPU compositor, 0 JS #}
    <div class="flex-1 overflow-hidden">
      <div class="promo-ticker-track flex whitespace-nowrap" style="will-change:transform;">
        {% for _ in [1, 2] %}
          {% for msg in promo_messages %}
            <span class="inline-flex items-center gap-3 px-5 text-xs font-medium text-emerald-100/80">
              {{ msg }}
              <span class="text-emerald-700" aria-hidden="true">•</span>
            </span>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>

  {% endif %}

  {# ── Server Status ── #}
  {% set s = server %}
  {% macro sc(st) %}{{ 'text-rose-400' if st=='critical' else ('text-amber-400' if st=='warning' else 'text-emerald-400') }}{% endmacro %}
  {% macro bc(st) %}{{ 'bg-rose-500' if st=='critical' else ('bg-amber-400' if st=='warning' else 'bg-emerald-400') }}{% endmacro %}
  <div class="flex items-center gap-px overflow-hidden rounded-xl border border-slate-800 bg-slate-950 divide-x divide-slate-800">
    {% for item in [
      ('CPU',     s.cpu_pct,  s.cpu_status),
      ('RAM',     s.ram_pct,  s.ram_status),
      ('Storage', s.disk_pct, s.disk_status),
    ] %}
      <div class="flex flex-1 flex-col gap-1.5 px-4 py-3">
        <div class="flex items-center justify-between">
          <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ item[0] }}</span>
          <span class="text-xs font-bold {{ sc(item[2]) }}">{{ item[1] }}%</span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-slate-800">
          <div class="h-1 rounded-full {{ bc(item[2]) }}" style="width:{{ [item[1],100]|min }}%"></div>
        </div>
      </div>
    {% endfor %}
    <div class="flex flex-col gap-0.5 px-4 py-3">
      <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">Load</span>
      <span class="text-xs font-bold {{ sc(s.load_status) }}">{{ s.load1 }}</span>
    </div>
  </div>

  {# ── Projects table ── #}
  <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/50">
    {% if projects %}
      <table class="min-w-full divide-y divide-slate-800 text-sm">
        <thead class="bg-slate-950/60 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <tr>
            <th class="px-3 py-2">Project</th>
            <th class="px-3 py-2">Live Site</th>
            <th class="px-3 py-2">Created</th>
            <th class="px-3 py-2 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-200">
          {% for p in projects %}
            <tr class="hover:bg-slate-900/80 transition-colors">
              {# ── Project: name · status · subdomain — all inline ── #}
              <td class="px-3 py-2 whitespace-nowrap">
                <span class="font-medium text-white text-sm">{{ p.name }}</span>
                <span class="mx-1.5 text-slate-700">·</span>
                {% if p.status == 'running' %}
                  <span class="inline-flex rounded-full bg-emerald-500/15 px-1.5 py-px text-[9px] font-semibold text-emerald-300 ring-1 ring-emerald-500/30">Running</span>
                {% elif p.status == 'pending' %}
                  <span class="inline-flex rounded-full bg-amber-500/15 px-1.5 py-px text-[9px] font-semibold text-amber-300 ring-1 ring-amber-500/30">Pending</span>
                {% elif p.status == 'failed' %}
                  <span class="inline-flex rounded-full bg-rose-500/15 px-1.5 py-px text-[9px] font-semibold text-rose-300 ring-1 ring-rose-500/30">Failed</span>
                {% else %}
                  <span class="inline-flex rounded-full bg-slate-800 px-1.5 py-px text-[9px] font-semibold text-slate-300">{{ p.get_status_display() }}</span>
                {% endif %}
                <span class="mx-1.5 text-slate-700">·</span>
                <span class="font-mono text-[9px] text-slate-500">{{ p.subdomain }}</span>
              </td>

              {# ── Live site — all links inline ── #}
              <td class="px-3 py-2 whitespace-nowrap">
                {% if apps_base_domain and p.project_type == 'static' %}
                  {% set _fqdn = p.subdomain ~ '.' ~ apps_base_domain %}
                  {% set _port = ':' ~ student_site_port if student_site_port else '' %}
                  {% set _sub_root = student_site_scheme ~ '://' ~ _fqdn ~ _port ~ '/' %}
                  {% set _has_custom = p.custom_hostname and p.custom_hostname_verified %}
                  {% set _custom_root = (student_site_scheme ~ '://' ~ p.custom_hostname ~ '/') if _has_custom else '' %}
                  {% set _subs = p.subfolders.all() %}
                  <span class="inline-flex flex-wrap items-center gap-1">
                    {% if _has_custom %}
                      {% if _subs %}
                        {% for sf in _subs %}
                          {% set _path = (sf.path.strip('/') ~ '/') if sf.path else '' %}
                          <a href="{{ _custom_root ~ _path }}" target="_blank" rel="noopener noreferrer"
                             class="inline-flex items-center gap-0.5 rounded bg-amber-500/10 px-1.5 py-px text-[10px] font-semibold text-amber-300 ring-1 ring-amber-500/25 hover:bg-amber-500/20 transition-colors">
                            🔗 {% if _path %}/{{ _path }}{% else %}{{ p.custom_hostname }}{% endif %}
                          </a>
                          <form method="post" action="{{ url('projects:subfolder_delete', slug=p.slug, sf_id=sf.pk) }}"
                                onsubmit="return confirm('Remove subfolder \'{{ sf.path or '/' }}\'?')" class="inline">
                            {{ csrf_input }}
                            <button type="submit" title="Remove subfolder"
                                    class="text-[10px] text-rose-500 hover:text-rose-400 leading-none">×</button>
                          </form>
                        {% endfor %}
                      {% else %}
                        <a href="{{ _custom_root }}" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-0.5 rounded bg-amber-500/10 px-1.5 py-px text-[10px] font-semibold text-amber-300 ring-1 ring-amber-500/25 hover:bg-amber-500/20 transition-colors">
                          🔗 {{ p.custom_hostname }}
                        </a>
                      {% endif %}
                    {% else %}
                      {% if _subs %}
                        {% for sf in _subs %}
                          {% set _path = (sf.path.strip('/') ~ '/') if sf.path else '' %}
                          <a href="{{ _sub_root ~ _path }}" target="_blank" rel="noopener noreferrer"
                             class="inline-flex items-center gap-0.5 rounded bg-sky-500/10 px-1.5 py-px text-[10px] font-semibold text-sky-300 ring-1 ring-sky-500/25 hover:bg-sky-500/20 transition-colors">
                            🌐 {% if _path %}/{{ _path }}{% else %}{{ p.subdomain }}{% endif %}
                          </a>
                          <form method="post" action="{{ url('projects:subfolder_delete', slug=p.slug, sf_id=sf.pk) }}"
                                onsubmit="return confirm('Remove subfolder \'{{ sf.path or '/' }}\'?')" class="inline">
                            {{ csrf_input }}
                            <button type="submit" title="Remove subfolder"
                                    class="text-[10px] text-rose-500 hover:text-rose-400 leading-none">×</button>
                          </form>
                        {% endfor %}
                      {% else %}
                        <a href="{{ _sub_root }}" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-0.5 rounded bg-sky-500/10 px-1.5 py-px text-[10px] font-semibold text-sky-300 ring-1 ring-sky-500/25 hover:bg-sky-500/20 transition-colors">
                          🌐 {{ p.subdomain }}
                        </a>
                      {% endif %}
                      {% if p.custom_hostname and not p.custom_hostname_verified %}
                        <span class="text-[10px] text-slate-600">{{ p.custom_hostname }} (unverified)</span>
                      {% endif %}
                    {% endif %}
                  </span>
                {% elif apps_base_domain %}
                  <span class="font-mono text-[10px] text-slate-500">{{ p.subdomain }}</span>
                {% else %}
                  <span class="text-slate-600">—</span>
                {% endif %}
              </td>

              <td class="px-3 py-2 text-slate-400 text-xs whitespace-nowrap">{{ p.created_at.strftime("%d %b '%y") }}</td>
              <td class="px-3 py-2 text-right whitespace-nowrap">
                <span class="inline-flex items-center gap-1 text-xs font-medium">
                  <a href="{{ url('projects:upload_zip', slug=p.slug) }}" class="text-emerald-400 hover:text-emerald-300">ZIP</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:upload_static_files', slug=p.slug) }}" class="text-emerald-400 hover:text-emerald-300">Files</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:domain', slug=p.slug) }}" class="text-amber-400 hover:text-amber-300">Domain</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:logs', slug=p.slug) }}" class="text-slate-400 hover:text-white">Logs</a>
                  <span class="text-slate-700">·</span>
                  <a href="{{ url('projects:delete', slug=p.slug) }}" class="text-rose-400 hover:text-rose-300">Del</a>
                </span>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      {% include "partials/projects/_empty_state.jinja" %}
    {% endif %}
  </div>

  {# ── Upgrade nudge when at limit ── #}
  {% if project_count >= plan_limit %}
    <div class="rounded-xl border border-amber-500/40 bg-amber-500/10 px-5 py-4 text-sm text-amber-100">
      <p class="font-semibold text-amber-50">You've used all {{ plan_limit }} website slot{{ 's' if plan_limit != 1 }}.</p>
      <p class="mt-1 text-amber-100/80">Upgrade to a higher plan <strong>or</strong> buy an add-on to stack extra slots on top of your current plan.</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a href="{{ url('billing:redeem') }}"
           class="inline-flex items-center gap-1.5 rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-amber-400">
          🎟 Upgrade Plan
        </a>
        <a href="{{ url('billing:redeem') }}#addons"
           class="inline-flex items-center gap-1.5 rounded-lg border border-sky-500/60 bg-sky-500/15 px-4 py-2 text-sm font-semibold text-sky-200 hover:bg-sky-500/25">
          ➕ Buy Add-on (keep current plan)
        </a>
      </div>
    </div>
  {% endif %}

</section>
{% endblock %}

{% block extra_js %}
{% if onboarding_active %}<script src="{{ static('js/upload-form.js') }}"></script>{% endif %}
{% if plan_is_expired and expiry_share_url %}
<script>
function expiryBanner() {
  return {
    copied: false,
    copy(text) {
      navigator.clipboard.writeText(text);
      this.copied = true;
      setTimeout(() => this.copied = false, 2500);
    },
  };
}
</script>
{% endif %}
{% endblock %}
