<div
  x-show="toastMsg"
  x-transition
  :class="toastType === 'error' ? 'border-rose-500/40 bg-rose-950/90 text-rose-200' : 'border-emerald-500/40 bg-emerald-950/90 text-emerald-200'"
  class="fixed bottom-5 right-5 z-[200] max-w-xs rounded-xl border px-4 py-3 text-sm font-medium shadow-2xl backdrop-blur-sm"
  x-text="toastMsg"
  style="display:none;"
></div>

<div x-show="cartOpen" x-cloak class="fixed inset-0 z-[150]" style="display:none;">
  <div class="absolute inset-0 bg-slate-950/70 backdrop-blur-sm" @click="cartOpen = false"></div>
  <div class="absolute right-0 top-0 bottom-0 flex w-full max-w-sm flex-col border-l border-slate-800 bg-slate-900 shadow-2xl">
    <div class="flex items-center justify-between border-b border-slate-800 px-5 py-4">
      <h2 class="text-lg font-semibold text-white">Cart (<span x-text="cartCount"></span>)</h2>
      <button type="button" @click="cartOpen = false" class="text-xl leading-none text-slate-400 hover:text-white">✕</button>
    </div>
    <div class="flex-1 space-y-3 overflow-y-auto px-5 py-4">
      <template x-if="cartItems.length === 0">
        <div class="py-16 text-center">
          <p class="text-4xl">🛒</p>
          <p class="mt-3 text-sm text-slate-400">Your cart is empty</p>
        </div>
      </template>
      <template x-for="item in cartItems" :key="item.type + '-' + item.id">
        <div class="flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-950/60 p-3">
          <template x-if="item.type === 'product'">
            <div class="relative h-12 w-12 shrink-0">
              <img x-show="item.image_url" :src="item.image_url" alt="" class="h-12 w-12 rounded-lg object-cover">
              <div x-show="!item.image_url" class="flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br from-emerald-900 to-slate-800 text-lg text-emerald-400">📦</div>
            </div>
          </template>
          <template x-if="item.type === 'server'">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-sky-950 text-lg text-sky-300">🖥</div>
          </template>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-medium text-white" x-text="item.name"></p>
            <p class="text-xs text-slate-400">₹<span x-text="item.price.toFixed(2)"></span> × <span x-text="item.qty"></span></p>
          </div>
          <div class="shrink-0 text-right">
            <p class="text-sm font-semibold text-emerald-300">₹<span x-text="item.subtotal.toFixed(2)"></span></p>
            <button
              x-show="item.type === 'product'"
              type="button"
              @click="removeFromCart(item.product_id)"
              class="mt-1 text-[10px] text-slate-500 hover:text-rose-400"
            >Remove</button>
          </div>
        </div>
      </template>
    </div>
    <div class="space-y-3 border-t border-slate-800 px-5 py-4">
      <div class="flex items-center justify-between text-sm font-semibold">
        <span class="text-slate-300">Total</span>
        <span class="text-lg text-emerald-300">₹<span x-text="cartTotal.toFixed(2)"></span></span>
      </div>
      <button
        type="button"
        @click="cartOpen = false; checkoutOpen = true"
        :disabled="cartCount === 0"
        class="w-full rounded-xl bg-emerald-500 py-3 text-sm font-bold text-slate-950 shadow transition-all hover:bg-emerald-400 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-40"
      >
        Proceed to Checkout →
      </button>
    </div>
  </div>
</div>

<div x-show="checkoutOpen" x-cloak class="fixed inset-0 z-[160] flex items-center justify-center px-4" style="display:none;">
  <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" @click="checkoutOpen = false"></div>
  <div class="relative w-full max-w-md space-y-4 rounded-2xl border border-slate-700 bg-slate-900 p-6 shadow-2xl">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Checkout</h2>
      <button type="button" @click="checkoutOpen = false" class="text-xl text-slate-400 hover:text-white">✕</button>
    </div>
    <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3 text-sm text-slate-400">
      <template x-for="item in cartItems" :key="'co-' + item.type + '-' + item.id">
        <div class="flex justify-between gap-2 py-0.5">
          <span class="truncate" x-text="item.name"></span>
          <span class="shrink-0 text-emerald-300">₹<span x-text="item.subtotal.toFixed(2)"></span></span>
        </div>
      </template>
      <div class="mt-2 flex justify-between border-t border-slate-800 pt-2 font-semibold text-white">
        <span>Total</span>
        <span class="text-emerald-300">₹<span x-text="cartTotal.toFixed(2)"></span></span>
      </div>
    </div>
    <div class="space-y-3">
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-300">Full name *</label>
        <input type="text" x-model="buyerName" placeholder="Your name" class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-300">Email address *</label>
        <input type="email" x-model="buyerEmail" placeholder="you@example.com" class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-300">Phone (optional)</label>
        <input type="tel" x-model="buyerPhone" placeholder="+91 98765 43210" class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-emerald-500 focus:outline-none">
      </div>
    </div>
    <button
      type="button"
      @click="checkout()"
      :disabled="loading"
      class="flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-500 py-3 text-sm font-bold text-slate-950 transition-all hover:bg-emerald-400 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-50"
    >
      <span x-text="loading ? 'Opening payment…' : 'Pay ₹' + cartTotal.toFixed(2) + ' →'"></span>
    </button>
    <p class="text-center text-[11px] text-slate-600">Product + hosting in one payment · Secured by Razorpay</p>
  </div>
</div>
