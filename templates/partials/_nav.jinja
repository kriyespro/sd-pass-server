<header class="flex flex-col gap-4 border-b border-slate-800 pb-4 sm:flex-row sm:items-center sm:justify-between">
  <a href="{{ url('home') }}" class="text-lg font-semibold text-white hover:text-emerald-300">{{ site_name }}</a>
  <nav class="flex flex-wrap items-center gap-3 text-sm font-medium text-slate-300">
    <a href="{{ url('home') }}" class="hover:text-white">Home</a>
    <a href="{{ url('resell:store') }}" class="hover:text-amber-300">🛒 Resell</a>
    {% if request.user is defined and request.user.is_authenticated %}
      <a href="{{ url('affiliates:partner') }}" class="hover:text-violet-300">Partner</a>
      <a href="{{ url('projects:dashboard') }}" class="hover:text-white">Server</a>
      <a href="{{ url('billing:redeem') }}" class="hover:text-emerald-300">Upgrade</a>
      <a href="{{ url('notifications:list') }}" class="relative inline-flex items-center gap-1 hover:text-white">
        <span>Alerts</span>
        {% if notification_unread_count > 0 %}
          <span class="rounded-full bg-emerald-500 px-1.5 py-0.5 text-xs font-bold text-slate-950">{{ notification_unread_count }}</span>
        {% endif %}
      </a>
      {% if request.user is defined and request.user.is_staff %}
        <a href="{{ url('admin_monitor:dashboard') }}" class="rounded-md bg-violet-500/15 px-2 py-1 font-semibold text-violet-300 ring-1 ring-violet-500/40 hover:bg-violet-500/25">Admin</a>
      {% endif %}
      {% if trainer_portal_visible %}
        <a href="{{ url('trainer:overview') }}" class="hover:text-sky-300">Trainer</a>
      {% endif %}
      <form method="post" action="{{ url('accounts:logout') }}" class="inline">
        {{ csrf_input }}
        <button type="submit" class="hover:text-white">Log out</button>
      </form>
    {% else %}
      <a href="{{ url('accounts:login') }}" class="hover:text-white">Log in</a>
      <a href="{{ url('accounts:register') }}" class="rounded-lg bg-emerald-500/10 px-3 py-1 text-emerald-300 ring-1 ring-emerald-500/40 hover:bg-emerald-500/20">Sign up</a>
    {% endif %}
  </nav>
</header>
