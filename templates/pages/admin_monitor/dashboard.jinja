{% extends "base.jinja" %}
{% block title %}Mission Control — StudentCloud{% endblock %}
{% block content %}
<section class="space-y-4">

  {# ══ Header (compact) ══ #}
  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">Mission Control</h1>
      <p class="text-[11px] text-slate-500">Staff · live health &amp; billing</p>
    </div>
    <a href="{{ url('admin_monitor:dashboard') }}"
       class="rounded-md border border-slate-700 bg-slate-900 px-2 py-1 text-[11px] font-medium text-slate-300 hover:bg-slate-800">
      ↻ Refresh
    </a>
  </div>

  {# ══ Overview (server + platform) ══ #}
  {% set sv = server %}
  {% macro bar(pct, status) %}
    <div class="mt-0.5 h-1 w-full overflow-hidden rounded-full bg-slate-800">
      <div class="h-1 rounded-full
        {{ 'bg-rose-500' if status == 'critical' else ('bg-amber-400' if status == 'warning' else 'bg-emerald-400') }}"
        style="width:{{ [pct,100]|min }}%"></div>
    </div>
  {% endmacro %}
  {% macro stat_colour(status) %}
    {{ 'text-rose-400' if status == 'critical' else ('text-amber-400' if status == 'warning' else 'text-emerald-300') }}
  {% endmacro %}

  <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-2.5 sm:p-3">
    <div class="grid gap-1.5 sm:grid-cols-2 lg:grid-cols-4">
      <div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/40 px-2 py-1.5">
        <div class="flex items-center justify-between gap-1">
          <span class="text-[10px] font-semibold uppercase text-slate-500">CPU</span>
          <span class="text-xs font-bold {{ stat_colour(sv.cpu_status) }}">{{ sv.cpu_pct }}%</span>
        </div>
        {{ bar(sv.cpu_pct, sv.cpu_status) }}
        <p class="mt-0.5 truncate text-[10px] leading-tight text-slate-600">{{ sv.load1 }}/{{ sv.load5 }}/{{ sv.load15 }} · {{ sv.cpu_count }}c</p>
      </div>
      <div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/40 px-2 py-1.5">
        <div class="flex items-center justify-between gap-1">
          <span class="text-[10px] font-semibold uppercase text-slate-500">RAM</span>
          <span class="text-xs font-bold {{ stat_colour(sv.ram_status) }}">{{ sv.ram_pct }}%</span>
        </div>
        {{ bar(sv.ram_pct, sv.ram_status) }}
        <p class="mt-0.5 text-[10px] leading-tight text-slate-600">{{ sv.ram_used_gb }}/{{ sv.ram_total_gb }} GB</p>
      </div>
      <div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/40 px-2 py-1.5">
        <div class="flex items-center justify-between gap-1">
          <span class="text-[10px] font-semibold uppercase text-slate-500">Disk</span>
          <span class="text-xs font-bold {{ stat_colour(sv.disk_status) }}">{{ sv.disk_pct }}%</span>
        </div>
        {{ bar(sv.disk_pct, sv.disk_status) }}
        <p class="mt-0.5 text-[10px] leading-tight text-slate-600">{{ sv.disk_used_gb }}/{{ sv.disk_total_gb }} GB</p>
      </div>
      <div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/40 px-2 py-1.5">
        <div class="flex items-center justify-between gap-1">
          <span class="text-[10px] font-semibold uppercase text-slate-500">Net</span>
          <span class="text-xs font-bold text-sky-300">↑{{ sv.net_sent_mb }}M</span>
        </div>
        <p class="mt-1 text-[10px] leading-tight text-slate-600">↓{{ sv.net_recv_mb }}M · {{ sv.uptime_hours }}h up</p>
      </div>
    </div>

    <div class="mt-2 grid grid-cols-3 gap-1.5 sm:grid-cols-6">
      {% macro kpi(label, value, sub, colour='text-white') %}
        <div class="min-w-0 rounded-lg border border-slate-800/80 bg-slate-950/40 px-2 py-1.5">
          <p class="text-[10px] font-semibold uppercase text-slate-500">{{ label }}</p>
          <p class="text-base font-bold leading-tight {{ colour }}">{{ value }}</p>
          {% if sub %}<p class="mt-0.5 truncate text-[10px] leading-tight text-slate-600" title="{{ sub }}">{{ sub }}</p>{% endif %}
        </div>
      {% endmacro %}
      {{ kpi('Users', user_active, user_total ~ ' · +' ~ users_joined_week ~ ' 7d') }}
      {{ kpi('Projects', project_active, project_deleted ~ ' del · ' ~ projects_custom_domain ~ ' dom') }}
      {{ kpi('Running', projects_running, projects_failed ~ ' fail', 'text-emerald-300') }}
      {{ kpi('Uploads', upload_total, uploads_pending ~ ' pend · ' ~ ((upload_week_bytes/1048576)|round(1) if upload_week_bytes else 0) ~ 'MB 7d') }}
      {{ kpi('Alerts', notifications_unread, deployments_failed_week ~ ' fail 7d', 'text-amber-300') }}
      {{ kpi('Coupons', coupons_available, coupons_used ~ ' used', 'text-violet-300') }}
    </div>
  </div>

  {# ══ Billing / Plans (compact) ══ #}
  <div class="flex flex-wrap items-center gap-2">
    <span class="text-[10px] font-semibold uppercase text-slate-500">Plans</span>
    {% set plan_colours = {'free':'bg-slate-700','starter':'bg-sky-600','pro':'bg-emerald-600','business':'bg-violet-600'} %}
    {% for row in sub_by_plan %}
      <div class="flex items-center gap-1.5 rounded-lg border border-slate-800 bg-slate-900/60 px-2 py-1">
        <span class="rounded-full {{ plan_colours.get(row.plan_slug, 'bg-slate-700') }} px-1.5 py-0.5 text-[10px] font-bold text-white">{{ row.plan_slug | capitalize }}</span>
        <span class="text-xs font-semibold text-white">{{ row.c }}</span>
        <span class="text-[10px] text-slate-500">{{ row.limit }}/plan</span>
      </div>
    {% else %}
      <p class="text-[10px] text-slate-500">No subscriptions yet.</p>
    {% endfor %}
    <a href="{{ url('admin:billing_subscription_changelist') }}" class="rounded-lg border border-violet-700/40 bg-violet-600/10 px-2 py-1 text-[10px] font-semibold text-violet-300 hover:bg-violet-600/20">Plans →</a>
    <a href="{{ url('admin:billing_couponcode_changelist') }}" class="rounded-lg border border-emerald-700/40 bg-emerald-600/10 px-2 py-1 text-[10px] font-semibold text-emerald-300 hover:bg-emerald-600/20">Coupons →</a>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
    <div class="flex items-center justify-between gap-3 border-b border-slate-800 bg-slate-950/60 px-4 py-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-200">All student websites</h2>
        <p class="mt-0.5 text-xs text-slate-500">{{ student_websites|length }} project{{ 's' if student_websites|length != 1 }} — contact &amp; plan</p>
      </div>
      <a
        href="{{ url('admin_monitor:export_websites_csv') }}"
        title="Download CSV"
        class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-slate-700 bg-slate-800 text-xs font-bold text-emerald-300 hover:border-emerald-500/50 hover:bg-slate-700 hover:text-emerald-200"
      >D</a>
    </div>
    <div class="max-h-[32rem] overflow-auto">
      <table class="min-w-full text-left text-xs">
        <thead class="sticky top-0 z-10 bg-slate-950/95 text-slate-500">
          <tr>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Website</th>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Email</th>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Name</th>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Mobile</th>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Plan</th>
            <th class="px-3 py-2.5 text-center font-semibold uppercase tracking-wide">Sites</th>
            <th class="px-3 py-2.5 font-semibold uppercase tracking-wide">Status</th>
            <th class="w-8 px-1 py-2.5 text-center font-semibold uppercase tracking-wide" title="Download site files">D</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-300">
          {% for row in student_websites %}
            <tr class="hover:bg-slate-900/80">
              <td class="px-3 py-2.5">
                <span class="font-medium text-white">{{ row.project_name }}</span>
                {% if row.site_url %}
                  <span class="text-slate-600"> · </span>
                  <a href="{{ row.site_url }}" target="_blank" rel="noopener noreferrer" class="text-[11px] font-medium text-sky-400 hover:text-sky-300">Visit website ↗</a>
                {% endif %}
                {% if row.custom_url %}
                  <span class="text-slate-600"> · </span>
                  <a href="{{ row.custom_url }}" target="_blank" rel="noopener noreferrer" class="text-[11px] font-medium text-amber-400 hover:text-amber-300">Custom domain ↗</a>
                {% endif %}
              </td>
              <td class="px-3 py-2.5"><a href="mailto:{{ row.email }}" class="text-sky-300 hover:underline">{{ row.email }}</a></td>
              <td class="px-3 py-2.5 text-slate-200">{{ row.name }}</td>
              <td class="px-3 py-2.5 font-mono text-slate-400">{{ row.mobile }}</td>
              <td class="px-3 py-2.5">
                {% set pc = {'free':'bg-slate-600','starter':'bg-sky-600','pro':'bg-emerald-600','business':'bg-violet-600'} %}
                <span class="inline-block rounded-full {{ pc.get(row.plan_slug, 'bg-slate-600') }} px-2 py-0.5 text-[10px] font-bold text-white">{{ row.plan_slug | capitalize }}</span>
              </td>
              <td class="px-3 py-2.5 text-center font-semibold text-white">{{ row.site_count }}</td>
              <td class="px-3 py-2.5"><span class="rounded-full bg-slate-800 px-2 py-0.5 text-[10px] text-emerald-300">{{ row.status }}</span></td>
              <td class="px-1 py-2.5 text-center">
                {% if row.has_site_files %}
                  <a
                    href="{{ url('admin_monitor:download_project_files', project_id=row.project_id) }}"
                    title="Download site files (ZIP)"
                    class="inline-flex h-6 w-6 items-center justify-center rounded border border-slate-700 bg-slate-800 text-[10px] font-bold text-emerald-300 hover:border-emerald-500/50 hover:bg-slate-700 hover:text-emerald-200"
                  >D</a>
                {% else %}
                  <span class="inline-flex h-6 w-6 items-center justify-center rounded border border-slate-800 text-[10px] text-slate-600" title="No files uploaded yet">—</span>
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr><td colspan="8" class="py-10 text-center text-slate-500">No projects yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  {# ══ Tables grid ══ #}
  <div class="grid gap-5 xl:grid-cols-2">

    {# Recent uploads #}
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/60 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">📦 Recent Uploads</h2>
        <a href="{{ url('admin:uploads_projectupload_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">All →</a>
      </div>
      <div class="max-h-72 overflow-auto">
        <table class="min-w-full text-left text-xs">
          <thead class="sticky top-0 bg-slate-950/95 text-slate-500">
            <tr>
              <th class="px-3 py-2">Time</th><th class="px-3 py-2">Project</th>
              <th class="px-3 py-2">Owner</th><th class="px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800 text-slate-300">
            {% for u in recent_uploads %}
              <tr class="hover:bg-slate-900/80">
                <td class="whitespace-nowrap px-3 py-2 font-mono text-slate-500">{{ u.created_at.strftime("%m-%d %H:%M") }}</td>
                <td class="px-3 py-2"><a href="{{ url('admin:projects_project_change', u.project.pk) }}" class="text-emerald-400 hover:underline">{{ u.project.name }}</a></td>
                <td class="max-w-[8rem] truncate px-3 py-2 text-slate-500">{{ u.owner.email }}</td>
                <td class="px-3 py-2"><span class="rounded bg-slate-800 px-1.5 py-0.5 font-mono text-[10px]">{{ u.get_status_display() }}</span></td>
              </tr>
            {% else %}
              <tr><td colspan="4" class="py-8 text-center text-slate-500">No uploads.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {# Recent logs #}
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/60 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">📋 Project Logs</h2>
        <a href="{{ url('admin:logs_logentry_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">All →</a>
      </div>
      <ul class="max-h-72 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for e in recent_logs %}
          <li class="px-4 py-2.5 hover:bg-slate-900/60">
            <div class="flex flex-wrap items-baseline gap-2">
              <span class="font-mono text-slate-500">{{ e.created_at.strftime("%m-%d %H:%M") }}</span>
              <span class="rounded bg-slate-800 px-1.5 text-[10px] font-semibold uppercase text-slate-400">{{ e.get_kind_display() }}</span>
              <a href="{{ url('admin:projects_project_change', e.project.pk) }}" class="text-emerald-400 hover:underline">{{ e.project.name }}</a>
            </div>
            <p class="mt-1 line-clamp-1 text-slate-500">{{ e.message }}</p>
          </li>
        {% else %}
          <li class="py-8 text-center text-slate-500">No log entries.</li>
        {% endfor %}
      </ul>
    </div>

  </div>

  <div class="grid gap-5 lg:grid-cols-3">

    {# New users #}
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/60 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">👤 New Users</h2>
        <a href="{{ url('admin:accounts_user_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">All →</a>
      </div>
      <ul class="max-h-72 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for u in recent_users %}
          <li class="flex items-center justify-between gap-2 px-4 py-2.5">
            <a href="{{ url('admin:accounts_user_change', u.pk) }}" class="truncate font-medium text-sky-300 hover:underline">{{ u.email }}</a>
            <span class="shrink-0 font-mono text-slate-500">{{ u.date_joined.strftime("%m-%d") }}</span>
          </li>
        {% else %}
          <li class="py-8 text-center text-slate-500">No users.</li>
        {% endfor %}
      </ul>
    </div>

    {# New projects #}
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/60 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">🌐 New Projects</h2>
        <a href="{{ url('admin:projects_project_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">All →</a>
      </div>
      <ul class="max-h-72 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for p in recent_projects %}
          <li class="px-4 py-2.5">
            <a href="{{ url('admin:projects_project_change', p.pk) }}" class="font-medium text-emerald-300 hover:underline">{{ p.name }}</a>
            <p class="mt-0.5 truncate text-slate-500">{{ p.owner.email }} · {{ p.get_status_display() }}</p>
          </li>
        {% else %}
          <li class="py-8 text-center text-slate-500">No projects.</li>
        {% endfor %}
      </ul>
    </div>

    {# Security scans #}
    <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950/60 px-4 py-3">
        <h2 class="text-sm font-semibold text-slate-200">🔒 Security Scans</h2>
        <a href="{{ url('admin:security_scanreport_changelist') }}" class="text-xs text-violet-400 hover:text-violet-300">All →</a>
      </div>
      <ul class="max-h-72 divide-y divide-slate-800 overflow-y-auto text-xs">
        {% for s in recent_scans %}
          <li class="px-4 py-2.5">
            <div class="flex items-baseline gap-2">
              <span class="font-mono text-slate-500">{{ s.created_at.strftime("%m-%d %H:%M") }}</span>
              <span class="font-semibold text-slate-200">{{ s.get_status_display() }}</span>
            </div>
            {% if s.upload and s.upload.project %}
              <p class="mt-0.5 truncate text-slate-500">{{ s.upload.project.name }}</p>
            {% endif %}
          </li>
        {% else %}
          <li class="py-8 text-center text-slate-500">No scans.</li>
        {% endfor %}
      </ul>
    </div>

  </div>

  {# ══ Quick links ══ #}
  <div class="rounded-xl border border-slate-800 bg-slate-950/50 p-4">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-500">⚡ Quick Links</p>
    <div class="flex flex-wrap gap-2 text-xs">
      {% set links = [
        ('Billing', url('admin:billing_subscription_changelist')),
        ('Coupons', url('admin:billing_couponcode_changelist')),
        ('Batches', url('admin:students_batch_changelist')),
        ('Quotas', url('admin:students_quotaconfig_changelist')),
        ('Deployments', url('admin:deployments_deployment_changelist')),
        ('Backups', url('admin:backups_backupjob_changelist')),
        ('Databases', url('admin:databases_databaseinstance_changelist')),
        ('Notifications', url('admin:notifications_notification_changelist')),
        ('Users', url('admin:accounts_user_changelist')),
        ('Projects', url('admin:projects_project_changelist')),
      ] %}
      {% for label, href in links %}
        <a href="{{ href }}"
           class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 font-medium text-slate-300 hover:border-violet-500/50 hover:bg-slate-800 hover:text-violet-300 transition-colors">
          {{ label }}
        </a>
      {% endfor %}
    </div>
  </div>

</section>
{% endblock %}
