{% if log_entries %}
  <ul class="max-h-[32rem] divide-y divide-slate-800 overflow-y-auto text-sm">
    {% for e in log_entries %}
      <li class="px-4 py-3 hover:bg-slate-900/50">
        <div class="flex flex-wrap items-baseline gap-2 text-xs text-slate-500">
          <span class="font-mono text-slate-400">{{ e.created_at.strftime("%Y-%m-%d %H:%M:%S") }}</span>
          <span class="rounded bg-slate-800 px-1.5 py-0.5 font-semibold uppercase tracking-wide text-emerald-200/90">{{ e.get_kind_display() }}</span>
        </div>
        <pre class="mt-1 whitespace-pre-wrap break-words font-sans text-slate-200">{{ e.message }}</pre>
      </li>
    {% endfor %}
  </ul>
  {% if page_obj.has_other_pages() %}
    <div class="flex justify-center gap-2 border-t border-slate-800 px-4 py-3 text-xs">
      {% if page_obj.has_previous() %}
        <a href="{{ url('projects:logs', slug=project.slug) }}?page={{ page_obj.previous_page_number() }}" class="text-emerald-400 hover:text-emerald-300">Newer</a>
      {% endif %}
      {% if page_obj.has_next() %}
        <a href="{{ url('projects:logs', slug=project.slug) }}?page={{ page_obj.next_page_number() }}" class="text-emerald-400 hover:text-emerald-300">Older</a>
      {% endif %}
    </div>
  {% endif %}
{% else %}
  <p class="px-4 py-8 text-center text-sm text-slate-500">No log lines yet. Upload a ZIP or wait for a deploy job.</p>
{% endif %}
