{% extends "base.jinja" %}
{% block title %}Create account — StudentCloud Deploy{% endblock %}
{% block content %}
<div class="mx-auto max-w-lg rounded-2xl border border-slate-800 bg-slate-900/70 p-8">
  <h1 class="text-2xl font-semibold text-white">Create your account</h1>
  <p class="mt-2 text-sm text-slate-400">Name, email, mobile (optional), and password.</p>
  <form method="post" class="mt-6 space-y-4">
    {{ csrf_input }}
    {% for field in form %}
      <div>
        <label for="{{ field.id_for_label }}" class="block text-sm font-medium text-slate-200">{{ field.label }}</label>
        {{ field }}
        {% if field.help_text %}
          <p class="mt-1 text-xs text-slate-500">{{ field.help_text|safe }}</p>
        {% endif %}
        {% if field.errors %}
          {% for err in field.errors %}
            <p class="mt-1 text-sm text-rose-300">{{ err }}</p>
          {% endfor %}
        {% endif %}
      </div>
    {% endfor %}
    <button type="submit" class="w-full rounded-lg bg-emerald-500 py-2 text-sm font-semibold text-slate-950 hover:bg-emerald-400">Create account</button>
  </form>
  <p class="mt-4 text-center text-sm text-slate-400">
    Already have an account?
    <a href="{{ url('accounts:login') }}" class="font-semibold text-emerald-400 hover:text-emerald-300">Log in</a>
  </p>
</div>
{% endblock %}
