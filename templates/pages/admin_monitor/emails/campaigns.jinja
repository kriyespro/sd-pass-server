{% extends "base.jinja" %}
{% block title %}Email Campaigns — Krizn{% endblock %}
{% block content %}
<section class="space-y-4">

  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">Email Campaigns</h1>
      <p class="text-[11px] text-slate-500">Recurring sends — weekly · every 2 weeks · monthly</p>
    </div>
    <div class="flex flex-wrap gap-1.5">
      {% if due_count %}
        <form method="post" action="{{ url('admin_emails:campaigns_process_due') }}">
          {{ csrf_input }}
          <button type="submit"
                  class="rounded border border-amber-600/50 bg-amber-600/15 px-2.5 py-1 text-[11px] font-semibold text-amber-300 hover:bg-amber-600/25">
            ▶ Run {{ due_count }} Due
          </button>
        </form>
      {% endif %}
      <a href="{{ url('admin_emails:campaign_create') }}"
         class="rounded border border-emerald-700/40 bg-emerald-600/10 px-2.5 py-1 text-[11px] font-semibold text-emerald-300 hover:bg-emerald-600/20">
        + New Campaign
      </a>
      <a href="{{ url('admin_emails:list') }}"
         class="rounded border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-medium text-slate-400 hover:bg-slate-800">
        ← Email
      </a>
    </div>
  </div>

  {% if messages %}
    <div class="space-y-1">
      {% for message in messages %}
        <p class="rounded-lg border px-3 py-2 text-xs
          {{ 'border-emerald-800/50 bg-emerald-950/40 text-emerald-300' if message.tags == 'success' else 'border-rose-800/50 bg-rose-950/40 text-rose-300' }}">
          {{ message }}
        </p>
      {% endfor %}
    </div>
  {% endif %}

  {% if campaigns %}
    <div class="space-y-2">
      {% set freq_colours = {
        'weekly':   'bg-sky-800/40 text-sky-300',
        'biweekly': 'bg-violet-800/40 text-violet-300',
        'monthly':  'bg-amber-800/40 text-amber-300',
      } %}
      {% for c in campaigns %}
        <div class="rounded-xl border {{ 'border-slate-800 bg-slate-900/50' if c.is_active else 'border-slate-800/50 bg-slate-900/20 opacity-60' }} p-3">
          <div class="flex flex-wrap items-center justify-between gap-3">

            {# Left: info #}
            <div class="flex flex-wrap items-center gap-3 min-w-0">
              {# Active indicator #}
              <span class="h-2 w-2 shrink-0 rounded-full {{ 'bg-emerald-400' if c.is_active else 'bg-slate-600' }}"></span>

              {# Name + badges #}
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-white text-sm">{{ c.name }}</p>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-bold {{ freq_colours.get(c.frequency, 'bg-slate-700 text-slate-400') }}">
                    {{ c.get_frequency_display() }}
                  </span>
                </div>
                <div class="mt-0.5 flex flex-wrap gap-x-3 gap-y-0.5 text-[11px] text-slate-500">
                  <span>Template: <span class="text-slate-300">{{ c.template.get_template_type_display() }}</span></span>
                  <span>List: <span class="text-slate-300">{{ c.email_list.name }}</span> <span class="text-slate-600">({{ c.email_list.count }})</span></span>
                </div>
              </div>
            </div>

            {# Right: schedule + actions #}
            <div class="flex flex-wrap items-center gap-3">
              <div class="text-right text-[10px]">
                <p class="text-slate-500">Next run</p>
                <p class="font-mono {{ 'text-amber-300' if c.is_due else 'text-slate-300' }}">
                  {{ c.next_run_at.strftime('%Y-%m-%d %H:%M') }}
                  {% if c.is_due %}<span class="ml-1 text-amber-400">● due</span>{% endif %}
                </p>
                {% if c.last_run_at %}
                  <p class="text-slate-600 mt-0.5">Last: {{ c.last_run_at.strftime('%m-%d %H:%M') }}</p>
                {% endif %}
              </div>

              <div class="flex gap-1">
                <form method="post" action="{{ url('admin_emails:campaign_run_now', pk=c.pk) }}"
                      onsubmit="return confirm('Send campaign &quot;{{ c.name }}&quot; now to {{ c.email_list.count }} recipients?')" class="inline">
                  {{ csrf_input }}
                  <button type="submit"
                          class="rounded border border-emerald-700/40 bg-emerald-600/10 px-2 py-0.5 text-[10px] font-semibold text-emerald-300 hover:bg-emerald-600/20">
                    Send Now
                  </button>
                </form>
                <form method="post" action="{{ url('admin_emails:campaign_toggle', pk=c.pk) }}" class="inline">
                  {{ csrf_input }}
                  <button type="submit"
                          class="rounded border {{ 'border-slate-700 text-slate-400 hover:bg-slate-800' if c.is_active else 'border-emerald-700/40 text-emerald-400 hover:bg-emerald-600/10' }} bg-transparent px-2 py-0.5 text-[10px] font-semibold">
                    {{ 'Pause' if c.is_active else 'Resume' }}
                  </button>
                </form>
                <a href="{{ url('admin_emails:campaign_edit', pk=c.pk) }}"
                   class="rounded border border-sky-700/40 bg-sky-600/10 px-2 py-0.5 text-[10px] font-semibold text-sky-300 hover:bg-sky-600/20">
                  Edit
                </a>
                <form method="post" action="{{ url('admin_emails:campaign_delete', pk=c.pk) }}"
                      onsubmit="return confirm('Delete campaign &quot;{{ c.name }}&quot;?')" class="inline">
                  {{ csrf_input }}
                  <button type="submit"
                          class="rounded border border-rose-700/40 bg-rose-600/10 px-2 py-0.5 text-[10px] font-semibold text-rose-300 hover:bg-rose-600/20">
                    Del
                  </button>
                </form>
              </div>
            </div>

          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="rounded-xl border border-dashed border-slate-700 bg-slate-900/20 px-6 py-12 text-center">
      <p class="text-slate-500">No campaigns yet.</p>
      <a href="{{ url('admin_emails:campaign_create') }}"
         class="mt-3 inline-block rounded border border-emerald-700/40 bg-emerald-600/10 px-3 py-1.5 text-xs font-semibold text-emerald-300 hover:bg-emerald-600/20">
        Create your first campaign →
      </a>
    </div>
  {% endif %}

</section>
{% endblock %}
