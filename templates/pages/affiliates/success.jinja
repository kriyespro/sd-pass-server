{% extends "base.jinja" %}
{% block title %}Application Received — Krizn Affiliate{% endblock %}
{% block content %}
<section class="mx-auto max-w-lg py-16 text-center">
  <p class="text-5xl">🎉</p>
  <h1 class="mt-4 text-2xl font-bold text-white">Application received</h1>
  <p class="mt-3 text-sm text-slate-400">
    Thanks{% if application %}, {{ application.name }}{% endif %}! We review applications within 48 hours.
    Once approved, open <a href="{{ url('affiliates:dashboard') }}" class="text-emerald-400 hover:text-emerald-300">Affiliate Dashboard</a>
    to copy your product and store links.
  </p>
  <a href="{{ url('resell:store') }}" class="mt-8 inline-block rounded-lg border border-slate-700 px-5 py-2.5 text-sm text-slate-300 hover:text-white">
    Browse Resell Store →
  </a>
</section>
{% endblock %}
