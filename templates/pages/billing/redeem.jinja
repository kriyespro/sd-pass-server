{% extends "base.jinja" %}
{% block title %}Upgrade Plan — Krizn{% endblock %}
{% block content %}
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<section class="mx-auto max-w-3xl space-y-8" x-data="razorpayCheckout()"
         x-init="
           if(window.location.hash === '#addons') { $nextTick(() => document.getElementById('addons-section')?.scrollIntoView({behavior:'smooth'})); }
           const plan = new URLSearchParams(window.location.search).get('plan');
           if (plan) { $nextTick(() => document.getElementById('plan-' + plan)?.scrollIntoView({behavior:'smooth', block:'center'})); }
         ">

  {# ── Page header ── #}
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-white">Upgrade Your Plan</h1>
      <p class="mt-1 text-sm text-slate-400">Choose a plan below and pay securely with Razorpay.</p>
    </div>
    <a href="{{ url('projects:dashboard') }}" class="text-sm font-medium text-slate-400 hover:text-white">← Back</a>
  </div>

  {# ── Current plan badge ── #}
  {% set plan = subscription.plan_slug %}
  <div class="flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/60 px-5 py-4">
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Current Plan</p>
      <p class="mt-0.5 text-lg font-semibold text-white">{{ plan_labels.get(plan, plan | capitalize) }}</p>
      {% if subscription.current_period_end %}
        <p class="mt-1 text-xs text-slate-400">
          Active until {{ subscription.current_period_end.strftime('%d %b %Y') }}
        </p>
      {% endif %}
    </div>
    <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-300 ring-1 ring-emerald-500/30">
      {% if subscription.max_projects >= 999 %}Unlimited websites{% else %}{{ subscription.max_projects }} website{{ 's' if subscription.max_projects != 1 }}{% endif %}
    </span>
  </div>

  {# ── Payment error/success banners ── #}
  <div x-show="errorMsg" x-cloak
       class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-4 py-3 text-sm text-rose-100">
    <span x-text="errorMsg"></span>
  </div>
  <div x-show="successMsg" x-cloak
       class="rounded-lg border border-emerald-700/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-100">
    <span x-text="successMsg"></span>
  </div>

  {# ── Pricing cards ── #}
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {% for p in plans %}
      <div id="plan-{{ p.slug }}" class="relative flex flex-col rounded-2xl border {{ 'border-emerald-500/60 bg-emerald-500/5 ring-1 ring-emerald-500/30' if p.highlight else 'border-slate-800 bg-slate-900/60' }} p-5">
        {% if p.highlight %}
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-bold text-slate-950">Most Popular</span>
        {% endif %}
        <p class="text-base font-semibold text-white">{{ p.name }}</p>
        <p class="text-xs text-slate-500">{{ p.subtitle }}</p>
        <p class="mt-2 text-2xl font-bold text-white">{{ p.price }}<span class="text-sm font-normal text-slate-400">/{{ p.period }}</span></p>
        <p class="mt-3 text-sm text-slate-400">
          <span class="font-semibold text-emerald-300">{{ p.sites }} website{{ 's' if p.sites != '1' }}</span>
          {% if p.get('flask', 0) > 0 %}
            <span class="ml-2 inline-flex items-center gap-1 rounded-full bg-amber-500/15 px-2 py-0.5 text-xs font-semibold text-amber-300 ring-1 ring-amber-500/30">
              🐍 {{ p.flask }} Flask app{{ 's' if p.flask != 1 }}
            </span>
          {% endif %}
        </p>
        <p class="mt-1 text-xs text-slate-500">{{ p.specs }}</p>
        <ul class="mt-3 space-y-1 text-xs text-slate-400">
          <li>✓ Static site hosting</li>
          <li>✓ Custom domain support</li>
          <li>✓ 1-year validity</li>
          {% if p.get('flask', 0) > 0 %}<li>✓ Flask + SQLite app hosting</li>{% endif %}
        </ul>
        <div class="mt-4 flex-1 flex items-end">
          {% if subscription.plan_slug == p.slug and subscription.is_active and subscription.is_paid %}
            <span class="w-full text-center rounded-lg border border-emerald-600/40 bg-emerald-500/10 px-4 py-2.5 text-sm font-semibold text-emerald-300">
              ✓ Current Plan
            </span>
          {% else %}
            <button
              @click="pay('{{ p.slug }}', '{{ p.price }}', '{{ p.name }}')"
              :disabled="loading"
              class="w-full rounded-lg {{ 'bg-emerald-500 hover:bg-emerald-400 text-slate-950' if p.highlight else 'bg-slate-700 hover:bg-slate-600 text-white' }} px-4 py-2.5 text-sm font-semibold transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
              <span x-show="loading && activePlan === '{{ p.slug }}'" x-cloak>Processing…</span>
              <span x-show="!(loading && activePlan === '{{ p.slug }}')">Buy Now — {{ p.price }}/yr</span>
            </button>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {# ── Add-on Plans ── #}
  <div id="addons-section" class="space-y-4">
    <div>
      <h2 class="text-xl font-semibold text-white">Add-on Plans</h2>
      <p class="mt-1 text-sm text-slate-400">
        Already on a plan? Buy an add-on to stack extra website slots on top — your current plan stays active.
      </p>
    </div>

    {# Active add-ons summary #}
    {% if active_addons %}
      <div class="rounded-xl border border-sky-700/40 bg-sky-900/20 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-sky-400">Your Active Add-ons</p>
        <ul class="mt-2 space-y-1.5">
          {% for addon in active_addons %}
            <li class="flex items-center justify-between text-sm">
              <span class="text-sky-100">{{ addon.plan_label }}
                <span class="text-slate-500">·</span>
                {% if addon.extra_flask_projects > 0 %}
                  <span class="text-amber-300">+{{ addon.extra_flask_projects }} Flask app{{ 's' if addon.extra_flask_projects != 1 }}</span>
                {% else %}
                  <span class="text-emerald-300">+{{ addon.extra_projects }} site{{ 's' if addon.extra_projects != 1 }}</span>
                {% endif %}
              </span>
              <span class="text-xs text-slate-400">until {{ addon.current_period_end.strftime('%d %b %Y') }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {# Add-on error/success banners #}
    <div x-show="addonErrorMsg" x-cloak
         class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-4 py-3 text-sm text-rose-100">
      <span x-text="addonErrorMsg"></span>
    </div>
    <div x-show="addonSuccessMsg" x-cloak
         class="rounded-lg border border-sky-700/60 bg-sky-950/40 px-4 py-3 text-sm text-sky-100">
      <span x-text="addonSuccessMsg"></span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {% for p in plans %}
        {% if p.slug != 'test_plan' %}
          <div class="relative flex flex-col rounded-2xl border border-sky-800/40 bg-sky-900/10 p-5">
            <span class="absolute -top-3 right-4 rounded-full bg-sky-600 px-2.5 py-0.5 text-[10px] font-bold text-white tracking-wide">ADD-ON</span>
            <p class="text-base font-semibold text-white">{{ p.name }}</p>
            <p class="text-xs text-slate-500">{{ p.subtitle }}</p>
            <p class="mt-2 text-2xl font-bold text-white">{{ p.price }}<span class="text-sm font-normal text-slate-400">/{{ p.period }}</span></p>
            <p class="mt-3 text-sm text-slate-400">
              <span class="font-semibold text-sky-300">+{{ p.sites }} extra site{{ 's' if p.sites != '1' }}</span>
            </p>
            <p class="mt-1 text-xs text-slate-500">{{ p.specs }}</p>
            <div class="mt-4 flex-1 flex items-end">
              <button
                @click="payAddon('{{ p.slug }}', '{{ p.price }}', '{{ p.name }}')"
                :disabled="addonLoading"
                class="w-full rounded-lg bg-sky-700 hover:bg-sky-600 text-white px-4 py-2.5 text-sm font-semibold transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                <span x-show="addonLoading && addonActivePlan === '{{ p.slug }}'" x-cloak>Processing…</span>
                <span x-show="!(addonLoading && addonActivePlan === '{{ p.slug }}')">Add {{ p.sites }} site{{ 's' if p.sites != '1' }} — {{ p.price }}/yr</span>
              </button>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {# ── Flask Add-on ── #}
  {% if flask_addon %}
  <div class="space-y-4">
    <div>
      <h2 class="text-xl font-semibold text-white">🐍 Flask App Add-on</h2>
      <p class="mt-1 text-sm text-slate-400">
        Add a Flask app slot to your existing plan. Requires WordPress Pro or higher base plan.
        Flask runtime coming soon — lock in your slot now.
      </p>
    </div>
    <div class="relative flex flex-col rounded-2xl border border-amber-700/40 bg-amber-900/10 p-5 max-w-sm">
      <span class="absolute -top-3 right-4 rounded-full bg-amber-600 px-2.5 py-0.5 text-[10px] font-bold text-white tracking-wide">FLASK ADD-ON</span>
      <p class="text-base font-semibold text-white">{{ flask_addon.name }}</p>
      <p class="text-xs text-slate-400 mt-0.5">{{ flask_addon.subtitle }}</p>
      <p class="mt-2 text-2xl font-bold text-white">{{ flask_addon.price }}<span class="text-sm font-normal text-slate-400">/{{ flask_addon.period }}</span></p>
      <p class="mt-3 text-sm text-amber-300 font-semibold">+1 Flask app slot</p>
      <p class="mt-1 text-xs text-slate-500">{{ flask_addon.specs }}</p>
      <ul class="mt-3 space-y-1 text-xs text-slate-400">
        <li>✓ Python · Flask · SQLite</li>
        <li>✓ HTML · CSS · Tailwind · JS</li>
        <li>✓ 1-year validity</li>
        <li>✓ Stacks on top of base plan</li>
      </ul>
      <div class="mt-4">
        <button
          @click="payAddon('{{ flask_addon.slug }}', '{{ flask_addon.price }}', '{{ flask_addon.name }}')"
          :disabled="addonLoading"
          class="w-full rounded-lg bg-amber-600 hover:bg-amber-500 text-white px-4 py-2.5 text-sm font-semibold transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
          <span x-show="addonLoading && addonActivePlan === '{{ flask_addon.slug }}'" x-cloak>Processing…</span>
          <span x-show="!(addonLoading && addonActivePlan === '{{ flask_addon.slug }}')">Add Flask Slot — {{ flask_addon.price }}/yr</span>
        </button>
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Coupon redemption form ── #}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    <h2 class="text-base font-semibold text-white">Have a Coupon Code?</h2>
    <p class="mt-1 text-sm text-slate-400">Enter it below to activate your plan instantly — no payment needed.</p>

    {% if form.errors or form.non_field_errors() %}
      <div class="mt-4 rounded-lg border border-rose-700/60 bg-rose-950/40 px-4 py-3 text-sm text-rose-100">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
        {% for field in form %}{% for err in field.errors %}{{ err }}{% endfor %}{% endfor %}
      </div>
    {% endif %}

    <form method="post" action="{{ url('billing:redeem') }}" class="mt-5 space-y-4">
      {{ csrf_input }}
      <div>
        <label for="{{ form.code.id_for_label }}" class="block text-sm font-medium text-slate-200">
          {{ form.code.label }}
        </label>
        {{ form.code }}
        {% if form.code.errors %}
          {% for err in form.code.errors %}
            <p class="mt-1 text-sm text-rose-300">{{ err }}</p>
          {% endfor %}
        {% endif %}
      </div>
      <button type="submit"
        class="inline-flex items-center gap-2 rounded-lg bg-slate-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-600 active:scale-95 transition-transform">
        Activate with Coupon
      </button>
    </form>
  </div>

</section>

<script>
function razorpayCheckout() {
  return {
    loading: false,
    activePlan: '',
    errorMsg: '',
    successMsg: '',
    addonLoading: false,
    addonActivePlan: '',
    addonErrorMsg: '',
    addonSuccessMsg: '',
    csrfToken: document.querySelector('meta[name="csrf-token"]').content,

    async pay(planSlug, planPrice, planName) {
      this.errorMsg = '';
      this.successMsg = '';
      this.loading = true;
      this.activePlan = planSlug;

      try {
        const orderRes = await fetch('{{ url("billing:create_order") }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': this.csrfToken,
          },
          body: JSON.stringify({ plan_slug: planSlug }),
        });

        const orderData = await orderRes.json();
        if (!orderRes.ok) {
          this.errorMsg = orderData.error || 'Failed to initiate payment. Please try again.';
          this.loading = false;
          return;
        }

        const self = this;
        const options = {
          key: '{{ razorpay_key_id }}',
          amount: orderData.amount,
          currency: orderData.currency,
          name: '{{ site_name }}',
          description: planName + ' — 1 Year',
          order_id: orderData.order_id,
          theme: { color: '#10b981' },
          handler: async function(response) {
            try {
              const verifyRes = await fetch('{{ url("billing:verify_payment") }}', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRFToken': self.csrfToken,
                },
                body: JSON.stringify({
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_signature: response.razorpay_signature,
                  plan_slug: planSlug,
                }),
              });
              const verifyData = await verifyRes.json();
              if (verifyRes.ok && verifyData.status === 'success') {
                self.successMsg = '🎉 Payment successful! You are now on ' + verifyData.label + '. Refreshing…';
                setTimeout(function() { window.location.reload(); }, 1800);
              } else {
                self.errorMsg = verifyData.error || 'Payment verified but plan activation failed. Contact support.';
              }
            } catch(e) {
              self.errorMsg = 'Network error during verification. Contact support with your payment ID: ' + response.razorpay_payment_id;
            }
            self.loading = false;
          },
          modal: {
            ondismiss: function() {
              self.loading = false;
              self.activePlan = '';
            },
          },
          prefill: {
            email: '{{ request.user.email }}',
          },
        };

        const rzp = new Razorpay(options);
        rzp.on('payment.failed', function(response) {
          self.errorMsg = 'Payment failed: ' + (response.error.description || 'Please try again.');
          self.loading = false;
          self.activePlan = '';
        });
        rzp.open();

      } catch(e) {
        this.errorMsg = 'Network error. Please check your connection and try again.';
        this.loading = false;
      }
    },

    async payAddon(planSlug, planPrice, planName) {
      this.addonErrorMsg = '';
      this.addonSuccessMsg = '';
      this.addonLoading = true;
      this.addonActivePlan = planSlug;

      try {
        const orderRes = await fetch('{{ url("billing:create_order") }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRFToken': this.csrfToken },
          body: JSON.stringify({ plan_slug: planSlug }),
        });
        const orderData = await orderRes.json();
        if (!orderRes.ok) {
          this.addonErrorMsg = orderData.error || 'Failed to initiate payment. Please try again.';
          this.addonLoading = false;
          return;
        }

        const self = this;
        const options = {
          key: '{{ razorpay_key_id }}',
          amount: orderData.amount,
          currency: orderData.currency,
          name: '{{ site_name }}',
          description: planName + ' Add-on — 1 Year',
          order_id: orderData.order_id,
          theme: { color: '#0284c7' },
          handler: async function(response) {
            try {
              const verifyRes = await fetch('{{ url("billing:verify_addon") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRFToken': self.csrfToken },
                body: JSON.stringify({
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_signature: response.razorpay_signature,
                  plan_slug: planSlug,
                }),
              });
              const verifyData = await verifyRes.json();
              if (verifyRes.ok && verifyData.status === 'success') {
                const what = verifyData.extra_flask > 0
                  ? '+' + verifyData.extra_flask + ' Flask app slot(s)'
                  : '+' + verifyData.extra_sites + ' site(s)';
                self.addonSuccessMsg = '🎉 Add-on activated! ' + what + ' added until ' + verifyData.expires + '. Refreshing…';
                setTimeout(function() { window.location.reload(); }, 2000);
              } else {
                self.addonErrorMsg = verifyData.error || 'Payment verified but add-on activation failed. Contact support.';
              }
            } catch(e) {
              self.addonErrorMsg = 'Network error during verification. Contact support with your payment ID: ' + response.razorpay_payment_id;
            }
            self.addonLoading = false;
          },
          modal: {
            ondismiss: function() {
              self.addonLoading = false;
              self.addonActivePlan = '';
            },
          },
          prefill: { email: '{{ request.user.email }}' },
        };

        const rzp = new Razorpay(options);
        rzp.on('payment.failed', function(response) {
          self.addonErrorMsg = 'Payment failed: ' + (response.error.description || 'Please try again.');
          self.addonLoading = false;
          self.addonActivePlan = '';
        });
        rzp.open();

      } catch(e) {
        this.addonErrorMsg = 'Network error. Please check your connection and try again.';
        this.addonLoading = false;
      }
    },
  };
}
</script>
{% endblock %}
