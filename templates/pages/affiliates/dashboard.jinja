{% extends "base.jinja" %}
{% block title %}Affiliate Dashboard — Krizn{% endblock %}

{% block content %}
<section class="mx-auto max-w-3xl space-y-6 py-4" x-data="{ copied: '' }">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white">Affiliate Dashboard</h1>
      <p class="mt-1 text-sm text-slate-400">Share your links — earn {{ product_commission_pct }}% on products and {{ server_commission_pct }}% on server plans.</p>
    </div>
    <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-2 text-right">
      <p class="text-[10px] font-semibold uppercase tracking-wide text-emerald-300">Total earned</p>
      <p class="text-xl font-bold text-emerald-200">₹{{ affiliate.total_earnings | float | round(2) }}</p>
    </div>
  </div>

  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Your referral code</p>
    <p class="mt-1 font-mono text-lg font-bold text-white">{{ affiliate.code }}</p>
    <p class="mt-2 text-xs text-slate-500">Append <code class="text-sky-300">?ref={{ affiliate.code }}</code> to any resell link. Cookie lasts for the session.</p>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <div class="rounded-xl border border-sky-500/30 bg-sky-500/5 p-4">
      <p class="text-2xl">📦</p>
      <p class="mt-1 font-semibold text-white">Product commission</p>
      <p class="text-2xl font-bold text-emerald-300">{{ product_commission_pct }}%</p>
      <p class="text-xs text-slate-500">On resell product price in each order</p>
    </div>
    <div class="rounded-xl border border-violet-500/30 bg-violet-500/5 p-4">
      <p class="text-2xl">🖥</p>
      <p class="mt-1 font-semibold text-white">Server plan commission</p>
      <p class="text-2xl font-bold text-emerald-300">{{ server_commission_pct }}%</p>
      <p class="text-xs text-slate-500">On server plan add-on in each order</p>
    </div>
  </div>

  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
    <h2 class="text-sm font-semibold text-white">Share links</h2>
    <p class="mt-1 text-xs text-slate-500">Copy and share — buyer must use your link before checkout.</p>

    <div class="mt-4 space-y-3">
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
        <p class="text-xs font-medium text-slate-400">Resell store (all products)</p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <input type="text" readonly value="{{ store_url }}" id="link-store"
                 class="min-w-0 flex-1 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-xs text-slate-300">
          <button type="button"
                  @click="navigator.clipboard.writeText(document.getElementById('link-store').value); copied='store'"
                  class="shrink-0 rounded-lg bg-emerald-500 px-3 py-2 text-xs font-semibold text-slate-950 hover:bg-emerald-400">
            Copy
          </button>
        </div>
        <p x-show="copied === 'store'" x-cloak class="mt-1 text-[11px] text-emerald-400">Copied!</p>
      </div>

      {% for row in product_links %}
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
        <p class="text-xs font-medium text-slate-300">{{ row.product.name }} <span class="text-slate-500">· ₹{{ row.product.price }}</span></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <input type="text" readonly value="{{ row.url }}" id="link-product-{{ row.product.pk }}"
                 class="min-w-0 flex-1 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-xs text-slate-300">
          <button type="button"
                  @click="navigator.clipboard.writeText(document.getElementById('link-product-{{ row.product.pk }}').value); copied='p{{ row.product.pk }}'"
                  class="shrink-0 rounded-lg border border-slate-600 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-slate-800">
            Copy
          </button>
        </div>
        <p x-show="copied === 'p{{ row.product.pk }}'" x-cloak class="mt-1 text-[11px] text-emerald-400">Copied!</p>
      </div>
      {% else %}
      <p class="text-sm text-slate-500">No active resell products yet.</p>
      {% endfor %}
    </div>
  </div>

  {% if commissions %}
  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
    <h2 class="text-sm font-semibold text-white">Recent commissions</h2>
    <div class="mt-3 overflow-x-auto">
      <table class="w-full min-w-[28rem] text-left text-xs">
        <thead class="text-slate-500">
          <tr>
            <th class="pb-2 pr-3 font-medium">Item</th>
            <th class="pb-2 pr-3 font-medium">Type</th>
            <th class="pb-2 pr-3 font-medium">Base</th>
            <th class="pb-2 font-medium">Earned</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-300">
          {% for c in commissions %}
          <tr>
            <td class="py-2 pr-3">{{ c.item_name }}</td>
            <td class="py-2 pr-3 capitalize">{{ c.item_type }}</td>
            <td class="py-2 pr-3">₹{{ c.base_amount }}</td>
            <td class="py-2 font-semibold text-emerald-300">₹{{ c.commission_amount }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}
</section>
{% endblock %}
