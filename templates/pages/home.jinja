{% extends "base.jinja" %}
{% block title %}StudentCloud — AI-Powered Web Hosting for Students{% endblock %}
{% block content %}

{# ══ HERO ══ #}
<section class="relative overflow-hidden rounded-3xl border border-slate-800 bg-gradient-to-br from-slate-950 via-slate-900 to-emerald-950/30 px-6 py-16 text-center sm:px-12 sm:py-20">

  {# Decorative blobs #}
  <div class="pointer-events-none absolute -left-20 -top-20 h-80 w-80 rounded-full bg-emerald-500/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -right-20 bottom-0 h-96 w-96 rounded-full bg-violet-500/10 blur-3xl"></div>
  <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-sky-500/5 blur-2xl"></div>

  {# Badge #}
  <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-xs font-semibold text-emerald-300">
    <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
    AI-Powered · Cloud Hosting · Student Platform
  </span>

  <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
    Deploy Your Website<br>
    <span class="bg-gradient-to-r from-emerald-400 via-sky-400 to-violet-400 bg-clip-text text-transparent">
      in Seconds with AI
    </span>
  </h1>

  <p class="mx-auto mt-5 max-w-xl text-base text-slate-300 sm:text-lg">
    StudentCloud gives you a real cloud server to publish your projects.
    Upload a ZIP — our AI handles the rest. No DevOps. No config. Just launch.
  </p>

  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    {% if request.user is defined and request.user.is_authenticated %}
      <a href="{{ url('projects:dashboard') }}"
         class="inline-flex items-center gap-2 rounded-xl bg-emerald-500 px-6 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-emerald-500/25 hover:bg-emerald-400 transition-colors">
        🚀 Go to Dashboard
      </a>
      <form method="post" action="{{ url('accounts:logout') }}" class="inline">
        {{ csrf_input }}
        <button type="submit"
          class="inline-flex items-center rounded-xl border border-slate-700 bg-slate-900 px-6 py-3 text-sm font-semibold text-slate-300 hover:border-slate-500 hover:text-white transition-colors">
          Log out
        </button>
      </form>
    {% else %}
      <a href="{{ url('accounts:register') }}"
         class="inline-flex items-center gap-2 rounded-xl bg-emerald-500 px-6 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-emerald-500/25 hover:bg-emerald-400 transition-colors">
        🚀 Get Started Free
      </a>
      <a href="{{ url('accounts:login') }}"
         class="inline-flex items-center rounded-xl border border-slate-700 bg-slate-900 px-6 py-3 text-sm font-semibold text-slate-300 hover:border-slate-500 hover:text-white transition-colors">
        Log in
      </a>
    {% endif %}
  </div>

  {# Trust bar #}
  <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-xs text-slate-500">
    <span>✅ Free to start</span>
    <span class="text-slate-700">·</span>
    <span>✅ AI image optimizer</span>
    <span class="text-slate-700">·</span>
    <span>✅ Custom domains</span>
    <span class="text-slate-700">·</span>
    <span>✅ Instant deploy</span>
  </div>
</section>

{# ══ HOW IT WORKS ══ #}
<section class="mt-12 space-y-4">
  <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-500">How it works</p>
  <div class="grid gap-4 sm:grid-cols-3">
    {% for step in [
      ('01', '📦', 'Upload your ZIP', 'Zip your HTML, CSS, JS files and upload through the dashboard — takes under 10 seconds.'),
      ('02', '🤖', 'AI processes it', 'Our AI scans for security, compresses images losslessly, and extracts your site automatically.'),
      ('03', '🌐', 'Go live instantly', 'Your site is live on a subdomain. Add a custom domain (dulhanindia.in, etc.) in one click.'),
    ] %}
      <div class="group relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/50 p-5 transition-all hover:border-slate-600">
        <div class="absolute right-4 top-4 text-4xl font-black text-slate-800/60 select-none group-hover:text-slate-700/60">{{ step[0] }}</div>
        <p class="text-2xl">{{ step[1] }}</p>
        <p class="mt-2 font-semibold text-white">{{ step[2] }}</p>
        <p class="mt-1 text-sm text-slate-400">{{ step[3] }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{# ══ FEATURES ══ #}
<section class="mt-10 space-y-4">
  <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-500">What you get</p>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {% for feat in [
      ('🤖', 'AI Image Optimizer', 'Every image on your site is automatically compressed (lossless) in the background — faster load times, zero effort.', 'emerald'),
      ('🌐', 'Live Subdomain', 'Instantly get a live URL like yourname.crorepatinetwork.com — share with anyone right away.', 'sky'),
      ('🔗', 'Custom Domain', 'Point your own domain (from any registrar) to StudentCloud using a simple A record.', 'violet'),
      ('🔒', 'Security Scan', 'Every upload is scanned for malware before it goes live — keeping the platform safe for everyone.', 'rose'),
      ('📊', 'Server Stats', 'See real-time CPU, RAM and disk usage right on your dashboard — always know the server is healthy.', 'amber'),
      ('🎟', 'Coupon Plans', 'Need more than 1 site? Unlock 3, 5 or 10 sites with a coupon code. Plans start at ₹1,499/year.', 'emerald'),
    ] %}
      {% set border = 'border-' ~ feat[3] ~ '-500/20' %}
      {% set glow = 'bg-' ~ feat[3] ~ '-500/5' %}
      {% set text = 'text-' ~ feat[3] ~ '-300' %}
      <div class="rounded-2xl border {{ border }} {{ glow }} p-5 transition-all hover:scale-[1.01]">
        <p class="text-2xl">{{ feat[0] }}</p>
        <p class="mt-2 font-semibold {{ text }}">{{ feat[1] }}</p>
        <p class="mt-1 text-sm text-slate-400">{{ feat[2] }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{# ══ PRICING ══ #}
<section class="mt-10 space-y-4">
  <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-500">Simple pricing</p>
  <div class="grid gap-4 sm:grid-cols-3">
    {% for plan in [
      ('Free',     '₹0',     'year', 1,  ['1 website', 'Subdomain hosting', 'AI optimizer', 'Security scan'], False),
      ('Pro',      '₹2,099', 'year', 5,  ['5 websites', 'Custom domains', 'AI optimizer', 'Priority support'], True),
      ('Business', '₹3,699', 'year', 10, ['10 websites', 'Custom domains', 'AI optimizer', 'Everything in Pro'], False),
    ] %}
      <div class="relative rounded-2xl border {{ 'border-emerald-500/50 bg-emerald-500/5 ring-1 ring-emerald-500/20' if plan[5] else 'border-slate-800 bg-slate-900/50' }} p-6">
        {% if plan[5] %}
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-bold text-slate-950">Most Popular</span>
        {% endif %}
        <p class="font-semibold text-white">{{ plan[0] }}</p>
        <p class="mt-1 text-3xl font-extrabold text-white">{{ plan[1] }}<span class="text-sm font-normal text-slate-400">/{{ plan[2] }}</span></p>
        <p class="mt-1 text-xs text-slate-500">Up to {{ plan[3] }} website{{ 's' if plan[3] > 1 }}</p>
        <ul class="mt-4 space-y-1.5 text-sm text-slate-300">
          {% for f in plan[4] %}
            <li class="flex items-center gap-2"><span class="text-emerald-400 text-xs">✓</span> {{ f }}</li>
          {% endfor %}
        </ul>
        {% if not loop.first %}
          <p class="mt-4 text-xs text-slate-500">Activate with a coupon code from your trainer.</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{# ══ CTA ══ #}
<section class="mt-10 overflow-hidden rounded-3xl border border-emerald-500/20 bg-gradient-to-br from-emerald-950/50 to-slate-900 px-8 py-12 text-center">
  <div class="pointer-events-none absolute h-40 w-40 rounded-full bg-emerald-500/10 blur-2xl"></div>
  <p class="text-xs font-semibold uppercase tracking-widest text-emerald-400">Ready to launch?</p>
  <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">Your website is one upload away</h2>
  <p class="mx-auto mt-3 max-w-md text-sm text-slate-400">Join students already hosting on StudentCloud. Create your free account and deploy your first site in under 2 minutes.</p>
  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    {% if request.user is defined and request.user.is_authenticated %}
      <a href="{{ url('projects:dashboard') }}"
         class="inline-flex items-center gap-2 rounded-xl bg-emerald-500 px-6 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-emerald-500/25 hover:bg-emerald-400">
        🚀 Go to Dashboard
      </a>
    {% else %}
      <a href="{{ url('accounts:register') }}"
         class="inline-flex items-center gap-2 rounded-xl bg-emerald-500 px-6 py-3 text-sm font-bold text-slate-950 shadow-lg shadow-emerald-500/25 hover:bg-emerald-400">
        🚀 Create Free Account
      </a>
      <a href="{{ url('accounts:login') }}"
         class="inline-flex items-center rounded-xl border border-slate-700 px-6 py-3 text-sm font-semibold text-slate-300 hover:border-slate-500 hover:text-white">
        Log in
      </a>
    {% endif %}
  </div>
</section>

{% endblock %}
