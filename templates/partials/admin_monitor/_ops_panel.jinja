{# Asset compression + platform backups — Mission Control #}
<div class="grid gap-4 lg:grid-cols-2 lg:items-stretch">
  <div class="flex min-w-0 flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-800 bg-slate-950/60 px-4 py-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-200">Asset compression</h2>
        <p class="mt-0.5 text-xs text-slate-500">All static sites with files on disk ({{ asset_sites_eligible }} eligible)</p>
      </div>
      <form method="post" action="{{ url('admin_monitor:run_asset_optimization') }}">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
        <button
          type="submit"
          {% if asset_running %}disabled{% endif %}
          class="rounded-lg border border-emerald-700/50 bg-emerald-600/20 px-3 py-1.5 text-[11px] font-semibold text-emerald-300 hover:bg-emerald-600/30 disabled:cursor-not-allowed disabled:opacity-50"
        >
          {% if asset_running %}Running…{% else %}Run now{% endif %}
        </button>
      </form>
    </div>
    <div class="grid gap-3 p-4 sm:grid-cols-2">
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2">
        <p class="text-[10px] font-semibold uppercase text-slate-500">Last run</p>
        <p class="mt-1 text-sm font-semibold text-white">
          {% if asset_last_finished %}{{ asset_last_finished.strftime('%Y-%m-%d %H:%M') }}{% else %}Never{% endif %}
        </p>
        {% if asset_run and asset_run.status == 'failed' %}
          <p class="mt-1 text-[10px] text-rose-400">Failed — check admin logs</p>
        {% endif %}
      </div>
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2">
        <p class="text-[10px] font-semibold uppercase text-slate-500">Next scheduled</p>
        <p class="mt-1 text-sm font-semibold text-white">
          {% if asset_next_run_in_progress %}In progress…
          {% elif asset_next_run %}{{ asset_next_run.strftime('%Y-%m-%d %H:%M') }}
          {% else %}—{% endif %}
        </p>
        <p class="mt-0.5 text-[10px] text-slate-600">Every {{ asset_interval_hours }}h · cron: <code class="text-slate-400">optimize_site_assets</code></p>
      </div>
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2 sm:col-span-2">
        <p class="text-[10px] font-semibold uppercase text-slate-500">Bytes saved (last run)</p>
        <p class="mt-1 text-lg font-bold text-emerald-300">{{ bytes_saved_human }}</p>
        {% if asset_run %}
          {% set scanned = asset_run.sites_scanned or asset_sites_eligible %}
          <p class="mt-1 text-[10px] text-slate-500">
            Scanned {{ scanned }} site(s) ·
            <strong class="text-slate-300">{{ asset_run.projects_processed }}</strong> had CSS/JS/images ·
            {{ asset_run.css_files }} CSS · {{ asset_run.js_files }} JS · {{ asset_run.image_files }} images ·
            {{ asset_run.files_optimized }} file(s) shrunk
          </p>
          {% if scanned > asset_run.projects_processed %}
            <p class="mt-0.5 text-[10px] text-slate-600">{{ scanned - asset_run.projects_processed }} site(s) are HTML-only (no CSS/JS/images to compress).</p>
          {% endif %}
          <p class="mt-0.5 text-[10px] text-slate-600">Tiny savings on repeat runs usually means files were already optimized.</p>
        {% endif %}
      </div>
      <div class="rounded-lg border border-slate-800 bg-slate-950/50 px-3 py-2 sm:col-span-2">
        <p class="text-[10px] font-semibold uppercase text-slate-500">Redis cache memory</p>
        {% if cache_stats.available %}
          <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-300">
            <span>Used: <strong class="text-white">{{ cache_stats.used_memory_human }}</strong></span>
            <span>Peak: <strong class="text-white">{{ cache_stats.used_memory_peak_human }}</strong></span>
            <span>Max: <strong class="text-white">{{ cache_stats.maxmemory_human }}</strong></span>
            <span>Keys: <strong class="text-white">{{ cache_stats.key_count }}</strong></span>
            {% if cache_stats.hit_rate_pct is not none %}
              <span>Hit rate: <strong class="text-emerald-300">{{ cache_stats.hit_rate_pct }}%</strong></span>
            {% endif %}
          </div>
        {% else %}
          <p class="mt-1 text-xs text-slate-500">Redis unavailable</p>
          {% if cache_stats.error %}
            <p class="mt-0.5 text-[10px] text-rose-400/90" title="{{ cache_stats.error }}">{{ cache_stats.error }}</p>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <div class="min-w-0 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
    <div class="border-b border-slate-800 bg-slate-950/60 px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-200">Platform backups</h2>
      <p class="mt-0.5 text-xs text-slate-500">Manual ZIP: database dump + student site files</p>
    </div>
    <div class="flex flex-wrap gap-2 border-b border-slate-800 px-4 py-2.5">
      {% for btype, label in backup_type_choices %}
        <form method="post" action="{{ url('admin_monitor:create_platform_backup') }}">
          <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
          <input type="hidden" name="backup_type" value="{{ btype }}">
          <button
            type="submit"
            class="rounded-lg border border-sky-700/50 bg-sky-600/15 px-2.5 py-1 text-[10px] font-semibold text-sky-300 hover:bg-sky-600/25"
          >{{ label }}</button>
        </form>
      {% endfor %}
    </div>
    <div class="max-h-64 overflow-auto">
      <table class="w-full table-fixed text-left text-[10px]">
        <colgroup>
          <col class="w-[4.25rem]">
          <col class="w-[2.5rem]">
          <col class="w-[3rem]">
          <col class="w-[2.5rem]">
          <col class="w-[3rem]">
        </colgroup>
        <thead class="sticky top-0 bg-slate-950/95 text-slate-500">
          <tr>
            <th class="px-2 py-1.5 font-semibold uppercase">When</th>
            <th class="px-1 py-1.5 font-semibold uppercase">Type</th>
            <th class="px-1 py-1.5 font-semibold uppercase">Size</th>
            <th class="px-1 py-1.5 font-semibold uppercase">Status</th>
            <th class="px-1 py-1.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-300">
          {% for b in platform_backups %}
            <tr class="hover:bg-slate-900/80">
              <td class="px-2 py-2 align-top">
                <p class="font-mono leading-tight text-slate-200">{{ b.created_at.strftime('%Y-%m-%d') }}</p>
                <p class="font-mono leading-tight text-slate-500">{{ b.created_at.strftime('%H:%M') }}</p>
              </td>
              <td class="px-1 py-2 align-top text-slate-300">
                {% if b.backup_type == 'full' %}Full
                {% elif b.backup_type == 'database' %}DB
                {% else %}Sites{% endif %}
              </td>
              <td class="whitespace-nowrap px-1 py-2 align-top text-slate-200">{{ b.size_human }}</td>
              <td class="px-1 py-2 align-top">
                <span
                  class="inline-block rounded-full px-1.5 py-px text-[9px]
                  {{ 'bg-emerald-900/50 text-emerald-300' if b.status == 'done' else ('bg-amber-900/50 text-amber-300' if b.status in ('pending','running') else 'bg-rose-900/50 text-rose-300') }}"
                  {% if b.status == 'done' and not b.file_on_disk %}title="File missing on server"{% elif b.status == 'failed' and b.error_message %}title="{{ b.error_message }}"{% endif %}
                >{{ b.get_status_display() }}</span>
              </td>
              <td class="px-1 py-2 align-top">
                <div class="inline-flex items-center gap-1">
                  {% if b.status == 'done' and b.file_on_disk %}
                    <a
                      href="{{ url('admin_monitor:download_platform_backup', backup_id=b.pk) }}"
                      title="Download ZIP"
                      class="inline-flex h-5 w-5 items-center justify-center rounded border border-emerald-700/50 bg-emerald-950/40 text-[9px] font-semibold leading-none text-emerald-300 hover:bg-emerald-900/40"
                    >↓</a>
                  {% endif %}
                  {% if b.status not in ('pending', 'running') %}
                    <form
                      method="post"
                      action="{{ url('admin_monitor:delete_platform_backup', backup_id=b.pk) }}"
                      class="inline"
                      onsubmit="return confirm('Delete backup #{{ b.pk }}?');"
                    >
                      <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                      <button
                        type="submit"
                        title="Delete backup"
                        class="inline-flex h-5 w-5 items-center justify-center rounded border border-rose-800/60 bg-rose-950/40 text-[9px] font-semibold leading-none text-rose-300 hover:bg-rose-900/40"
                      >×</button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="5" class="py-8 text-center text-slate-500">No backups yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
