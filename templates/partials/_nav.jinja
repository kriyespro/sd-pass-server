<header class="border-b border-slate-800 pb-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">

    {# ── Left: logo + welcome ── #}
    <div class="flex flex-wrap items-center gap-3">

      {# Brand logo #}
      <a href="{{ url('home') }}" class="group flex items-center gap-2" aria-label="Krizn home">
        {# Cloud + lightning icon #}
        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-500 to-cyan-500 shadow-lg shadow-emerald-500/30 ring-1 ring-white/10 transition-transform group-hover:scale-105">
          <svg class="h-4 w-4 text-slate-950" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
          </svg>
        </span>
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-xl font-bold tracking-tight text-transparent">
          Krizn
        </span>
      </a>

      {# Welcome greeting — authenticated users only #}
      {% if request.user is defined and request.user.is_authenticated %}
        {% set _fname = request.user.first_name or request.user.username %}
        <span class="hidden items-center gap-1.5 rounded-full border border-slate-700/60 bg-slate-800/50 px-3 py-1 text-xs font-medium sm:inline-flex">
          <svg class="h-3 w-3 text-emerald-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-7 9a7 7 0 1 1 14 0H3z"/>
          </svg>
          <span class="text-slate-400">Welcome,</span>
          <span class="font-semibold text-emerald-300">{{ _fname }}</span>
          <span class="text-slate-500">·</span>
          <span class="text-slate-400">Have a nice day</span>
          <span class="text-amber-400">☀</span>
        </span>
      {% endif %}
    </div>

    {# ── Right: navigation links ── #}
    <nav class="flex flex-wrap items-center gap-3 text-sm font-medium text-slate-300">
      <a href="{{ url('home') }}" class="hover:text-white">Home</a>
      <a href="{{ url('resell:store') }}" class="hover:text-amber-300">🛒 Resell</a>
      {% if request.user is defined and request.user.is_authenticated %}
        <a href="{{ url('affiliates:partner') }}" class="hover:text-violet-300">Partner</a>
        <a href="{{ url('projects:dashboard') }}" class="hover:text-white">Server</a>
        <a href="{{ url('billing:redeem') }}" class="hover:text-emerald-300">Upgrade</a>
        <a href="{{ url('notifications:list') }}" class="relative inline-flex items-center gap-1 hover:text-white">
          <span>Alerts</span>
          {% if notification_unread_count > 0 %}
            <span class="rounded-full bg-emerald-500 px-1.5 py-0.5 text-xs font-bold text-slate-950">{{ notification_unread_count }}</span>
          {% endif %}
        </a>
        {% if request.user.is_staff %}
          <a href="{{ url('admin_monitor:dashboard') }}" class="rounded-md bg-violet-500/15 px-2 py-1 font-semibold text-violet-300 ring-1 ring-violet-500/40 hover:bg-violet-500/25">Admin</a>
        {% endif %}
        {% if trainer_portal_visible %}
          <a href="{{ url('trainer:overview') }}" class="hover:text-sky-300">Trainer</a>
        {% endif %}
        <form method="post" action="{{ url('accounts:logout') }}" class="inline">
          {{ csrf_input }}
          <button type="submit" class="hover:text-white">Log out</button>
        </form>
      {% else %}
        <a href="{{ url('accounts:login') }}" class="hover:text-white">Log in</a>
        <a href="{{ url('accounts:register') }}" class="rounded-lg bg-emerald-500/10 px-3 py-1 text-emerald-300 ring-1 ring-emerald-500/40 hover:bg-emerald-500/20">Sign up</a>
      {% endif %}
    </nav>

  </div>
</header>
