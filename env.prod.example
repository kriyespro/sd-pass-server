# Copy to .env.prod and fill in. Used by docker-compose.prod.yml
#
# Compose variable substitution: either pass `docker compose --env-file .env.prod ...`
# every time, OR on the server run:  ln -sf .env.prod .env
# (Compose auto-reads `.env` in this folder for ${VAR} in the YAML — fixes `down` without flags).

# Host port published for Traefik HTTP (container still listens on 80 inside). Default 9080 avoids clashing with nginx on :80.
TRAEFIK_HTTP_PUBLISH=9080

SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgres://studentcloud:YOUR_DB_PASSWORD@db:5432/studentcloud

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Main app + platform wildcard. Per-student domains saved in the app are trusted automatically (no env edit).
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,.yourdomain.com,apps.yourdomain.com,.apps.yourdomain.com
# Optional extras; each saved custom domain also gets https://host and http://host for CSRF at runtime.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

STUDENT_APPS_BASE_DOMAIN=apps.yourdomain.com
TRAEFIK_UPSTREAM_URL=http://web:8000
TRAEFIK_DYNAMIC_DIR=/app/data/traefik/dynamic
TRAEFIK_ENTRYPOINTS=web
TRAEFIK_TLS_ON_PROJECT_ROUTES=false
STUDENT_PUBLIC_HTTP_PORT=0

# Optional: for Cloudflare API automation (dashboard DNS sync task)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
PLATFORM_PUBLIC_IP=203.0.113.10

FERNET_KEY=
