{# Shared login / sign-up panel #}
{% set _is_register = is_register|default(false) %}
{# Resolve the active form (context var differs between AuthGatewayView and LoginView/RegisterView) #}
{% set _login_form = login_form if login_form is defined else (form if (form is defined and not _is_register) else none) %}
{% set _reg_form   = register_form if register_form is defined else (form if (form is defined and _is_register) else none) %}
<div class="mx-auto max-w-md">
  <div class="rounded-3xl border border-slate-800 bg-gradient-to-b from-slate-900/90 to-slate-950/90 p-8 shadow-2xl shadow-emerald-950/10">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-emerald-400">{{ site_name }}</p>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        {{ 'Create your account' if _is_register else 'Welcome back' }}
      </h1>
      <p class="mt-2 text-sm text-slate-400">
        {{ 'Sign up to deploy your first site in minutes.' if _is_register else 'Sign in to open your dashboard.' }}
      </p>
    </div>

    {% if show_manual_auth|default(false) %}
      {# ── Manual email / password form (primary when SHOW_MANUAL_AUTH=True) ── #}
      <div class="mt-8">
        {% if _is_register %}
          <form method="post" action="{{ url('accounts:manual_register') }}" class="space-y-3">
            {{ csrf_input }}
            {% if _reg_form and _reg_form.non_field_errors() %}
              <div class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-3 py-2 text-sm text-rose-100">
                {% for err in _reg_form.non_field_errors() %}{{ err }}{% endfor %}
              </div>
            {% endif %}
            {% if _reg_form %}
              {% for field in _reg_form %}
                <div>
                  <label for="{{ field.id_for_label }}" class="block text-xs font-medium text-slate-300">{{ field.label }}</label>
                  {{ field }}
                  {% if field.errors %}{% for err in field.errors %}<p class="mt-1 text-xs text-rose-300">{{ err }}</p>{% endfor %}{% endif %}
                </div>
              {% endfor %}
            {% else %}
              <p class="text-xs text-rose-300">Registration form unavailable.</p>
            {% endif %}
            <button type="submit" class="w-full rounded-lg bg-emerald-600 py-2 text-sm font-semibold text-white hover:bg-emerald-500">Create account</button>
          </form>
        {% else %}
          <form method="post" action="{{ url('accounts:manual_login') }}" class="space-y-4">
            {{ csrf_input }}
            {# Non-field errors (invalid credentials, account locked, etc.) #}
            {% if _login_form and _login_form.non_field_errors() %}
              <div class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-3 py-2 text-sm text-rose-100">
                {% for err in _login_form.non_field_errors() %}{{ err }}{% endfor %}
              </div>
            {% endif %}
            <div>
              <label for="id_username" class="block text-xs font-medium text-slate-300">Email</label>
              <input id="id_username" name="username" type="email" autocomplete="email" required
                class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2"
                value="{{ _login_form.username.value() if _login_form and _login_form.username.value() else '' }}">
              {% if _login_form and _login_form.username.errors %}
                {% for err in _login_form.username.errors %}<p class="mt-1 text-xs text-rose-300">{{ err }}</p>{% endfor %}
              {% endif %}
            </div>
            <div>
              <label for="id_password" class="block text-xs font-medium text-slate-300">Password</label>
              <input id="id_password" name="password" type="password" autocomplete="current-password" required
                class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2">
              {% if _login_form and _login_form.password.errors %}
                {% for err in _login_form.password.errors %}<p class="mt-1 text-xs text-rose-300">{{ err }}</p>{% endfor %}
              {% endif %}
            </div>
            <button type="submit" class="w-full rounded-lg bg-emerald-600 py-2 text-sm font-semibold text-white hover:bg-emerald-500">Log in</button>
            <p class="text-center text-xs text-slate-500">
              After {{ axes_failure_limit|default(5) }} failed attempts, login locks for {{ axes_cooloff_minutes|default(30) }} min.
            </p>
          </form>
        {% endif %}
      </div>

      {% if google_login_url %}
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-700"></div></div>
          <div class="relative flex justify-center text-xs text-slate-500"><span class="bg-slate-900 px-2">or continue with</span></div>
        </div>
        {% with button_label = ('Sign up with Google' if _is_register else 'Sign in with Google') %}
          {% include "components/_google_sign_in_button.jinja" %}
        {% endwith %}
        {% if not google_oauth_configured %}
          <p class="mt-3 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-center text-xs text-amber-200">
            Admin: add <code class="text-amber-100">GOOGLE_OAUTH_CLIENT_ID</code> and
            <code class="text-amber-100">GOOGLE_OAUTH_CLIENT_SECRET</code> to <code class="text-amber-100">.env.prod</code>, then restart.
          </p>
        {% endif %}
      {% endif %}

    {% else %}
      {# ── Google-only mode ── #}
      <div class="mt-8">
        {% if google_login_url %}
          {% with button_label = ('Sign up with Google' if _is_register else 'Sign in with Google') %}
            {% include "components/_google_sign_in_button.jinja" %}
          {% endwith %}
          {% if not google_oauth_configured %}
            <p class="mt-3 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-center text-xs text-amber-200">
              Admin: add <code class="text-amber-100">GOOGLE_OAUTH_CLIENT_ID</code> and
              <code class="text-amber-100">GOOGLE_OAUTH_CLIENT_SECRET</code> to <code class="text-amber-100">.env.prod</code>, then restart the web container.
            </p>
          {% else %}
            <p class="mt-4 text-center text-xs text-slate-500">
              We use your Google email and name only to create your account. No password to remember.
            </p>
          {% endif %}
        {% else %}
          <div class="rounded-xl border border-rose-500/40 bg-rose-500/10 px-4 py-3 text-sm text-rose-100">
            <p class="font-semibold text-rose-50">Google sign-in URL missing</p>
            <p class="mt-1 text-rose-100/90">Rebuild the web image so <code class="text-xs">django-allauth</code> is installed, then run <code class="text-xs">migrate</code>.</p>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <p class="mt-6 text-center text-sm text-slate-400">
      {% if _is_register %}
        Already have an account?
        <a href="{{ url('accounts:login') }}" class="font-semibold text-emerald-400 hover:text-emerald-300">Log in</a>
      {% else %}
        New here?
        <a href="{{ url('accounts:register') }}" class="font-semibold text-emerald-400 hover:text-emerald-300">Create an account</a>
      {% endif %}
    </p>
  </div>
</div>
