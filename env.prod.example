# Copy to .env.prod and fill in. Used by docker-compose.prod.yml
#
# Compose variable substitution: either pass `docker compose --env-file .env.prod ...`
# every time, OR on the server run:  ln -sf .env.prod .env
# (Compose auto-reads `.env` in this folder for ${VAR} in the YAML — fixes `down` without flags).

# Gunicorn on host: WEB_HTTP_BIND:WEB_HTTP_PUBLISH -> container :8000.
# With nginx on the host: use WEB_HTTP_BIND=127.0.0.1 so Gunicorn is not on the public interface.
WEB_HTTP_BIND=0.0.0.0
WEB_HTTP_PUBLISH=9898

# If nginx sends Host 127.0.0.1:port but X-Forwarded-Host is the public name (requires WEB_HTTP_BIND=127.0.0.1).
RECOVER_PROXY_HOST_FROM_FORWARDED=false

# Host port published for Traefik HTTP (container still listens on 80 inside). Default 9080 avoids clashing with nginx on :80.
TRAEFIK_HTTP_PUBLISH=9080

SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgres://studentcloud:YOUR_DB_PASSWORD@db:5432/studentcloud

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Main app + platform wildcard. Per-student domains saved in the app are trusted automatically (no env edit).
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,.yourdomain.com,apps.yourdomain.com,.apps.yourdomain.com
# Optional extras; each saved custom domain also gets https://host and http://host for CSRF at runtime.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://apps.yourdomain.com

STUDENT_APPS_BASE_DOMAIN=apps.yourdomain.com
# If TLS terminates at nginx and Traefik→Gunicorn is HTTP, set true with STUDENT_SITE_PUBLIC_SCHEME=https (student hosts only).
# STUDENT_TRUST_TRAEFIK_HTTPS=false
TRAEFIK_UPSTREAM_URL=http://web:8000
TRAEFIK_DYNAMIC_DIR=/app/data/traefik/dynamic
TRAEFIK_ENTRYPOINTS=web
TRAEFIK_TLS_ON_PROJECT_ROUTES=false
STUDENT_PUBLIC_HTTP_PORT=0
# Port appended to http://{subdomain}.{STUDENT_APPS_BASE_DOMAIN}/ links (Traefik on host). Use 0 to omit (default :80).
STUDENT_SITE_HTTP_PORT=0
# http or https — links to student sites from the dashboard and notifications.
STUDENT_SITE_PUBLIC_SCHEME=https

# Optional: for Cloudflare API automation (dashboard DNS sync task)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
PLATFORM_PUBLIC_IP=203.0.113.10

FERNET_KEY=

# Google sign-in (OAuth 2.0 — create at https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must include:
#   https://YOUR_DOMAIN/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match your public dashboard host (no scheme), e.g. yourdomain.com
SITE_DOMAIN=yourdomain.com
SITE_NAME=StudentCloud Deploy
# Set true only for emergency email/password login (hidden behind a collapsible panel)
SHOW_MANUAL_AUTH=false

# TLS (core.settings.prod). For plain http:// to Gunicorn use SECURE_* and SECURE_PROXY_SSL=False.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_PROXY_SSL=True
USE_X_FORWARDED_HOST=False