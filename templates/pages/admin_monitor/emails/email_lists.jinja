{% extends "base.jinja" %}
{% block title %}Email Lists — Krizn{% endblock %}
{% block content %}
<section class="space-y-4">

  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-lg font-bold text-white">Email Lists</h1>
      <p class="text-[11px] text-slate-500">Named recipient lists for bulk sends</p>
    </div>
    <div class="flex flex-wrap gap-1.5">
      <a href="{{ url('admin_emails:email_list_create') }}"
         class="rounded border border-emerald-700/40 bg-emerald-600/10 px-2.5 py-1 text-[11px] font-semibold text-emerald-300 hover:bg-emerald-600/20">
        + New List
      </a>
      <a href="{{ url('admin_emails:list') }}"
         class="rounded border border-slate-700 bg-slate-900 px-2.5 py-1 text-[11px] font-medium text-slate-400 hover:bg-slate-800">
        ← Templates
      </a>
    </div>
  </div>

  {% if messages %}
    <div class="space-y-1">
      {% for message in messages %}
        <p class="rounded-lg border px-3 py-2 text-xs
          {{ 'border-emerald-800/50 bg-emerald-950/40 text-emerald-300' if message.tags == 'success' else 'border-rose-800/50 bg-rose-950/40 text-rose-300' }}">
          {{ message }}
        </p>
      {% endfor %}
    </div>
  {% endif %}

  {# ── Auto-Create Segments ── #}
  <div class="rounded-xl border border-violet-800/30 bg-violet-950/20 p-3">
    <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-violet-400">Auto-Create Lists from User Segments</p>
    <p class="mb-3 text-[10px] text-slate-500">One click creates or fully refreshes a named list from your live user data.</p>
    <div class="flex flex-wrap gap-1.5">
      {% for slug, label, description in segments %}
        <form method="post" action="{{ url('admin_emails:email_list_auto_create', segment=slug) }}" class="inline">
          {{ csrf_input }}
          <button type="submit"
                  title="{{ description }}"
                  class="rounded border border-violet-700/40 bg-violet-600/10 px-2.5 py-1 text-[11px] font-semibold text-violet-300 hover:bg-violet-600/25 transition-colors">
            {{ label }}
          </button>
        </form>
      {% endfor %}
    </div>
  </div>

  {# ── Existing Lists ── #}
  {% if lists %}
    <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/40">
      <table class="min-w-full text-left text-xs">
        <thead class="bg-slate-950/80 text-slate-500">
          <tr>
            <th class="px-4 py-2.5 font-semibold uppercase tracking-wide">Name</th>
            <th class="px-4 py-2.5 font-semibold uppercase tracking-wide">Description</th>
            <th class="px-4 py-2.5 font-semibold uppercase tracking-wide text-center">Recipients</th>
            <th class="px-4 py-2.5 font-semibold uppercase tracking-wide">Updated</th>
            <th class="px-4 py-2.5 font-semibold uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 text-slate-300">
          {% for lst in lists %}
            <tr class="hover:bg-slate-900/60">
              <td class="px-4 py-3 font-semibold text-white">{{ lst.name }}</td>
              <td class="px-4 py-3 text-slate-400">{{ lst.description or '—' }}</td>
              <td class="px-4 py-3 text-center">
                <span class="rounded-full bg-sky-800/40 px-2 py-0.5 text-[10px] font-bold text-sky-300">{{ lst.count }}</span>
              </td>
              <td class="px-4 py-3 font-mono text-slate-500">{{ lst.updated_at.strftime('%m-%d %H:%M') }}</td>
              <td class="px-4 py-3">
                <div class="flex gap-1">
                  <a href="{{ url('admin_emails:email_list_edit', pk=lst.pk) }}"
                     class="rounded border border-sky-700/40 bg-sky-600/10 px-2 py-0.5 text-[10px] font-semibold text-sky-300 hover:bg-sky-600/20">
                    Edit
                  </a>
                  <form method="post" action="{{ url('admin_emails:email_list_delete', pk=lst.pk) }}"
                        onsubmit="return confirm('Delete list &quot;{{ lst.name }}&quot;?')" class="inline">
                    {{ csrf_input }}
                    <button type="submit"
                            class="rounded border border-rose-700/40 bg-rose-600/10 px-2 py-0.5 text-[10px] font-semibold text-rose-300 hover:bg-rose-600/20">
                      Del
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <div class="rounded-xl border border-dashed border-slate-700 bg-slate-900/20 px-6 py-10 text-center">
      <p class="text-slate-500">No lists yet. Use the segment buttons above to auto-create, or create manually.</p>
    </div>
  {% endif %}

</section>
{% endblock %}
