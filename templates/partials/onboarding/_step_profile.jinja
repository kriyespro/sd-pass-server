<form method="post"
      action="{{ url('onboarding:step', step=1) }}"
      class="space-y-4"
      data-onboarding-form
      onsubmit="var b=this.querySelector('[type=submit]');if(b){b.disabled=true;b.textContent='Saving…';}">
  {{ csrf_input }}
  <p class="text-sm text-slate-300">
    Welcome! Confirm your name and tell us your <strong class="text-slate-200">city</strong> and
    <strong class="text-slate-200">mobile number</strong> so we can reach you about your site.
  </p>

  {% set form = onboarding_form %}
  {% if form %}
    {% if form.non_field_errors() %}
      <div class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-3 py-2 text-sm text-rose-100">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
      </div>
    {% endif %}
    {% for field in [form.first_name, form.last_name, form.city, form.mobile] %}
      <div>
        <label for="{{ field.id_for_label }}" class="block text-sm font-medium text-slate-200">{{ field.label }}</label>
        {{ field }}
        {% if field.help_text %}
          <p class="mt-1 text-xs text-slate-500">{{ field.help_text }}</p>
        {% endif %}
        {% if field.errors %}
          {% for err in field.errors %}<p class="mt-1 text-sm text-rose-300">{{ err }}</p>{% endfor %}
        {% endif %}
      </div>
    {% endfor %}
  {% else %}
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-slate-200" for="id_first_name">First name</label>
        <input type="text" name="first_name" id="id_first_name" required
               value="{{ request.user.first_name }}"
               class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-200" for="id_last_name">Last name</label>
        <input type="text" name="last_name" id="id_last_name" required
               value="{{ request.user.last_name }}"
               class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-200" for="id_city">City</label>
      <input type="text" name="city" id="id_city" required maxlength="120"
             value="{{ request.user.city }}"
             placeholder="e.g. Jaipur"
             class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-200" for="id_mobile">Mobile number</label>
      <input type="tel" name="mobile" id="id_mobile" required maxlength="32"
             value="{{ request.user.mobile }}"
             placeholder="e.g. +91 98765 43210"
             autocomplete="tel"
             class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100 outline-none ring-emerald-500/40 focus:border-emerald-500 focus:ring-2">
    </div>
  {% endif %}

  <button type="submit"
          class="w-full rounded-lg bg-emerald-500 py-2.5 text-sm font-semibold text-slate-950 hover:bg-emerald-400 disabled:cursor-not-allowed disabled:opacity-60">
    Continue
  </button>
</form>
