{% extends "base.jinja" %}
{% block title %}Notifications — StudentCloud Deploy{% endblock %}
{% block content %}
<section class="mx-auto max-w-2xl space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-white">Notifications</h1>
      <p class="text-sm text-slate-400">Deploy and security updates for your account.</p>
    </div>
    {% if page_obj.paginator.count > 0 %}
      <form method="post" action="{{ url('notifications:mark_all_read') }}" class="inline">
        {{ csrf_input }}
        <button type="submit" class="rounded-lg border border-slate-600 px-3 py-1.5 text-sm text-slate-200 hover:border-emerald-500/50 hover:text-emerald-300">Mark all read</button>
      </form>
    {% endif %}
  </div>

  <div class="divide-y divide-slate-800 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/50">
    {% if notifications %}
      {% for n in notifications %}
        <article class="flex flex-col gap-3 px-4 py-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="font-medium text-white">{{ n.title }}</h2>
              {% if n.read_at %}
                <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-400">Read</span>
              {% endif %}
              <span class="text-xs text-slate-500">{{ n.created_at.strftime("%Y-%m-%d %H:%M") }}</span>
            </div>
            {% if n.body %}
              <p class="mt-1 text-sm text-slate-400">{{ n.body }}</p>
            {% endif %}
            {% if n.link_url %}
              <a href="{{ n.link_url }}" class="mt-2 inline-block text-sm font-medium text-emerald-400 hover:text-emerald-300">Open →</a>
            {% endif %}
          </div>
          {% if not n.read_at %}
            <form method="post" action="{{ url('notifications:mark_read', pk=n.pk) }}" class="shrink-0">
              {{ csrf_input }}
              <button type="submit" class="rounded-lg bg-slate-800 px-3 py-1.5 text-xs font-semibold text-emerald-200 ring-1 ring-slate-600 hover:bg-slate-700">Mark read</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    {% else %}
      <p class="px-4 py-10 text-center text-sm text-slate-500">No notifications yet.</p>
    {% endif %}
  </div>

  {% if page_obj.has_other_pages() %}
    <div class="flex justify-center gap-4 text-sm">
      {% if page_obj.has_previous() %}
        <a href="{{ url('notifications:list') }}?page={{ page_obj.previous_page_number() }}" class="text-emerald-400 hover:text-emerald-300">Newer</a>
      {% endif %}
      {% if page_obj.has_next() %}
        <a href="{{ url('notifications:list') }}?page={{ page_obj.next_page_number() }}" class="text-emerald-400 hover:text-emerald-300">Older</a>
      {% endif %}
    </div>
  {% endif %}
</section>
{% endblock %}
