{% extends "base.jinja" %}
{% block title %}Affiliate Dashboard — Krizn{% endblock %}

{% block content %}
<section class="mx-auto max-w-3xl space-y-6 py-4" x-data="{ copied: '' }">

  {# ── Header ── #}
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-white">Affiliate Dashboard</h1>
      <p class="mt-1 text-sm text-slate-400">Earn by sharing — your commissions update in real time.</p>
    </div>
  </div>

  {# ── Stats row ── #}
  <div class="grid gap-3 sm:grid-cols-3">
    <div class="rounded-2xl border border-emerald-500/25 bg-gradient-to-br from-emerald-950/60 to-slate-900/80 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest text-emerald-400/70">Total earned</p>
      <p class="mt-2 text-3xl font-bold text-emerald-300">₹{{ affiliate.total_earnings | float | round(2) }}</p>
      <p class="mt-1 text-xs text-slate-500">Lifetime commissions</p>
    </div>
    <div class="rounded-2xl border border-sky-500/20 bg-slate-900/60 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest text-sky-400/70">Products</p>
      <p class="mt-2 text-3xl font-bold text-white">{{ product_commission_pct }}%</p>
      <p class="mt-1 text-xs text-slate-500">Per resell product</p>
    </div>
    <div class="rounded-2xl border border-violet-500/20 bg-slate-900/60 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest text-violet-400/70">Server plans</p>
      <p class="mt-2 text-3xl font-bold text-white">{{ server_commission_pct }}%</p>
      <p class="mt-1 text-xs text-slate-500">Per server add-on</p>
    </div>
  </div>

  {# ── Referral code ── #}
  <div class="rounded-2xl border border-slate-700/60 bg-slate-900/60 p-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Your referral code</p>
        <p class="mt-1.5 font-mono text-2xl font-bold tracking-wider text-white">{{ affiliate.code }}</p>
        <p class="mt-1 text-xs text-slate-500">Append <code class="rounded bg-slate-800 px-1 py-0.5 text-sky-300">?ref={{ affiliate.code }}</code> to any Krizn link.</p>
      </div>
      <button type="button"
              @click="navigator.clipboard.writeText('{{ affiliate.code }}'); copied='code'"
              class="flex items-center gap-2 rounded-xl border border-slate-600 bg-slate-800 px-4 py-2.5 text-sm font-semibold text-slate-200 transition hover:border-emerald-500/50 hover:bg-slate-700">
        <span x-show="copied !== 'code'">Copy code</span>
        <span x-show="copied === 'code'" x-cloak class="text-emerald-400">✓ Copied</span>
      </button>
    </div>
  </div>

  {# ── Share links ── #}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="font-semibold text-white">Share links</h2>
        <p class="mt-0.5 text-xs text-slate-500">Buyer must click your link before checkout for commission to apply.</p>
      </div>
    </div>

    <div class="space-y-2.5">
      {# Store link #}
      <div class="group rounded-xl border border-slate-700/60 bg-slate-950/50 p-3 transition hover:border-slate-600">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-emerald-400">🏪 Resell store — all products</p>
            <p class="mt-1 truncate font-mono text-[11px] text-slate-500">{{ store_url }}</p>
          </div>
          <button type="button"
                  @click="navigator.clipboard.writeText('{{ store_url }}'); copied='store'"
                  class="shrink-0 rounded-lg bg-emerald-500 px-3 py-1.5 text-xs font-bold text-slate-950 transition hover:bg-emerald-400 active:scale-95">
            <span x-show="copied !== 'store'">Copy</span>
            <span x-show="copied === 'store'" x-cloak>✓</span>
          </button>
        </div>
      </div>

      {% for row in product_links %}
      <div class="group rounded-xl border border-slate-800 bg-slate-950/50 p-3 transition hover:border-slate-700">
        <div class="flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-slate-300">
              {{ row.product.name }}
              <span class="ml-1 rounded bg-slate-800 px-1.5 py-0.5 text-[11px] font-semibold text-emerald-400">₹{{ row.product.price }}</span>
            </p>
            <p class="mt-1 truncate font-mono text-[11px] text-slate-600">{{ row.url }}</p>
          </div>
          <button type="button"
                  @click="navigator.clipboard.writeText({{ row.url | tojson }}); copied='p{{ row.product.pk }}'"
                  class="shrink-0 rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:border-emerald-500/50 hover:bg-slate-800 active:scale-95">
            <span x-show="copied !== 'p{{ row.product.pk }}'">Copy</span>
            <span x-show="copied === 'p{{ row.product.pk }}'" x-cloak class="text-emerald-400">✓</span>
          </button>
        </div>
      </div>
      {% else %}
      <div class="rounded-xl border border-dashed border-slate-700 p-6 text-center">
        <p class="text-sm text-slate-500">No active resell products yet.</p>
      </div>
      {% endfor %}
    </div>
  </div>

  {# ── Recent commissions ── #}
  {% if commissions %}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
    <h2 class="mb-4 font-semibold text-white">Recent commissions</h2>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[28rem] text-left text-xs">
        <thead>
          <tr class="border-b border-slate-800 text-[11px] font-semibold uppercase tracking-wider text-slate-500">
            <th class="pb-2.5 pr-4">Item</th>
            <th class="pb-2.5 pr-4">Type</th>
            <th class="pb-2.5 pr-4">Base</th>
            <th class="pb-2.5 text-right">Earned</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/60">
          {% for c in commissions %}
          <tr class="group transition hover:bg-slate-800/30">
            <td class="py-2.5 pr-4 text-slate-300">{{ c.item_name }}</td>
            <td class="py-2.5 pr-4">
              {% if c.item_type == 'product' %}
              <span class="rounded-full bg-sky-500/15 px-2 py-0.5 text-[11px] font-medium text-sky-300">Product</span>
              {% else %}
              <span class="rounded-full bg-violet-500/15 px-2 py-0.5 text-[11px] font-medium text-violet-300">Server</span>
              {% endif %}
            </td>
            <td class="py-2.5 pr-4 text-slate-400">₹{{ c.base_amount }}</td>
            <td class="py-2.5 text-right font-semibold text-emerald-300">+₹{{ c.commission_amount }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% else %}
  <div class="rounded-2xl border border-dashed border-slate-700/60 p-8 text-center">
    <p class="text-2xl">💸</p>
    <p class="mt-2 text-sm font-medium text-slate-400">No commissions yet</p>
    <p class="mt-1 text-xs text-slate-600">Share your links above — commissions appear here when orders come in.</p>
  </div>
  {% endif %}

</section>
{% endblock %}
