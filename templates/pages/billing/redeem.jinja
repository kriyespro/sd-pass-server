{% extends "base.jinja" %}
{% block title %}Upgrade Plan — StudentCloud Deploy{% endblock %}
{% block content %}
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<section class="mx-auto max-w-3xl space-y-8" x-data="razorpayCheckout()">

  {# ── Page header ── #}
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-white">Upgrade Your Plan</h1>
      <p class="mt-1 text-sm text-slate-400">Choose a plan below and pay securely with Razorpay.</p>
    </div>
    <a href="{{ url('projects:dashboard') }}" class="text-sm font-medium text-slate-400 hover:text-white">← Back</a>
  </div>

  {# ── Current plan badge ── #}
  {% set plan = subscription.plan_slug %}
  <div class="flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/60 px-5 py-4">
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Current Plan</p>
      <p class="mt-0.5 text-lg font-semibold text-white">{{ plan_labels.get(plan, plan | capitalize) }}</p>
      {% if subscription.current_period_end %}
        <p class="mt-1 text-xs text-slate-400">
          Active until {{ subscription.current_period_end.strftime('%d %b %Y') }}
        </p>
      {% endif %}
    </div>
    <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-300 ring-1 ring-emerald-500/30">
      {% if subscription.max_projects >= 999 %}Unlimited websites{% else %}{{ subscription.max_projects }} website{{ 's' if subscription.max_projects != 1 }}{% endif %}
    </span>
  </div>

  {# ── Payment error/success banners ── #}
  <div x-show="errorMsg" x-cloak
       class="rounded-lg border border-rose-700/60 bg-rose-950/40 px-4 py-3 text-sm text-rose-100">
    <span x-text="errorMsg"></span>
  </div>
  <div x-show="successMsg" x-cloak
       class="rounded-lg border border-emerald-700/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-100">
    <span x-text="successMsg"></span>
  </div>

  {# ── Pricing cards ── #}
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {% for p in plans %}
      <div class="relative flex flex-col rounded-2xl border {{ 'border-emerald-500/60 bg-emerald-500/5 ring-1 ring-emerald-500/30' if p.highlight else 'border-slate-800 bg-slate-900/60' }} p-5">
        {% if p.highlight %}
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-bold text-slate-950">Most Popular</span>
        {% endif %}
        <p class="text-base font-semibold text-white">{{ p.name }}</p>
        <p class="text-xs text-slate-500">{{ p.subtitle }}</p>
        <p class="mt-2 text-2xl font-bold text-white">{{ p.price }}<span class="text-sm font-normal text-slate-400">/{{ p.period }}</span></p>
        <p class="mt-3 text-sm text-slate-400">
          <span class="font-semibold text-emerald-300">{{ p.sites }} website{{ 's' if p.sites != '1' }}</span>
        </p>
        <p class="mt-1 text-xs text-slate-500">{{ p.specs }}</p>
        <ul class="mt-3 space-y-1 text-xs text-slate-400">
          <li>✓ Static site hosting</li>
          <li>✓ Custom domain support</li>
          <li>✓ 1-year validity</li>
        </ul>
        <div class="mt-4 flex-1 flex items-end">
          {% if subscription.plan_slug == p.slug and subscription.is_active and subscription.is_paid %}
            <span class="w-full text-center rounded-lg border border-emerald-600/40 bg-emerald-500/10 px-4 py-2.5 text-sm font-semibold text-emerald-300">
              ✓ Current Plan
            </span>
          {% else %}
            <button
              @click="pay('{{ p.slug }}', '{{ p.price }}', '{{ p.name }}')"
              :disabled="loading"
              class="w-full rounded-lg {{ 'bg-emerald-500 hover:bg-emerald-400 text-slate-950' if p.highlight else 'bg-slate-700 hover:bg-slate-600 text-white' }} px-4 py-2.5 text-sm font-semibold transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
              <span x-show="loading && activePlan === '{{ p.slug }}'" x-cloak>Processing…</span>
              <span x-show="!(loading && activePlan === '{{ p.slug }}')">Buy Now — {{ p.price }}/yr</span>
            </button>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {# ── Coupon redemption form ── #}
  <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
    <h2 class="text-base font-semibold text-white">Have a Coupon Code?</h2>
    <p class="mt-1 text-sm text-slate-400">Enter it below to activate your plan instantly — no payment needed.</p>

    {% if form.errors or form.non_field_errors() %}
      <div class="mt-4 rounded-lg border border-rose-700/60 bg-rose-950/40 px-4 py-3 text-sm text-rose-100">
        {% for err in form.non_field_errors() %}{{ err }}{% endfor %}
        {% for field in form %}{% for err in field.errors %}{{ err }}{% endfor %}{% endfor %}
      </div>
    {% endif %}

    <form method="post" action="{{ url('billing:redeem') }}" class="mt-5 space-y-4">
      {{ csrf_input }}
      <div>
        <label for="{{ form.code.id_for_label }}" class="block text-sm font-medium text-slate-200">
          {{ form.code.label }}
        </label>
        {{ form.code }}
        {% if form.code.errors %}
          {% for err in form.code.errors %}
            <p class="mt-1 text-sm text-rose-300">{{ err }}</p>
          {% endfor %}
        {% endif %}
      </div>
      <button type="submit"
        class="inline-flex items-center gap-2 rounded-lg bg-slate-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-600 active:scale-95 transition-transform">
        Activate with Coupon
      </button>
    </form>
  </div>

</section>

<script>
function razorpayCheckout() {
  return {
    loading: false,
    activePlan: '',
    errorMsg: '',
    successMsg: '',
    csrfToken: document.querySelector('meta[name="csrf-token"]').content,

    async pay(planSlug, planPrice, planName) {
      this.errorMsg = '';
      this.successMsg = '';
      this.loading = true;
      this.activePlan = planSlug;

      try {
        const orderRes = await fetch('{{ url("billing:create_order") }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': this.csrfToken,
          },
          body: JSON.stringify({ plan_slug: planSlug }),
        });

        const orderData = await orderRes.json();
        if (!orderRes.ok) {
          this.errorMsg = orderData.error || 'Failed to initiate payment. Please try again.';
          this.loading = false;
          return;
        }

        const self = this;
        const options = {
          key: '{{ razorpay_key_id }}',
          amount: orderData.amount,
          currency: orderData.currency,
          name: 'StudentCloud Deploy',
          description: planName + ' — 1 Year',
          order_id: orderData.order_id,
          theme: { color: '#10b981' },
          handler: async function(response) {
            try {
              const verifyRes = await fetch('{{ url("billing:verify_payment") }}', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRFToken': self.csrfToken,
                },
                body: JSON.stringify({
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_signature: response.razorpay_signature,
                  plan_slug: planSlug,
                }),
              });
              const verifyData = await verifyRes.json();
              if (verifyRes.ok && verifyData.status === 'success') {
                self.successMsg = '🎉 Payment successful! You are now on ' + verifyData.label + '. Refreshing…';
                setTimeout(function() { window.location.reload(); }, 1800);
              } else {
                self.errorMsg = verifyData.error || 'Payment verified but plan activation failed. Contact support.';
              }
            } catch(e) {
              self.errorMsg = 'Network error during verification. Contact support with your payment ID: ' + response.razorpay_payment_id;
            }
            self.loading = false;
          },
          modal: {
            ondismiss: function() {
              self.loading = false;
              self.activePlan = '';
            },
          },
          prefill: {
            email: '{{ request.user.email }}',
          },
        };

        const rzp = new Razorpay(options);
        rzp.on('payment.failed', function(response) {
          self.errorMsg = 'Payment failed: ' + (response.error.description || 'Please try again.');
          self.loading = false;
          self.activePlan = '';
        });
        rzp.open();

      } catch(e) {
        this.errorMsg = 'Network error. Please check your connection and try again.';
        this.loading = false;
      }
    },
  };
}
</script>
{% endblock %}
