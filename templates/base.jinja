<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% if csrf_token %}<meta name="csrf-token" content="{{ csrf_token }}">{% endif %}

  {# ── SEO: Title ── #}
  <title>{% block title %}{{ site_name }}{% endblock %}</title>

  {# ── SEO: Meta description ── #}
  <meta name="description" content="{% block meta_description %}Krizn — AI-powered cloud hosting for students and creators in India. Deploy websites and Flask apps free. Free SSL, custom domain, AI optimizer. Plans from ₹299.{% endblock %}">

  {# ── SEO: Robots — block must stay at top level (Jinja2 forbids block inside if) ── #}
  {# Private paths get noindex automatically; override {% block meta_robots %} in child templates if needed #}
  {% set _priv = request.path.startswith('/projects/') or request.path.startswith('/billing/')
      or request.path.startswith('/notifications/') or request.path.startswith('/onboarding/')
      or request.path.startswith('/admin/') or request.path.startswith('/ops/')
      or request.path.startswith('/trainer/') or request.path.startswith('/api/')
      or request.path.startswith('/sd/') %}
  {% block meta_robots %}<meta name="robots" content="{{ 'noindex, nofollow' if _priv else 'index, follow' }}">{% endblock %}

  {# ── SEO: Canonical ── #}
  <link rel="canonical" href="{% block canonical %}{{ request.scheme }}://{{ request.get_host() }}{{ request.path }}{% endblock %}">

  {# ── SEO: Open Graph ── #}
  <meta property="og:type" content="{% block og_type %}website{% endblock %}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:title" content="{% block og_title %}{{ site_name }}{% endblock %}">
  <meta property="og:description" content="{% block og_description %}Krizn — AI-powered cloud hosting for students in India. Free 2-day trial. Deploy in under 2 minutes.{% endblock %}">
  <meta property="og:url" content="{{ request.scheme }}://{{ request.get_host() }}{{ request.path }}">
  {# og:image added per-page via {% block og_image %} once assets exist #}
  {% block og_image %}{% endblock %}

  {# ── SEO: Twitter Card ── #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% block twitter_title %}{{ site_name }}{% endblock %}">
  <meta name="twitter:description" content="{% block twitter_description %}AI-powered cloud hosting for students in India. Free trial. Plans from ₹299.{% endblock %}">
  {# twitter:image added per-page via {% block twitter_image %} once assets exist #}
  {% block twitter_image %}{% endblock %}

  {# ── SEO: JSON-LD structured data (override per page) ── #}
  {% block json_ld %}{% endblock %}
  <link rel="stylesheet" href="{{ static('css/tailwind.css') }}">
  <script src="{{ static('js/htmx.min.js') }}" defer></script>
  <script src="{{ static('js/alpine.min.js') }}" defer></script>
  <script>
    document.addEventListener('htmx:configRequest', function (event) {
      var token = document.querySelector('meta[name="csrf-token"]');
      if (token && token.content) {
        event.detail.headers['X-CSRFToken'] = token.content;
      }
    });

  </script>
  <style>
    .htmx-indicator { opacity: 0; transition: opacity 150ms ease; }
    .htmx-request.htmx-indicator,
    form.htmx-request .htmx-indicator { opacity: 1; }
    [x-cloak] { display: none !important; }
    @keyframes promo-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  </style>
</head>
<body class="min-h-full antialiased">
  <div class="mx-auto flex min-h-full max-w-6xl flex-col px-4 py-6 sm:px-6 lg:px-8">
    {% include "partials/_nav.jinja" %}
    {% include "partials/_messages.jinja" %}
    <main class="flex-1 pt-6">
      {% block content %}{% endblock %}
    </main>
  </div>
  {% block extra_js %}{% endblock %}

  {# ── Auto-logout after 30 min of inactivity (authenticated users only) ── #}
  {% if request.user is defined and request.user.is_authenticated %}
  {# Hidden logout form — submitted by JS when timeout fires #}
  <form id="auto-logout-form" method="post" action="{{ url('accounts:logout') }}" style="display:none">
    {{ csrf_input }}
  </form>

  {# Warning toast — appears at 25 min, dismissed on any activity #}
  <div id="inactivity-toast"
       style="display:none;position:fixed;bottom:24px;right:24px;z-index:9999;
              max-width:320px;border-radius:14px;padding:14px 18px;
              background:#1e293b;border:1px solid rgba(245,158,11,0.5);
              box-shadow:0 8px 32px rgba(0,0,0,0.5);">
    <div style="display:flex;align-items:flex-start;gap:10px;">
      <span style="font-size:20px;line-height:1">⏱</span>
      <div style="flex:1;min-width:0">
        <p style="margin:0;font-size:13px;font-weight:700;color:#fbbf24">Still there?</p>
        <p style="margin:4px 0 10px;font-size:12px;color:#94a3b8;line-height:1.4">
          You'll be logged out in <strong id="inactivity-countdown" style="color:#f1f5f9">5:00</strong> due to inactivity.
        </p>
        <button onclick="window.__resetInactivityTimer()"
                style="padding:5px 14px;border-radius:8px;border:none;cursor:pointer;
                       background:#10b981;color:#0f172a;font-size:12px;font-weight:700">
          Stay logged in
        </button>
      </div>
    </div>
  </div>

  <script>
  (function () {
    var WARN_MS   = 25 * 60 * 1000;  /* show toast at 25 min */
    var LOGOUT_MS = 30 * 60 * 1000;  /* submit logout at 30 min */
    var toast     = document.getElementById('inactivity-toast');
    var countdown = document.getElementById('inactivity-countdown');
    var warnTimer, logoutTimer, countdownInterval;

    function fmtMs(ms) {
      var s = Math.max(0, Math.ceil(ms / 1000));
      return Math.floor(s / 60) + ':' + ('0' + (s % 60)).slice(-2);
    }

    function doLogout() {
      clearInterval(countdownInterval);
      document.getElementById('auto-logout-form').submit();
    }

    window.__resetInactivityTimer = function () {
      clearTimeout(warnTimer);
      clearTimeout(logoutTimer);
      clearInterval(countdownInterval);
      if (toast) toast.style.display = 'none';

      warnTimer = setTimeout(function () {
        if (toast) toast.style.display = 'block';
        /* Tick countdown every second */
        var remaining = LOGOUT_MS - WARN_MS;
        countdownInterval = setInterval(function () {
          remaining -= 1000;
          if (countdown) countdown.textContent = fmtMs(remaining);
          if (remaining <= 0) { clearInterval(countdownInterval); doLogout(); }
        }, 1000);
      }, WARN_MS);

      logoutTimer = setTimeout(doLogout, LOGOUT_MS);
    };

    /* Reset on any real user activity */
    ['mousedown','mousemove','keydown','scroll','touchstart','click','wheel'].forEach(function(e){
      document.addEventListener(e, window.__resetInactivityTimer, { passive: true });
    });

    /* Start the clock */
    window.__resetInactivityTimer();
  })();
  </script>
  {% endif %}

</body>
</html>
